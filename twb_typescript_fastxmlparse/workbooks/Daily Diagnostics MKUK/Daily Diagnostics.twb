        <calculation class='tableau' formula='{FIXED : SUM(IF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date]&#10;THEN [Clicks]&#10;ELSE 0&#10;END)}' />
