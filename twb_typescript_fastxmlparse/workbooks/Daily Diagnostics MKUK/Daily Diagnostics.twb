    <worksheet name='Total Media Spend %'>
      <table>
        <view>
          <datasources>
            <datasource caption='all_data_daily | Project : mkuk_prod_ehr' name='sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv' />
            <datasource caption='all_data_daily_extract | Project : mkuk_prod_ehr' name='sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='End Date' datatype='date' default-value-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Calculation_5125940808907870209]' name='[End Date]' param-domain-type='range' role='measure' source-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Date]' type='quantitative' value='#2026-05-16#'>
              <calculation class='tableau' formula='#2026-05-16#' />
            </column>
            <column caption='Start Date' datatype='date' default-value-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Calculation_5125940808907751424]' name='[Start Date]' param-domain-type='range' role='measure' source-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Date]' type='quantitative' value='#2026-05-10#'>
              <calculation class='tableau' formula='#2026-05-10#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv'>
            <column caption='Affiliate Partner' datatype='string' name='[Affiliate Platform (copy)_5213690683213893633]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Channel] = &quot;Affiliate&quot; THEN [Platform]&#10;ELSE &quot;NA&quot; END' />
            </column>
            <column caption='Axis' datatype='integer' name='[Axis]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MIN(0)' />
            </column>
            <column caption='vs. Spend PoP (%) Output' datatype='string' name='[Calculation_1060316291232759811]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IIF([vs. Spend PoP (%)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. Spend PoP (%)])*100, 2))+&quot;%&quot;' />
            </column>
            <column caption='Date Flag - Previous Period' datatype='boolean' name='[Calculation_4607252809837096965]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date]' />
            </column>
            <column caption='Targeting Type' datatype='string' name='[Calculation_598415825521487872]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[customDimension1]' />
            </column>
            <column caption='Gender' datatype='string' name='[Calculation_598415825523118081]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[customDimension2]' />
            </column>
            <column caption='SubChannel' datatype='string' name='[Calculation_598415825524580361]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Subchannel]' />
            </column>
            <column caption='Funnel Stage' datatype='string' name='[Calculation_598415825524805642]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[customDimension10]' />
            </column>
            <column caption='Campaign Name' datatype='string' name='[Calculation_598415825525301259]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[CampaignName]' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[CampaignName]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[Channel]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column caption='Date Difference' datatype='integer' name='[Date Difference]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Parameters].[Start Date], [Parameters].[End Date])' />
            </column>
            <column caption='Date Filter' datatype='boolean' name='[Date Flag (copy)_4607252809764151296]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date]' />
