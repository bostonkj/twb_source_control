            </column>
            <column caption='vs. KPI 4 PoP (%)' datatype='real' name='[vs. KPI 4 PoP (%)]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[KPI 4] / [KPI 4 Previous Period] - 1' />
            </column>
            <column caption='vs. Plan KPI 4 (#)' datatype='real' name='[vs. Plan KPI 4 (#)]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IIF(ISNULL([Plan KPI 4]), NULL, [KPI 4] - [Plan KPI 4])' />
            </column>
            <column caption='vs. Plan KPI 4 (%) Output' datatype='string' name='[vs. Plan KPI 4 (%) Output]' role='measure' type='nominal'>
