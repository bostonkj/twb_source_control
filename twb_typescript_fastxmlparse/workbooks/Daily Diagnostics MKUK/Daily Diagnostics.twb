        <calculation class='tableau' formula='IIF([vs. Spend PoP (%)] &gt; 0, &quot;Green&quot;, &quot;Red&quot;)' />
      </column>
      <column caption='KPI 1 Previous Period' datatype='real' name='[KPI 1 Previous Period]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[KPI 1]&#13;&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue] END)&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue]END)})&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN SUM((IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue] END))})&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformRevenue] END)&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END)&#13;&#10;END' />
      </column>
      <column caption='KPI 2 Tooltip' datatype='string' name='[KPI 1 Tooltip (copy 2)_1408500832895889409]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[KPI 2]&#13;&#10; WHEN &apos;Spend&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;     &#13;&#10;    WHEN &apos;CPM&apos; THEN &apos;Spend / Impressions * 1000&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Impressions&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;CTR&apos; THEN &apos;Clicks / Impressions&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;        &#13;&#10;    WHEN &apos;CPC&apos; THEN &apos;Spend / Clicks&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN &apos;Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN &apos;Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Clicks&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web CVR&apos; THEN &apos;Web Orders / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web RPV&apos; THEN &apos;Web Revenue / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web CPO&apos; THEN &apos;Spend / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;  &#13;&#10;    WHEN &apos;Web Orders&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web AOV&apos; THEN &apos;Web Revenue / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web Revenue&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web ROAS&apos; THEN &apos;Web Revenue / Spend&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web Traffic&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;           &#13;&#10;    WHEN &apos;Web CPV&apos; THEN &apos;Spend / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    &#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Platform CVR&apos; THEN &apos;Platform Orders / Clicks&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN &apos;Platform Orders&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Platform AOV&apos; THEN &apos;Platform Revenue / Platform Orders&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;  WHEN &apos;Platform Revenue&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10; &#13;&#10;   WHEN &apos;Platform ROAS&apos; THEN &apos;Platform Revenue / Spend&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;END' />
      </column>
