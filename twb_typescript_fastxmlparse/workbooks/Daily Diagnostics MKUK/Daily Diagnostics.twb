            </column>
            <column caption='vs. Plan Spend (%) Output' datatype='string' name='[vs. Spend PoP (%) Output (copy)_1060316291233464324]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IIF([vs. Plan Spend (%)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. Plan Spend (%)])*100, 2))+&quot;%&quot;' />
            </column>
            <column caption='vs. Spend LY (%) Output' datatype='string' name='[vs. Spend PoP (%) Output (copy)_1060316291233910789]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IIF([vs. Spend LY (%)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. Spend LY (%)])*100, 2))+&quot;%&quot;' />
            </column>
