              <calculation class='tableau' formula='IF [Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date] THEN &quot;TY&quot;&#13;&#10;ELSEIF   [Date]&gt;=DATEADD(&apos;year&apos;,-1,[Parameters].[Start Date]+1) and [Date]&lt;=DATEADD(&apos;year&apos;,-1,[Parameters].[End Date]+1) THEN &apos;LY&apos;&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;END' />
