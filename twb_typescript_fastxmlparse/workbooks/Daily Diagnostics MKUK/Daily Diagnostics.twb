              <calculation class='tableau' formula='IIF([vs. KPI 3 LY (#)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;IF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 3 LY (#)]) &gt; 100000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([vs. KPI 3 LY (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 3 LY (#)]) &gt; 10000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([vs. KPI 3 LY (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 3 LY (#)]) &gt; 1000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([vs. KPI 3 LY (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 3 LY (#)]) &gt; 100000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([vs. KPI 3 LY (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 3 LY (#)]) &gt; 10000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([vs. KPI 3 LY (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 3 LY (#)]) &gt; 1000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([vs. KPI 3 LY (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;