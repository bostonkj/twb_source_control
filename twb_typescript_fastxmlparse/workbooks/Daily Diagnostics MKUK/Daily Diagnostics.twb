            <column caption='Date Filter' datatype='boolean' name='[Date Flag (copy)_4607252809764151296]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date]' />
