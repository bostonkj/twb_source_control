            <column caption='KPI 3 Tooltip' datatype='string' name='[KPI 1 Tooltip (copy 3)_1408500832895901698]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[KPI 2 (copy)_4147041245412098048]&#13;&#10; WHEN &apos;Spend&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;     &#13;&#10;    WHEN &apos;CPM&apos; THEN &apos;Spend / Impressions * 1000&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Impressions&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;CTR&apos; THEN &apos;Clicks / Impressions&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;        &#13;&#10;    WHEN &apos;CPC&apos; THEN &apos;Spend / Clicks&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Clicks&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web CVR&apos; THEN &apos;Web Orders / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web RPV&apos; THEN &apos;Web Revenue / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN &apos;Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN &apos;Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web CPO&apos; THEN &apos;Spend / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;  &#13;&#10;    WHEN &apos;Web Orders&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web AOV&apos; THEN &apos;Web Revenue / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web Revenue&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web ROAS&apos; THEN &apos;Web Revenue / Spend&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web Traffic&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;           &#13;&#10;    WHEN &apos;Web CPV&apos; THEN &apos;Spend / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    &#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Platform CVR&apos; THEN &apos;Platform Orders / Clicks&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN &apos;Platform Orders&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Platform AOV&apos; THEN &apos;Platform Revenue / Platform Orders&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;  WHEN &apos;Platform Revenue&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10; &#13;&#10;   WHEN &apos;Platform ROAS&apos; THEN &apos;Platform Revenue / Spend&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='KPI 3 Output' datatype='string' name='[KPI 3 Output]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 100000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 10000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 1000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 100000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 10000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 1000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 100000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 10000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 1000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;)&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 100000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 10000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 1000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 100000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 10000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 1000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 100000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 10000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 1000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 3])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 3]), 2))&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 3])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 3])*100,2))+&quot;%&quot;&#13;&#10;END' />
            </column>
            <column caption='KPI 3' datatype='real' name='[KPI 3]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[KPI 2 (copy)_4147041245412098048]&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlatformOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlatformRevenue] END)&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [Spend] END)    WHEN &apos;Total Web Revenue&apos; THEN SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue]END)})&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN SUM((IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue] END))})&#13;&#10;END' />
            </column>
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[PlatformOrders]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-format='c&quot;$&quot;#,##0;&quot;$&quot;-#,##0' default-type='quantitative' layered='true' name='[PlatformRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[Platform]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column caption='Previous Period End Date' datatype='date' default-format='S' name='[Previous Period End Date]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE(DATEADD(&apos;day&apos;, -1, [Parameters].[Start Date]))' />
            </column>
            <column caption='Previous Period Start Date' datatype='date' default-format='S' name='[Previous Period Start Date]' role='dimension' type='ordinal'>
