      <column caption='Secondary KPI' datatype='real' name='[KPI 1 (copy)_4147041245423435780]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Primary KPI (copy)_4147041245423255555]&#10;    WHEN &quot;Spend&quot; THEN SUM([Spend])&#10;    WHEN &quot;CPM&quot; THEN (SUM([Spend]) / SUM([Impressions])) * 1000&#10;    WHEN &quot;Impressions&quot; THEN SUM([Impressions])&#10;    WHEN &quot;CTR&quot; THEN SUM([Clicks]) / SUM([Impressions])&#10;    WHEN &quot;CPC&quot; THEN SUM([Spend]) / SUM([Clicks])&#10;    WHEN &quot;Clicks&quot; THEN SUM([Clicks])&#10;    WHEN &quot;Web CVR&quot; THEN SUM([WebOrders]) / SUM([WebTraffic])&#10;    WHEN &quot;Web RPV&quot; THEN SUM([WebRevenue]) / SUM([WebTraffic])&#10;    WHEN &quot;Web CPO&quot; THEN SUM([Spend]) / SUM([WebOrders])&#10;    WHEN &quot;Web Orders&quot; THEN SUM([WebOrders])&#10;    WHEN &quot;Web AOV&quot; THEN SUM([WebRevenue]) / SUM([WebOrders])&#10;    WHEN &quot;Web Revenue&quot; THEN SUM([WebRevenue])&#10;    WHEN &quot;Web ROAS&quot; THEN SUM([WebRevenue]) / SUM([Spend])&#10;    WHEN &quot;Web Traffic&quot; THEN SUM([WebTraffic])&#10;    WHEN &quot;Web CPV&quot; THEN SUM([Spend]) / SUM([WebTraffic])&#10;    WHEN &quot;Platform CVR&quot; THEN SUM([PlatformOrders]) / SUM([Clicks])&#10;    WHEN &quot;Platform Orders&quot; THEN SUM([PlatformOrders])&#10;    WHEN &quot;Platform AOV&quot; THEN SUM([PlatformRevenue]) / SUM([PlatformOrders])&#10;    WHEN &quot;Platform Revenue&quot; THEN SUM([PlatformRevenue])&#10;    WHEN &quot;Platform ROAS&quot; THEN SUM([PlatformRevenue]) / SUM([Spend])&#10;    WHEN &apos;Total Web Revenue&apos; THEN SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;    WHEN &apos;% Total Web Revenue&apos; THEN SUM([WebRevenue]) / SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;END' />
      </column>
      <column caption='KPI 2 LY CF' datatype='real' name='[KPI 1 LY CF (copy 2)_1060316291239542794]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. KPI 2 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 2 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END' />
      </column>
      <column caption='KPI 3 LY CF' datatype='real' name='[KPI 1 LY CF (copy 3)_1060316291239567371]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. KPI 3 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 3 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END' />
      </column>
      <column caption='KPI 4 LY CF' datatype='real' name='[KPI 1 LY CF (copy)_1060316291239518217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. KPI 4 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 4 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END' />
      </column>
      <column caption='vs. Spend LY CF' datatype='string' hidden='true' name='[KPI 1 LY CF (copy)_1696449741421871104]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IIF([vs. Spend LY (%)]  &gt; 0, &quot;Green&quot;, &quot;Red&quot;)' />
      </column>
      <column caption='KPI 1 LY' datatype='real' name='[KPI 1 LY]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[KPI 1]&#13;&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [PlatformOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [PlatformRevenue] END)&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END)&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue]END)})&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN SUM((IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END))})&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Primary KPI Output' datatype='string' name='[KPI 1 Output (copy)_698902418656858112]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND [Secondary KPI (copy)_4147041245423730693] &gt; 1000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND([Secondary KPI (copy)_4147041245423730693] / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND [Secondary KPI (copy)_4147041245423730693] &gt; 1000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND([Secondary KPI (copy)_4147041245423730693] / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND [Secondary KPI (copy)_4147041245423730693] &gt; 1000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND([Secondary KPI (copy)_4147041245423730693] / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;)&#13;&#10;    THEN &quot;€&quot;+STR(ROUND([Secondary KPI (copy)_4147041245423730693]))&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND [Secondary KPI (copy)_4147041245423730693] &gt; 1000000000&#13;&#10;    THEN STR(ROUND([Secondary KPI (copy)_4147041245423730693] / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND [Secondary KPI (copy)_4147041245423730693] &gt; 1000000&#13;&#10;    THEN STR(ROUND([Secondary KPI (copy)_4147041245423730693] / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND [Secondary KPI (copy)_4147041245423730693] &gt; 1000&#13;&#10;    THEN STR(ROUND([Secondary KPI (copy)_4147041245423730693] / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;)&#13;&#10;    THEN STR(ROUND([Secondary KPI (copy)_4147041245423730693]))&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;€&quot;+STR(ROUND([Secondary KPI (copy)_4147041245423730693], 2))&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(([Secondary KPI (copy)_4147041245423730693])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 4 (copy)_4147041245423194114] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([Secondary KPI (copy)_4147041245423730693])*100,2))+&quot;%&quot;&#13;&#10;END' />
      </column>
      <column caption='KPI 1 Output' datatype='string' name='[KPI 1 Output]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 100000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 1]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 10000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 1]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 1000000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 1]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 100000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 1]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 10000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 1]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 1000000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 1]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 100000&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 1]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platfor