        <calculation class='tableau' formula='IF [Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date] THEN [Date] END' />
      </column>
      <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[Date]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
      <column aggregation='Year' datatype='date' default-type='ordinal' hidden='true' layered='true' name='[Date_LM]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
      <column aggregation='Year' datatype='date' default-type='ordinal' hidden='true' layered='true' name='[Date_LW]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
      <column aggregation='Year' datatype='date' default-type='ordinal' hidden='true' layered='true' name='[Date_LY]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
      <column caption='FCST CPC' datatype='real' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[FCST CPC]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTSpend]) / SUM([FCSTClicks])' />
      </column>
      <column caption='FCST CPM' datatype='real' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[FCST CPM]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTSpend]) / SUM([FCSTImpressions]) * 1000' />
      </column>
      <column caption='FCST CTR' datatype='real' default-format='p0.00%' name='[FCST CTR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTClicks]) / SUM([FCSTImpressions])' />
      </column>
      <column caption='FCST Web AOV' datatype='real' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[FCST Web AOV]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTWebRevenue]) / SUM([FCSTWebOrders])' />
      </column>
      <column caption='FCST Web CPO' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[FCST Web CPO]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTSpend]) / SUM([FCSTWebOrders])' />
      </column>
      <column caption='FCST Web CPV' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[FCST Web CPV]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTSpend]) / SUM([FCSTWebTraffic])' />
      </column>
      <column caption='FCST Web CVR' datatype='real' default-format='p0.00%' name='[FCST Web CVR]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTWebOrders]) / SUM([FCSTWebTraffic])' />
      </column>
      <column caption='FCST Web ROAS' datatype='real' default-format='c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00' name='[FCST Web ROAS]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([FCSTWebRevenue]) / SUM([FCSTSpend])' />
      </column>
      <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FCSTClicks]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
      <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FCSTImpressions]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
      <column aggregation='Sum' datatype='real' default-format='n&quot;$&quot;#,##0;-&quot;$&quot;#,##0' default-type='quantitative' layered='true' name='[FCSTSpend]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
      <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FCSTWebOrders]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
      <column aggregation='Sum' datatype='real' default-format='c&quot;$&quot;#,##0' default-type='quantitative' layered='true' name='[FCSTWebRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
      <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FCSTWebTraffic]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
      <column caption='Impressions Previous Period' datatype='integer' name='[Impressions Previous Period]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : SUM(IF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date]&#10;THEN [Impressions]&#10;ELSE 0&#10;END)}' />
      </column>
