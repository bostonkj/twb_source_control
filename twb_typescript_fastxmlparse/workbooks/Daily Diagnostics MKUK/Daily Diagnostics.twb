              <calculation class='tableau' formula='[customDimension2]' />
            </column>
            <column caption='SubChannel' datatype='string' name='[Calculation_598415825524580361]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Subchannel]' />
            </column>
            <column caption='Funnel Stage' datatype='string' name='[Calculation_598415825524805642]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[customDimension10]' />
            </column>
            <column caption='Campaign Name' datatype='string' name='[Calculation_598415825525301259]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[CampaignName]' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[CampaignName]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[Channel]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[Clicks]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='Date Difference' datatype='integer' name='[Date Difference]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Parameters].[Start Date], [Parameters].[End Date])' />
            </column>
            <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[Date]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[Impressions]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='KPI 2 LY CF' datatype='real' name='[KPI 1 LY CF (copy 2)_1060316291239542794]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. KPI 2 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 2 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END' />
            </column>
            <column caption='KPI 2 PoP CF' datatype='real' name='[KPI 1 PoP CF (copy 2)_1060316291239923725]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. KPI 2 PoP (#)]*-1 &#13;&#10;    ELSE [vs. KPI 2 PoP (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END' />
            </column>
            <column caption='KPI 2 LY' datatype='real' name='[KPI 2 LY]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[KPI 2]&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; TH