            <column caption='Plan KPI 2 CF' datatype='real' name='[Plan KPI 1 CF (copy 2)_1060316291240255504]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. Plan KPI 2 (%)]*-1 &#13;&#10;    ELSE [vs. Plan KPI 2 (%)] //Default: positive numbers are Green and negative are Red&#13;&#10;END' />
            </column>
            <column caption='Plan KPI 2' datatype='real' name='[Plan KPI 2]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[KPI 2]&#10; WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanImpressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanImpressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanClicks] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanImpressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanClicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanClicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot;  THEN NULL&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN NULL&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN NULL&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN NULL&#13;&#10;END' />
            </column>
