          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv'>
            <column caption='Affiliate Partner' datatype='string' name='[Affiliate Platform (copy)_5213690683213893633]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Channel] = &quot;Affiliate&quot; THEN [Platform]&#10;ELSE &quot;NA&quot; END' />
