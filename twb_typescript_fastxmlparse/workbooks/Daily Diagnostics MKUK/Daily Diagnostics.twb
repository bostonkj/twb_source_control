          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv'>
            <column caption='Affiliate Partner' datatype='string' name='[Affiliate Platform (copy)_5213690683213893633]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Channel] = &quot;Affiliate&quot; THEN [Platform]&#10;ELSE &quot;NA&quot; END' />
            </column>
            <column caption='Axis' datatype='integer' name='[Axis]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MIN(0)' />
            </column>
            <column caption='Date Flag' datatype='string' name='[Calculation_1009650805398740992]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date] THEN &quot;TY&quot;&#13;&#10;ELSEIF   [Date]&gt;=DATEADD(&apos;year&apos;,-1,[Parameters].[Start Date]+1) and [Date]&lt;=DATEADD(&apos;year&apos;,-1,[Parameters].[End Date]+1) THEN &apos;LY&apos;&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;END' />
            </column>
