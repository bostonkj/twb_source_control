      <column caption='Total Web Revenue' datatype='real' default-format='c&quot;$&quot;#,##0;&quot;$&quot;-#,##0' name='[Calculation_2049419372567126016]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue]END)})' />
      </column>
      <column caption='% Total Web Revenue' datatype='real' default-format='p0.00%' name='[Calculation_2049419372584763398]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM((IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue] END))}))' />
      </column>
      <column caption='Spend Output' datatype='string' name='[Calculation_2061241316276006912]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF  ([Spend]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([Spend]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  ([Spend]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([Spend]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF  ([Spend]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([Spend]) / 1000))+&quot;K&quot;&#13;&#10;END' />
      </column>
      <column caption='Select Dimension' datatype='string' name='[Calculation_2456924749637644288]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;    WHEN &quot;Date&quot; THEN STR([Date])&#13;&#10;    WHEN &quot;Platform&quot; THEN [Targeting Type (copy)_5213690683212029952]&#13;&#10;    WHEN &quot;Affiliate Partner&quot; THEN [Affiliate Platform (copy)_5213690683213893633]&#13;&#10;    WHEN &quot;Channel&quot; THEN [Channel]&#13;&#10;    WHEN &quot;Subchannel&quot; THEN [Calculation_598415825524580361]&#13;&#10;    WHEN &quot;Funnel Stage&quot; THEN [Calculation_598415825524805642]&#13;&#10;    WHEN &quot;Campaign&quot; THEN [Calculation_598415825525301259]&#10;END' />
