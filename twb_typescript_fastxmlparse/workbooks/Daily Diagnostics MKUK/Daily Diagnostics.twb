            <column caption='vs. KPI 4 LY (#)' datatype='real' name='[vs. KPI 4 LY (#)]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[KPI 4] - [KPI 4 LY]' />
            </column>
            <column caption='vs. KPI 4 LY (%) Output' datatype='string' name='[vs. KPI 4 LY (%) Output]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IIF([vs. KPI 4 LY (%)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. KPI 4 LY (%)])*100, 2))+&quot;%&quot;' />
            </column>
            <column caption='vs. KPI 4 LY (%)' datatype='real' name='[vs. KPI 4 LY (%)]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[KPI 4] / [KPI 4 LY] - 1' />
            </column>
            <column caption='vs. KPI 4 PoP (#)' datatype='real' name='[vs. KPI 4 PoP (#)]' role='measure' type='quantitative'>
