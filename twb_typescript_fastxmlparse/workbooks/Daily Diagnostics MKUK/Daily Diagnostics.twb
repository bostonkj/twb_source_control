        <calculation class='tableau' formula='[Date]&gt;=[Parameters].[Start Date (copy)_1874623398589341703] and [Date]&lt;=[Parameters].[End Date (copy)_1874623398589362184] &#10;&#10;/*&#10;IF [Date]&gt;=[Start Date 2] and [Date]&lt;=[End Date 2] THEN &quot;TY&quot;&#13;&#10;END&#10;*/' />
      </column>
      <column caption='Date Filter' datatype='boolean' name='[Date Flag (copy)_4607252809764151296]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date]' />
      </column>
