            <column caption='vs. Plan Spend (#)' datatype='real' default-format='c&quot;$&quot;#,##0;-&quot;$&quot;#,##0' name='[vs. Plan Spend (#)]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Spend]) - SUM([PlanSpend])' />
