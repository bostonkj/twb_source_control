            <column caption='Start Date' datatype='date' default-value-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Calculation_5125940808907751424]' name='[Start Date]' param-domain-type='range' role='measure' source-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Date]' type='quantitative' value='#2026-05-10#'>
