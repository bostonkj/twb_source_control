          <datasource-dependencies datasource='Parameters'>
            <column caption='End Date' datatype='date' default-value-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Calculation_5125940808907870209]' name='[End Date]' param-domain-type='range' role='measure' source-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Date]' type='quantitative' value='#2026-05-16#'>
              <calculation class='tableau' formula='#2026-05-16#' />
            </column>
            <column caption='Start Date' datatype='date' default-value-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Calculation_5125940808907751424]' name='[Start Date]' param-domain-type='range' role='measure' source-field='[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Date]' type='quantitative' value='#2026-05-10#'>
              <calculation class='tableau' formula='#2026-05-10#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv'>
            <column caption='Affiliate Partner' datatype='string' name='[Affiliate Platform (copy)_5213690683213893633]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Channel] = &quot;Affiliate&quot; THEN [Platform]&#10;ELSE &quot;NA&quot; END' />
            </column>
            <column caption='vs. Spend Output' datatype='string' name='[Calculation_581527309140324352]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF ABS(SUM([Spend])) &gt; 100000000000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000000)) + &quot;B&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 10000000000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000000, 1)) + &quot;B&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 1000000000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;ELSEIF ABS(SUM([Spend])) &gt; 100000000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000)) + &quot;M&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 10000000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000, 1)) + &quot;M&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 1000000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000, 2)) + &quot;M&quot;&#10;&#10;ELSEIF ABS(SUM([Spend])) &gt; 100000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000)) + &quot;K&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 10000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000, 1)) + &quot;K&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 1000&#10;    THEN &quot;€&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000, 2)) + &quot;K&quot;&#10;END' />
            </column>
            <column caption='Targeting Type' datatype='string' name='[Calculation_598415825521487872]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[customDimension1]' />
            </column>
            <column caption='Gender' datatype='string' name='[Calculation_598415825523118081]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[customDimension2]' />
            </column>
            <column caption='SubChannel' datatype='string' name='[Calculation_598415825524580361]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Subchannel]' />
            </column>
            <column caption='Funnel Stage' datatype='string' name='[Calculation_598415825524805642]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[customDimension10]' />
