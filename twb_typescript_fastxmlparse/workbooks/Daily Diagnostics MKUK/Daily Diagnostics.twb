 CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;€&quot;+STR(ROUND(ABS([KPI 4]), 2))&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 4])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 4])*100,2))+&quot;%&quot;&#13;&#10;END' />
