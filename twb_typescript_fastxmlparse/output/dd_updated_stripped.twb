      </column>
      <column caption="CPM LY" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[CPM LY]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend_LY (copy)_4607252809801973762]) / SUM([Impressions_LY (copy)_4607252810079092747]) * 1000"/>
      </column>
      <column caption="CPM Previous Period" datatype="real" default-format="C1033%" hidden="true" name="[CPM Previous Period]" role="measure" type="quantitative">
        <calculation class="tableau" formula="([Spend Previous Period])/SUM([Impressions Previous Period])*1000"/>
      </column>
      <column caption="CPM" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPM]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend]) / SUM([Impressions]) * 1000"/>
      </column>
      <column caption="CTR LM" datatype="real" default-format="p0.00%" hidden="true" name="[CTR LM]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Clicks_LM (copy)_4607252810079092742]) / SUM([Impressions_LM (copy)_4607252810079092745])"/>
      </column>
      <column caption="CTR LW" datatype="real" default-format="p0.00%" hidden="true" name="[CTR LW]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Clicks_LW (copy)_4607252810079092743]) / SUM([Impressions_LW (copy)_4607252810079092746])"/>
      </column>
      <column caption="CTR LY" datatype="real" default-format="p0.00%" hidden="true" name="[CTR LY]" role="measure" type="quantitative">
