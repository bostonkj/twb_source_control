            <column caption="vs. KPI 1 PoP (#) Output" datatype="string" name="[KPI 1 PoP (#) Output]" role="measure" type="nominal">
              <calculation class="tableau" formula="IIF([vs. KPI 1 PoP (#)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;IF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 100000000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 10000000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 1000000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 100000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 10000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 1000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 100000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 10000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 1 PoP (#)]) &gt; 1000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 1 PoP (#)]), 2))&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 1 PoP (#)])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 1])*100,2))+&quot;%&quot;&#13;&#10;END"/>
            </column>
            <column caption="Plan KPI 1 CF" datatype="real" name="[KPI 1 PoP CF (copy 2)_1060316291238060040]" role="measure" type="quantitative">
              <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 1] IN ('CPM', 'CPC', 'Web CPO', 'Web CPV')&#13;&#10;    THEN[vs. Plan KPI 1 (#)]*-1 &#13;&#10;    ELSE [vs. Plan KPI 1 (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"/>
