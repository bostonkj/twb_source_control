      </column>
      <column caption="Date Flag" datatype="string" name="[Calculation_1009650805398740992]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF [Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date] THEN &quot;TY&quot;&#13;&#10;ELSEIF   [Date]&gt;=DATEADD('year',-1,[Parameters].[Start Date]+1) and [Date]&lt;=DATEADD('year',-1,[Parameters].[End Date]+1) THEN 'LY'&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;END"/>
      </column>
      <column caption="vs. Spend TY" datatype="real" default-format="c&quot;$&quot;#,##0,K" hidden="true" name="[Calculation_1009650805404004353]" role="measure" type="quantitative">
        <calculation class="tableau" formula="sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END)"/>
      </column>
      <column caption="vs. Spend PoP (#) Output" datatype="string" name="[Calculation_1060316291224948736]" role="measure" type="nominal">
        <calculation class="tableau" formula="IIF(([vs. Spend PoP (#)]) &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+&#13;&#10;&#13;&#10;IF ABS([vs. Spend PoP (#)]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;END"/>
      </column>
      <column caption="vs. Spend PoP (%) Output" datatype="string" name="[Calculation_1060316291232759811]" role="measure" type="nominal">
        <calculation class="tableau" formula="IIF([vs. Spend PoP (%)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. Spend PoP (%)])*100, 2))+&quot;%&quot;"/>
      </column>
      <column caption="KPI 1 PoP CF" datatype="real" name="[Calculation_1060316291237552134]" role="measure" type="quantitative">
        <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 1] IN ('CPM', 'CPC', 'Web CPO', 'Web CPV')&#13;&#10;    THEN[vs. KPI 1 PoP (#)]*-1 &#13;&#10;    ELSE [vs. KPI 1 PoP (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"/>
      </column>
      <column caption="KPI 1 Tooltip" datatype="string" name="[Calculation_1198520500214992896]" role="dimension" type="nominal">
        <calculation class="tableau" formula="CASE [Parameters].[KPI 1]&#13;&#10;  WHEN 'Spend' THEN 'Sourced from Media Platforms'&#13;&#10;     &#13;&#10;    WHEN 'CPM' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Impressions' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'CTR' THEN 'Sourced from Media Platforms'&#13;&#10;        &#13;&#10;    WHEN 'CPC' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Clicks' THEN 'Sourced from Media Platforms'&#13;&#10;       &#13;&#10;    WHEN 'Web CVR' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web RPV' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web CPO' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;  &#13;&#10;    WHEN 'Web Orders' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web AOV' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web Revenue' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Total Web Revenue' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN '% Total Web Revenue' THEN 'Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web ROAS' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web Traffic' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;           &#13;&#10;    WHEN 'Web CPV' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Platform CVR' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN 'Platform Orders' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Platform AOV' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;  WHEN 'Platform Revenue' THEN 'Sourced from Media Platforms'&#13;&#10; &#13;&#10;   WHEN 'Platform ROAS' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;END"/>
      </column>
      <column caption="Refresh tooltip" datatype="string" name="[Calculation_1314488142121086976]" role="dimension" type="nominal">
        <calculation class="tableau" formula="'Refreshed weekly by 8am CT'"/>
