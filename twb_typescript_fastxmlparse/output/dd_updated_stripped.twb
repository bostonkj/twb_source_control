      <column caption="CPC LM" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPC LM]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend_LM (copy)_4607252810079092754]) / SUM([Clicks_LM (copy)_4607252810079092742])"/>
      </column>
      <column caption="CPC LW" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPC LW]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend_LW (copy)_4607252810079092755]) / SUM([Clicks_LW (copy)_4607252810079092743])"/>
      </column>
      <column caption="CPC LY" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPC LY]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend_LY (copy)_4607252809801973762]) / SUM([Clicks_LY (copy)_4607252810079092744])"/>
      </column>
      <column caption="CPC Previous Period" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[CPC Previous Period]" role="measure" type="quantitative">
        <calculation class="tableau" formula="([Spend Previous Period]) / SUM([Clicks Previous Period])"/>
      </column>
      <column caption="CPC" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPC]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend]) / SUM([Clicks])"/>
      </column>
      <column caption="CPM LM" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPM LM]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend_LM (copy)_4607252810079092754]) / SUM([Impressions_LM (copy)_4607252810079092745]) * 1000"/>
      </column>
      <column caption="CPM LW" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPM LW]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend_LW (copy)_4607252810079092755]) / SUM([Impressions_LW (copy)_4607252810079092746]) * 1000"/>
      </column>
      <column caption="CPM LY" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" name="[CPM LY]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([Spend_LY (copy)_4607252809801973762]) / SUM([Impressions_LY (copy)_4607252810079092747]) * 1000"/>
      </column>
      <column caption="CPM Previous Period" datatype="real" default-format="C1033%" hidden="true" name="[CPM Previous Period]" role="measure" type="quantitative">
        <calculation class="tableau" formula="([Spend Previous Period])/SUM([Impressions Previous Period])*1000"/>
