      <column caption="Total Web Revenue" datatype="real" default-format="c&quot;$&quot;#,##0;&quot;$&quot;-#,##0" hidden="true" name="[Calculation_2049419372567126016]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue]END)})"/>
