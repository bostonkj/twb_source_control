            <column caption="KPI 2 Tooltip" datatype="string" name="[KPI 1 Tooltip (copy 2)_1408500832895889409]" role="dimension" type="nominal">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 2]&#13;&#10;  WHEN 'Spend' THEN 'Sourced from Media Platforms'&#13;&#10;     &#13;&#10;    WHEN 'CPM' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Impressions' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'CTR' THEN 'Sourced from Media Platforms'&#13;&#10;        &#13;&#10;    WHEN 'CPC' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Clicks' THEN 'Sourced from Media Platforms'&#13;&#10;       &#13;&#10;    WHEN 'Web CVR' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web RPV' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web CPO' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;  &#13;&#10;    WHEN 'Web Orders' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web AOV' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web Revenue' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Total Web Revenue' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN '% Total Web Revenue' THEN 'Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web ROAS' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web Traffic' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;           &#13;&#10;    WHEN 'Web CPV' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Platform CVR' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN 'Platform Orders' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Platform AOV' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;  WHEN 'Platform Revenue' THEN 'Sourced from Media Platforms'&#13;&#10; &#13;&#10;   WHEN 'Platform ROAS' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;END"/>
            </column>
            <column caption="KPI 2 Output" datatype="string" name="[KPI 2 Output]" role="measure" type="nominal">
              <calculation class="tableau" formula="IF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 2]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 100000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 10000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 1000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 100000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 10000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 1000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 100000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 10000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 2]) &gt; 1000&#13;&#10;    THEN STR(ROUND(ABS([KPI 2]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 2])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2]), 2))&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 2])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 2])*100,2))+&quot;%&quot;&#13;&#10;END"/>
            </column>
            <column caption="KPI 2" datatype="real" name="[KPI 2]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 2]&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlatformOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlatformRevenue] END)&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END)&#13;&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue]END)})&#13;&#10;    WHEN '% Total Web Revenue' THEN SUM((IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END))})&#13;&#10;END"/>
