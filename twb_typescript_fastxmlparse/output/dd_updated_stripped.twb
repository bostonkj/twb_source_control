            <column caption="KPI 2 LY" datatype="real" name="[KPI 2 LY]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 2]&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformRevenue] END)&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END)&#13;&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue]END)})&#13;&#10;    WHEN '% Total Web Revenue' THEN SUM((IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END))})&#13;&#10;END"/>
