            <column caption="KPI 3 Output" datatype="string" name="[KPI 3 Output]" role="measure" type="nominal">
              <calculation class="tableau" formula="IF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 3]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 100000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 10000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 1000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 100000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 10000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 1000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 100000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 10000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 3]) &gt; 1000&#13;&#10;    THEN STR(ROUND(ABS([KPI 3]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 3])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 3]), 2))&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 3])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy)_4147041245412098048] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 3])*100,2))+&quot;%&quot;&#13;&#10;END"/>
            </column>
            <column caption="KPI 3" datatype="real" name="[KPI 3]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 2 (copy)_4147041245412098048]&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END)&#13;&#10;    