      <column caption="% Total Web Revenue" datatype="real" default-format="p0.00%" name="[Calculation_2049419372584763398]" role="measure" type="quantitative">
        <calculation class="tableau" formula="(SUM((IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = 'TY' THEN [WebRevenue] END))}))"/>
      </column>
      <column caption="Spend Output" datatype="string" hidden="true" name="[Calculation_2061241316276006912]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF  ([Spend]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([Spend]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  ([Spend]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([Spend]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF  ([Spend]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([Spend]) / 1000))+&quot;K&quot;&#13;&#10;END"/>
      </column>
      <column caption="Select Dimension" datatype="string" name="[Calculation_2456924749637644288]" role="dimension" type="nominal">
        <calculation class="tableau" formula="CASE [Parameters].[Parameter 2]&#10;    WHEN &quot;Platform&quot; THEN [Platform]&#10;    WHEN &quot;Channel&quot; THEN [Channel]&#10;    WHEN &quot;Goal&quot; THEN [Calculation_598415825521487872]&#10;    WHEN &quot;Budget Subchannel&quot; THEN [Calculation_598415825523118081]&#10;    WHEN &quot;EMR Subchannel&quot; THEN [Calculation_598415825523388418]&#10;    WHEN &quot;Tactic&quot; THEN [Calculation_598415825523662852]&#10;    WHEN &quot;Publisher&quot; THEN [Calculation_598415825524023301]&#10;    WHEN &quot;Category&quot; THEN [Calculation_598415825524154374]&#10;    WHEN &quot;Budget Objective&quot; THEN [Calculation_598415825524305927]&#10;    WHEN &quot;Testing&quot; THEN [Calculation_598415825524457480]&#10;    WHEN &quot;Budget Detail&quot; THEN [Calculation_598415825524580361]&#10;    WHEN &quot;Testing Name&quot; THEN [Calculation_598415825524805642]&#10;    WHEN &quot;Campaign&quot; THEN [Calculation_598415825525301259]&#10;END"/>
      </column>
