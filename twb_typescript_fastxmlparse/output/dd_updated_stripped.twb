      <column caption="FCST CPC" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST CPC]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTSpend]) / SUM([FCSTClicks])"/>
      </column>
      <column caption="FCST CPM" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST CPM]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTSpend]) / SUM([FCSTImpressions]) * 1000"/>
      </column>
      <column caption="FCST CTR" datatype="real" default-format="p0.00%" hidden="true" name="[FCST CTR]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTClicks]) / SUM([FCSTImpressions])"/>
      </column>
      <column caption="FCST Web AOV" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST Web AOV]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTWebRevenue]) / SUM([FCSTWebOrders])"/>
      </column>
      <column caption="FCST Web CPO" datatype="real" default-format="c&quot;$&quot;#,##0;-&quot;$&quot;#,##0" hidden="true" name="[FCST Web CPO]" role="measure" type="quantitative">
