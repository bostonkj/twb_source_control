              <calculation class="tableau" formula="CASE [Parameters].[KPI 4 (copy)_4147041245423194114]&#13;&#10; WHEN 'Spend' THEN 'Sourced from Media Platforms'&#13;&#10;     &#13;&#10;    WHEN 'CPM' THEN 'Spend / Impressions * 1000&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Impressions' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'CTR' THEN 'Clicks / Impressions&#13;&#10;Sourced from Media Platforms'&#13;&#10;        &#13;&#10;    WHEN 'CPC' THEN 'Spend / Clicks&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Clicks' THEN 'Sourced from Media Platforms'&#13;&#10;       &#13;&#10;    WHEN 'Web CVR' THEN 'Web Orders / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web RPV' THEN 'Web Revenue / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web CPO' THEN 'Spend / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;  &#13;&#10;    WHEN 'Web Orders' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Total Web Revenue' THEN 'Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN '% Total Web Revenue' THEN 'Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web AOV' THEN 'Web Revenue / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web Revenue' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web ROAS' THEN 'Web Revenue / Spend&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web Traffic' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;           &#13;&#10;    WHEN 'Web CPV' THEN 'Spend / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    &#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Platform CVR' THEN 'Platform Orders / Clicks&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN 'Platform Orders' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Platform AOV' THEN 'Platform Revenue / Platform Orders&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;  WHEN 'Platform Revenue' THEN 'Sourced from Media Platforms'&#13;&#10; &#13;&#10;   WHEN 'Platform ROAS' THEN 'Platform Revenue / Spend&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;END"/>
            </column>
            <column aggregation="Sum" datatype="integer" default-type="quantitative" hidden="true" layered="true" name="[PlatformOrders]" pivot="key" role="measure" type="quantitative" user-datatype="integer" visual-totals="Default"/>
            <column aggregation="Sum" datatype="real" default-format="c&quot;$&quot;#,##0;&quot;$&quot;-#,##0" default-type="quantitative" hidden="true" layered="true" name="[PlatformRevenue]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"/>
            <column aggregation="Count" datatype="string" default-type="nominal" layered="true" name="[Platform]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"/>
            <column caption="Primary KPI Contribution" datatype="real" default-format="p0.00%" name="[Primary KPI (copy)_698902418725126146]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 4 (copy)_4147041245423194114]&#10;    WHEN &quot;Spend&quot; THEN SUM([Spend]) / WINDOW_SUM(SUM([Spend]))&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED : SUM([WebRevenue]) }) / WINDOW_SUM(SUM({ FIXED : SUM([WebRevenue]) }))&#10;    WHEN '% Total Web Revenue' THEN SUM([WebRevenue]) / SUM({ FIXED : SUM([WebRevenue]) }) / WINDOW_SUM(SUM([WebRevenue]) / SUM({ FIXED : SUM([WebRevenue]) }))&#10;    WHEN &quot;CPM&quot; THEN ((SUM([Spend]) / SUM([Impressions])) * 1000) / WINDOW_SUM(((SUM([Spend]) / SUM([Impressions])) * 1000))&#10;    WHEN &quot;Impressions&quot; THEN SUM([Impressions]) / WINDOW_SUM(SUM([Impressions]))&#10;    WHEN &quot;CTR&quot; THEN (SUM([Clicks]) / SUM([Impressions])) / WINDOW_SUM((SUM([Clicks]) / SUM([Impressions])))&#10;    WHEN &quot;CPC&quot; THEN (SUM([Spend]) / SUM([Clicks])) / WINDOW_SUM((SUM([Spend]) / SUM([Clicks])))&#10;    WHEN &quot;Clicks&quot; THEN SUM([Clicks]) / WINDOW_SUM(SUM([Clicks]))&#10;    WHEN &quot;Web CVR&quot; THEN (SUM([WebOrders]) / SUM([WebTraffic])) / WINDOW_SUM((SUM([WebOrders]) / SUM([WebTraffic])))&#10;    WHEN &quot;Web CPO&quot; THEN (SUM([Spend]) / SUM([WebOrders])) / WINDOW_SUM((SUM([Spend]) / SUM([WebOrders])))&#10;    WHEN &quot;Web Orders&quot; THEN SUM([WebOrders]) / WINDOW_SUM(SUM([WebOrders]))&#10;    WHEN &quot;Web AOV&quot; THEN (SUM([WebRevenue]) / SUM([WebOrders])) / WINDOW_SUM((SUM([WebRevenue]) / SUM([WebOrders])))&#10;    WHEN &quot;Web Revenue&quot; THEN SUM([WebRevenue]) / WINDOW_SUM(SUM([WebRevenue]))&#10;    WHEN &quot;Web ROAS&quot; THEN (SUM([WebRevenue]) / SUM([Spend])) / WINDOW_SUM((SUM([WebRevenue]) / SUM([Spend])))&#10;    WHEN &quot;Web Traffic&quot; THEN SUM([WebTraffic]) / WINDOW_SUM(SUM([WebTraffic]))&#10;    WHEN &quot;Web CPV&quot; THEN (SUM([Spend]) / SUM([WebTraffic])) / WINDOW_SUM((SUM([Spend]) / SUM([WebTraffic])))&#10;    WHEN &quot;Platform CVR&quot; THEN (SUM([Spend]) / SUM([WebTraffic])) / WINDOW_SUM((SUM([Spend]) / SUM([WebTraffic])))&#10;    WHEN &quot;Platform Orders&quot; THEN SUM([PlatformOrders]) / WINDOW_SUM(SUM([PlatformOrders]))&#10;    WHEN &quot;Platform AOV&quot; THEN (SUM([PlatformRevenue]) / SUM([PlatformOrders])) / WINDOW_SUM((SUM([PlatformRevenue]) / SUM([PlatformOrders])))&#10;    WHEN &quot;Platform Revenue&quot; THEN SUM([PlatformRevenue]) / WINDOW_SUM(SUM([PlatformRevenue]))&#10;    WHEN &quot;Platform ROAS&quot; THEN (SUM([PlatformRevenue]) / SUM([Spend])) / WINDOW_SUM((SUM([PlatformRevenue]) / SUM([Spend])))&#10;END">
                <table-calc ordering-type="Rows"/>
              </calculation>
            </column>
            <column caption="Primary KPI" datatype="real" name="[Secondary KPI (copy)_4147041245423730693]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 4 (copy)_4147041245423194114]&#10;    WHEN &quot;Spend&quot; THEN SUM([Spend])&#10;    WHEN &quot;CPM&quot; THEN (SUM([Spend]) / SUM([Impressions])) * 1000&#10;    WHEN &quot;Impressions&quot; THEN SUM([Impressions])&#10;    WHEN &quot;CTR&quot; THEN SUM([Clicks]) / SUM([Impressions])&#10;    WHEN &quot;CPC&quot; THEN SUM([Spend]) / SUM([Clicks])&#10;    WHEN &quot;Clicks&quot; THEN SUM([Clicks])&#10;    WHEN &quot;Web CVR&quot; THEN SUM([WebOrders]) / SUM([WebTraffic])&#10;    WHEN &quot;Web RPV&quot; THEN SUM([WebRevenue]) / SUM([WebTraffic])&#10;    WHEN &quot;Web CPO&quot; THEN SUM([Spend]) / SUM([WebOrders])&#10;    WHEN &quot;Web Orders&quot; THEN SUM([WebOrders])&#10;    WHEN &quot;Web AOV&quot; THEN SUM([WebRevenue]) / SUM([WebOrders])&#10;    WHEN &quot;Web Revenue&quot; THEN SUM([WebRevenue])&#10;    WHEN &quot;Web ROAS&quot; THEN SUM([WebRevenue]) / SUM([Spend])&#10;    WHEN &quot;Web Traffic&quot; THEN SUM([WebTraffic])&#10;    WHEN &quot;Web CPV&quot; THEN SUM([Spend]) / SUM([WebTraffic])&#10;    WHEN &quot;Platform CVR&quot; THEN SUM([PlatformOrders]) / SUM([Clicks])&#10;    WHEN &quot;Platform Orders&quot; THEN SUM([PlatformOrders])&#10;    WHEN &quot;Platform AOV&quot; THEN SUM([PlatformRevenue]) / SUM([PlatformOrders])&#10;    WHEN &quot;Platform Revenue&quot; THEN SUM([PlatformRevenue])&#10;    WHEN &quot;Platform ROAS&quot; THEN SUM([PlatformRevenue]) / SUM([Spend])&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;    WHEN '% Total Web Revenue' THEN SUM([WebRevenue]) / SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;END"/>
