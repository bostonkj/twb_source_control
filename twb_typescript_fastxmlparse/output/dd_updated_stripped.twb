      <column caption="FCST Web CPV" datatype="real" default-format="c&quot;$&quot;#,##0;-&quot;$&quot;#,##0" hidden="true" name="[FCST Web CPV]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTSpend]) / SUM([FCSTWebTraffic])"/>
      </column>
      <column caption="FCST Web CVR" datatype="real" default-format="p0.00%" hidden="true" name="[FCST Web CVR]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTWebOrders]) / SUM([FCSTWebTraffic])"/>
      </column>
      <column caption="FCST Web ROAS" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST Web ROAS]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTWebRevenue]) / SUM([FCSTSpend])"/>
      </column>
