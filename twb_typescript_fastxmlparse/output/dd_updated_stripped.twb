              <calculation class="tableau" formula="IIF([vs. KPI 1 LY (#)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. KPI 1 LY (%)])*100, 2))+&quot;%&quot;"/>
