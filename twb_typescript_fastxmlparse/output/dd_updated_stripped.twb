Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 4 PoP (#)]) &gt; 100000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 4 PoP (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 4 PoP (#)]) &gt; 10000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 4 PoP (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 4 PoP (#)]) &gt; 1000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 4 PoP (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 4 PoP (#)]) &gt; 100000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 4 PoP (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 4 PoP (#)]) &gt; 10000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 4 PoP (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 4 PoP (#)]) &gt; 1000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 4 PoP (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&quot;CPM&qu