          <datasource-dependencies datasource="sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv">
            <column caption="Date Flag" datatype="string" name="[Calculation_1009650805398740992]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF [Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date] THEN &quot;TY&quot;&#13;&#10;ELSEIF   [Date]&gt;=DATEADD('year',-1,[Parameters].[Start Date]+1) and [Date]&lt;=DATEADD('year',-1,[Parameters].[End Date]+1) THEN 'LY'&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;END"/>
