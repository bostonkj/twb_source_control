        <calculation class="tableau" formula="CASE [Parameters].[KPI 4 (copy)_4147041245423194114]&#13;&#10; WHEN 'Spend' THEN 'Sourced from Media Platforms'&#13;&#10;     &#13;&#10;    WHEN 'CPM' THEN 'Spend / Impressions * 1000&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Impressions' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'CTR' THEN 'Clicks / Impressions&#13;&#10;Sourced from Media Platforms'&#13;&#10;        &#13;&#10;    WHEN 'CPC' THEN 'Spend / Clicks&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Clicks' THEN 'Sourced from Media Platforms'&#13;&#10;       &#13;&#10;    WHEN 'Web CVR' THEN 'Web Orders / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web RPV' THEN 'Web Revenue / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web CPO' THEN 'Spend / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;  &#13;&#10;    WHEN 'Web Orders' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Total Web Revenue' THEN 'Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN '% Total Web Revenue' THEN 'Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web AOV' THEN 'Web Revenue / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web Revenue' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web ROAS' THEN 'Web Revenue / Spend&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web Traffic' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;           &#13;&#10;    WHEN 'Web CPV' THEN 'Spend / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    &#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Platform CVR' THEN 'Platform Orders / Clicks&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN 'Platform Orders' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Platform AOV' THEN 'Platform Revenue / Platform Orders&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;  WHEN 'Platform Revenue' THEN 'Sourced from Media Platforms'&#13;&#10; &#13;&#10;   WHEN 'Platform ROAS' THEN 'Platform Revenue / Spend&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;END"/>
