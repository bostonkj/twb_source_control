      <column caption="KPI 1 LY CF" datatype="real" name="[KPI 1 PoP CF (copy)_1060316291238035463]" role="measure" type="quantitative">
        <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 1] IN ('CPM', 'CPC', 'Web CPO', 'Web CPV')&#13;&#10;    THEN[vs. KPI 1 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 1 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"/>
      </column>
      <column caption="KPI 4 PoP CF" datatype="real" name="[KPI 1 PoP CF (copy)_1060316291239903244]" role="measure" type="quantitative">
        <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN ('CPM', 'CPC', 'Web CPO', 'Web CPV')&#13;&#10;    THEN[vs. KPI 4 PoP (#)]*-1 &#13;&#10;    ELSE [vs. KPI 4 PoP (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"/>
      </column>
      <column caption="vs. Spend PoP CF" datatype="string" hidden="true" name="[KPI 1 PoP CF (copy)_1696449741421883393]" role="measure" type="nominal">
        <calculation class="tableau" formula="IIF([vs. Spend PoP (%)] &gt; 0, &quot;Green&quot;, &quot;Red&quot;)"/>
      </column>
      <column caption="KPI 1 Previous Period" datatype="real" name="[KPI 1 Previous Period]" role="measure" type="quantitative">
        <calculation class="tableau" formula="CASE [Parameters].[KPI 1]&#13;&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'PP' THEN [WebRevenue] END)&#13;&#10;    WHEN 'Total Web Revenue' THE