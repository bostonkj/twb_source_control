      <column aggregation="Count" datatype="string" default-type="nominal" hidden="true" layered="true" name="[Initiative]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"/>
      <column caption="Secondary KPI" datatype="real" name="[KPI 1 (copy)_4147041245423435780]" role="measure" type="quantitative">
        <calculation class="tableau" formula="CASE [Parameters].[Primary KPI (copy)_4147041245423255555]&#10;    WHEN &quot;Spend&quot; THEN SUM([Spend])&#10;    WHEN &quot;CPM&quot; THEN (SUM([Spend]) / SUM([Impressions])) * 1000&#10;    WHEN &quot;Impressions&quot; THEN SUM([Impressions])&#10;    WHEN &quot;CTR&quot; THEN SUM([Clicks]) / SUM([Impressions])&#10;    WHEN &quot;CPC&quot; THEN SUM([Spend]) / SUM([Clicks])&#10;    WHEN &quot;Clicks&quot; THEN SUM([Clicks])&#10;    WHEN &quot;Web CVR&quot; THEN SUM([WebOrders]) / SUM([WebTraffic])&#10;    WHEN &quot;Web RPV&quot; THEN SUM([WebRevenue]) / SUM([WebTraffic])&#10;    WHEN &quot;Web CPO&quot; THEN SUM([Spend]) / SUM([WebOrders])&#10;    WHEN &quot;Web Orders&quot; THEN SUM([WebOrders])&#10;    WHEN &quot;Web AOV&quot; THEN SUM([WebRevenue]) / SUM([WebOrders])&#10;    WHEN &quot;Web Revenue&quot; THEN SUM([WebRevenue])&#10;    WHEN &quot;Web ROAS&quot; THEN SUM([WebRevenue]) / SUM([Spend])&#10;    WHEN &quot;Web Traffic&quot; THEN SUM([WebTraffic])&#10;    WHEN &quot;Web CPV&quot; THEN SUM([Spend]) / SUM([WebTraffic])&#10;    WHEN &quot;Platform CVR&quot; THEN SUM([PlatformOrders]) / SUM([Clicks])&#10;    WHEN &quot;Platform Orders&quot; THEN SUM([PlatformOrders])&#10;    WHEN &quot;Platform AOV&quot; THEN SUM([PlatformRevenue]) / SUM([PlatformOrders])&#10;    WHEN &quot;Platform Revenue&quot; THEN SUM([PlatformRevenue])&#10;    WHEN &quot;Platform ROAS&quot; THEN SUM([PlatformRevenue]) / SUM([Spend])&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;    WHEN '% Total Web Revenue' THEN SUM([WebRevenue]) / SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;END"/>
      </column>
      <column caption="KPI 2 LY CF" datatype="real" name="[KPI 1 LY CF (copy 2)_1060316291239542794]" role="measure" type="quantitative">
        <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2] IN ('CPM', 'CPC', 'Web CPO', 'Web CPV')&#13;&#10;    THEN[vs. KPI 2 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 2 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"/>
      </column>
      <column caption="KPI 3 LY CF" datatype="real" name="[KPI 1 LY CF (copy 3)_1060316291239567371]" role="measure" type="quantitative">
        <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2 (copy)_4147041245412098048] IN ('CPM', 'CPC', 'Web CPO', 'Web CPV')&#13;&#10;    THEN[vs. KPI 3 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 3 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"/>
      </column>
      <column caption="KPI 4 LY CF" datatype="real" name="[KPI 1 LY CF (copy)_1060316291239518217]" role="measure" type="quantitative">
        <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN ('CPM', 'CPC', 'Web CPO', 'Web CPV')&#13;&#10;    THEN[vs. KPI 4 LY (#)]*-1 &#13;&#10;    ELSE [vs. KPI 4 LY (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"/>
      </column>
      <column caption="vs. Spend LY CF" datatype="string" hidden="true" name="[KPI 1 LY CF (copy)_1696449741421871104]" role="measure" type="nominal">
        <calculation class="tableau" formula="IIF([vs. Spend LY (%)]  &gt; 0, &quot;Green&quot;, &quot;Red&quot;)"/>
      </column>
      <column caption="KPI 1 LY" datatype="real" name="[KPI 1 LY]" role="measure" type="quantitative">
        <calculation class="tableau" formula="CASE [Parameters].[KPI 1]&#13;&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Clicks] END)&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformRevenue] END)&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'LY' THEN [Spend] END)&#13;&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue]END)})&#13;&#10;    WHEN '% Total Web Revenue' THEN SUM((IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = 'LY' THEN [WebRevenue] END))})&#13;&#10;&#13;&#10;END"/>
      </column>
