0992]) = 'TY' THEN [PlanWebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebTraffic] END)&#13;&#10;    WHEN 'Total Web Revenue' THEN NULL&#13;&#10;    WHEN '% Total Web Revenue' THEN NULL&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot;  THEN NULL&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN NULL&#13;&#10;END"/>
