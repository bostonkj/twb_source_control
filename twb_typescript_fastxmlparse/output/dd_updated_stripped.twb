        <calculation class="tableau" formula="CASE [Parameters].[KPI 1]&#13;&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanImpressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanImpressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanClicks] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanImpressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanClicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanClicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebTraffic] END)&#13;&#10;    WHEN 'Total Web Revenue' THEN NULL&#13;&#10;    WHEN '% Total Web Revenue' THEN NULL&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = 'TY' THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot;  THEN NULL&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN NULL&#13;&#10;END"/>
