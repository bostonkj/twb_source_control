            <column caption="vs. Plan KPI 2 (#)" datatype="real" name="[vs. Plan KPI 2 (#)]" role="measure" type="quantitative">
              <calculation class="tableau" formula="IIF(ISNULL([Plan KPI 2]), NULL, [KPI 2] - [Plan KPI 2])"/>
