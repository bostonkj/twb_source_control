) = &apos;PP&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformOrders] END)&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformRevenue] END)&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [PlatformRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [Spend] END)&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN SUM({ FIXED :SUM(IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue]END)})&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN SUM((IF ([Calculation_1009650805398740992]) = &apos;PP&apos; THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = 