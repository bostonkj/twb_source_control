            <column caption="Plan KPI 4 CF" datatype="real" name="[Plan KPI 1 CF (copy)_1060316291240189967]" role="measure" type="quantitative">
              <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 2 (copy) (copy)_4147041245412114433] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. Plan KPI 4 (#)]*-1 &#13;&#10;    ELSE [vs. Plan KPI 4 (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"></calculation>

              
