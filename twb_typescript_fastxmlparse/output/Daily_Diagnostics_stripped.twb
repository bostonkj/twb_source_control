            <column caption="vs. KPI 3 LY (%) Output" datatype="string" name="[vs. KPI 3 LY (%) Output]" role="measure" type="nominal">
              <calculation class="tableau" formula="IIF([vs. KPI 3 LY (%)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. KPI 3 LY (%)])*100, 2))+&quot;%&quot;"></calculation>

              
