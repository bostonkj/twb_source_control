              <calculation class="tableau" formula="[Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date]"></calculation>

              
                        </column>
            <column aggregation="Year" datatype="date" default-type="ordinal" layered="true" name="[Date]" pivot="key" role="dimension" type="ordinal" user-datatype="date" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="integer" default-type="quantitative" layered="true" name="[Impressions]" pivot="key" role="measure" type="quantitative" user-datatype="integer" visual-totals="Default"></column>
            <column caption="KPI 1 Output" datatype="string" name="[KPI 1 Output]" role="measure" type="nominal">
              <calculation class="tableau" formula="IF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([KPI 1]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 100000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 10000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 1000000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 100000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 10000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 1000000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 100000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 10000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([KPI 1]) &gt; 1000&#13;&#10;    THEN STR(ROUND(ABS([KPI 1]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 1])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 1]), 2))&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(ABS([KPI 1])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 1] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 1])*100,2))+&quot;%&quot;&#13;&#10;END"></calculation>

              
