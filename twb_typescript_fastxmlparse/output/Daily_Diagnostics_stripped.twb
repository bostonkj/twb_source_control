      <column caption="Impressions Previous Period" datatype="integer" hidden="true" name="[Impressions Previous Period]" role="measure" type="quantitative">
        <calculation class="tableau" formula="{FIXED : SUM(IF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date]&#10;THEN [Impressions]&#10;ELSE 0&#10;END)}"></calculation>

        
            </column>
