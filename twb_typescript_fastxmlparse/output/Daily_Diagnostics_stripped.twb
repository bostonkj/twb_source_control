            <column aggregation="Count" datatype="string" default-type="nominal" hidden="true" layered="true" name="[CampaignName]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column aggregation="Count" datatype="string" default-type="nominal" layered="true" name="[Channel]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
