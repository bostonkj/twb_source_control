              <calculation class="tableau" formula="IIF([vs. Plan Spend (#)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+&#13;&#10;IF ABS([vs. Plan Spend (#)]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF  ABS([vs. Plan Spend (#)]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Plan Spend (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;END"></calculation>

              
                        </column>
