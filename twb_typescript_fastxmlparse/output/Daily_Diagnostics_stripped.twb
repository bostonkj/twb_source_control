              <calculation class="tableau" formula="IF ABS(SUM([Spend])) &gt; 100000000000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000000)) + &quot;B&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 10000000000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000000, 1)) + &quot;B&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 1000000000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;ELSEIF ABS(SUM([Spend])) &gt; 100000000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000)) + &quot;M&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 10000000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000, 1)) + &quot;M&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 1000000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000000, 2)) + &quot;M&quot;&#10;&#10;ELSEIF ABS(SUM([Spend])) &gt; 100000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000)) + &quot;K&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 10000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000, 1)) + &quot;K&quot;&#10;ELSEIF ABS(SUM([Spend])) &gt; 1000&#10;    THEN &quot;$&quot; + STR(ROUND(ABS(SUM([Spend])) / 1000, 2)) + &quot;K&quot;&#10;END"></calculation>

              
