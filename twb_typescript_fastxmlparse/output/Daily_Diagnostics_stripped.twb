            <column caption="Primary KPI Label" datatype="string" name="[Primary KPI (copy)_773774772069158912]" role="dimension" type="nominal">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 4 (copy)_4147041245423194114]&#10;    WHEN &quot;Spend&quot; THEN &apos;Spend&apos;&#10;    WHEN &quot;CPM&quot; THEN &apos;CPM&apos;&#10;    WHEN &quot;Impressions&quot; THEN &apos;Impressions&apos;&#10;    WHEN &quot;CTR&quot; THEN &apos;CTR&apos;&#10;    WHEN &quot;CPC&quot; THEN &apos;CPC&apos;&#10;    WHEN &quot;Clicks&quot; THEN &apos;Clicks&apos;&#10;    WHEN &quot;Web CVR&quot; THEN &apos;Web CVR&apos;&#10;    WHEN &quot;Web CPO&quot; THEN &apos;Web CPO&apos;&#10;    WHEN &quot;Web Orders&quot; THEN &apos;Web Orders&apos;&#10;    WHEN &quot;Web AOV&quot; THEN &apos;Web AOV&apos;&#10;    WHEN &quot;Web Revenue&quot; THEN &apos;Web Revenue&apos;&#10;    WHEN &quot;Web ROAS&quot; THEN &apos;Web ROAS&apos;&#10;    WHEN &quot;Web Traffic&quot; THEN &apos;Web Traffic&apos;&#10;    WHEN &quot;Web CPV&quot; THEN &apos;Web CPV&apos;&#10;    WHEN &quot;Platform CVR&quot; THEN &apos;Platform CVR&apos;&#10;    WHEN &quot;Platform Orders&quot; THEN &apos;Platform Orders&apos;&#10;    WHEN &quot;Platform AOV&quot; THEN &apos;Platform AOV&apos;&#10;    WHEN &quot;Platform Revenue&quot; THEN &apos;Platform Revenue&apos;&#13;&#10;    WHEN &quot;Total Web Revenue&quot; THEN &apos;Total Web Revenue&apos;&#13;&#10;    WHEN &quot;% Total Web Revenue&quot; THEN &apos;% Total Web Revenue&apos;&#10;END"></calculation>

              
                        </column>
            <column caption="Secondary KPI Output" datatype="string" name="[Primary KPI Output (copy)_698902418663059457]" role="measure" type="nominal">
              <calculation class="tableau" formula="IF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND [KPI 1 (copy)_4147041245423435780] &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND([KPI 1 (copy)_4147041245423435780] / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND [KPI 1 (copy)_4147041245423435780] &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND([KPI 1 (copy)_4147041245423435780] / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND [KPI 1 (copy)_4147041245423435780] &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND([KPI 1 (copy)_4147041245423435780] / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND([KPI 1 (copy)_4147041245423435780]))&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND [KPI 1 (copy)_4147041245423435780] &gt; 1000000000&#13;&#10;    THEN STR(ROUND([KPI 1 (copy)_4147041245423435780] / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND [KPI 1 (copy)_4147041245423435780] &gt; 1000000&#13;&#10;    THEN STR(ROUND([KPI 1 (copy)_4147041245423435780] / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND [KPI 1 (copy)_4147041245423435780] &gt; 1000&#13;&#10;    THEN STR(ROUND([KPI 1 (copy)_4147041245423435780] / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;)&#13;&#10;    THEN STR(ROUND([KPI 1 (copy)_4147041245423435780]))&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND([KPI 1 (copy)_4147041245423435780], 2))&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 1 (copy)_4147041245423435780])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[Primary KPI (copy)_4147041245423255555] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 1 (copy)_4147041245423435780])*100,2))+&quot;%&quot;&#13;&#10;END"></calculation>

              
                        </column>
            <column caption="Primary KPI" datatype="real" name="[Secondary KPI (copy)_4147041245423730693]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 4 (copy)_4147041245423194114]&#10;    WHEN &quot;Spend&quot; THEN SUM([Spend])&#10;    WHEN &quot;CPM&quot; THEN (SUM([Spend]) / SUM([Impressions])) * 1000&#10;    WHEN &quot;Impressions&quot; THEN SUM([Impressions])&#10;    WHEN &quot;CTR&quot; THEN SUM([Clicks]) / SUM([Impressions])&#10;    WHEN &quot;CPC&quot; THEN SUM([Spend]) / SUM([Clicks])&#10;    WHEN &quot;Clicks&quot; THEN SUM([Clicks])&#10;    WHEN &quot;Web CVR&quot; THEN SUM([WebOrders]) / SUM([WebTraffic])&#10;    WHEN &quot;Web RPV&quot; THEN SUM([WebRevenue]) / SUM([WebTraffic])&#10;    WHEN &quot;Web CPO&quot; THEN SUM([Spend]) / SUM([WebOrders])&#10;    WHEN &quot;Web Orders&quot; THEN SUM([WebOrders])&#10;    WHEN &quot;Web AOV&quot; THEN SUM([WebRevenue]) / SUM([WebOrders])&#10;    WHEN &quot;Web Revenue&quot; THEN SUM([WebRevenue])&#10;    WHEN &quot;Web ROAS&quot; THEN SUM([WebRevenue]) / SUM([Spend])&#10;    WHEN &quot;Web Traffic&quot; THEN SUM([WebTraffic])&#10;    WHEN &quot;Web CPV&quot; THEN SUM([Spend]) / SUM([WebTraffic])&#10;    WHEN &quot;Platform CVR&quot; THEN SUM([PlatformOrders]) / SUM([Clicks])&#10;    WHEN &quot;Platform Orders&quot; THEN SUM([PlatformOrders])&#10;    WHEN &quot;Platform AOV&quot; THEN SUM([PlatformRevenue]) / SUM([PlatformOrders])&#10;    WHEN &quot;Platform Revenue&quot; THEN SUM([PlatformRevenue])&#10;    WHEN &quot;Platform ROAS&quot; THEN SUM([PlatformRevenue]) / SUM([Spend])&#10;    WHEN &apos;Total Web Revenue&apos; THEN SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;    WHEN &apos;% Total Web Revenue&apos; THEN SUM([WebRevenue]) / SUM({ FIXED [Date Flag (copy)_4607252809764151296]: SUM([WebRevenue]) })&#10;END"></calculation>

              
                        </column>
