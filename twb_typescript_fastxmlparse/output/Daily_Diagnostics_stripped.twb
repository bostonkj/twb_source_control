    <worksheet name="KPI 1 %">
      <table>
        <view>
          <datasources>
            <datasource caption="all_data_daily | Project : loft_prod_ehr" name="sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv"></datasource>
            <datasource caption="all_data_daily_export | Project : loft_prod_ehr" name="sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)"></datasource>
            <datasource name="Parameters"></datasource>

            
            
            
                    </datasources>
          <datasource-dependencies datasource="Parameters">
            <column caption="End Date" datatype="date" default-value-field="[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Calculation_5125940808907870209]" name="[End Date]" param-domain-type="range" role="measure" source-field="[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Date]" type="quantitative" value="#2026-05-23#">
              <calculation class="tableau" formula="#2026-05-23#"></calculation>

              
                        </column>
            <column caption="KPI 1" datatype="string" name="[KPI 1]" param-domain-type="list" role="measure" type="nominal" value="&quot;Web Revenue&quot;">
              <calculation class="tableau" formula="&quot;Web Revenue&quot;"></calculation>

              
                        </column>
            <column caption="Start Date" datatype="date" default-value-field="[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Calculation_5125940808907751424]" name="[Start Date]" param-domain-type="range" role="measure" source-field="[sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv (copy)].[Date]" type="quantitative" value="#2026-05-17#">
              <calculation class="tableau" formula="#2026-05-17#"></calculation>

              
                        </column>

            
            
            
                    </datasource-dependencies>
          <datasource-dependencies datasource="sqlproxy.0cwbr6b196dmu111xqfnl0sa93bv">
            <column caption="Axis" datatype="integer" name="[Axis]" role="measure" type="quantitative">
              <calculation class="tableau" formula="MIN(0)"></calculation>

              
                        </column>
            <column caption="Date Flag" datatype="string" name="[Calculation_1009650805398740992]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF [Date]&gt;=[Parameters].[Start Date] and [Date]&lt;=[Parameters].[End Date] THEN &quot;TY&quot;&#13;&#10;ELSEIF   [Date]&gt;=DATEADD(&apos;year&apos;,-1,[Parameters].[Start Date]+1) and [Date]&lt;=DATEADD(&apos;year&apos;,-1,[Parameters].[End Date]+1) THEN &apos;LY&apos;&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;END"></calculation>

              
                        </column>
            <column caption="KPI 1 PoP CF" datatype="real" name="[Calculation_1060316291237552134]" role="measure" type="quantitative">
              <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 1] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. KPI 1 PoP (#)]*-1 &#13;&#10;    ELSE [vs. KPI 1 PoP (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"></calculation>

              
                        </column>
            <column caption="Goal" datatype="string" name="[Calculation_598415825521487872]" role="dimension" type="nominal">
              <calculation class="tableau" formula="[customDimension1]"></calculation>

              
                        </column>
            <column caption="Budget Subchannel" datatype="string" name="[Calculation_598415825523118081]" role="dimension" type="nominal">
              <calculation class="tableau" formula="[customDimension2]"></calculation>

              
                        </column>
            <column caption="Budget Detail" datatype="string" name="[Calculation_598415825524580361]" role="dimension" type="nominal">
              <calculation class="tableau" formula="[customDimension9]"></calculation>

              
                        </column>
            <column caption="Campaign Name" datatype="string" name="[Calculation_598415825525301259]" role="dimension" type="nominal">
              <calculation class="tableau" formula="[CampaignName]"></calculation>

              
                        </column>
            <column aggregation="Count" datatype="string" default-type="nominal" hidden="true" layered="true" name="[CampaignName]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column aggregation="Count" datatype="string" default-type="nominal" layered="true" name="[Channel]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="integer" default-type="quantitative" layered="true" name="[Clicks]" pivot="key" role="measure" type="quantitative" user-datatype="integer" visual-totals="Default"></column>
            <column caption="Date Difference" datatype="integer" hidden="true" name="[Date Difference]" role="measure" type="quantitative">
              <calculation class="tableau" formula="DATEDIFF(&apos;day&apos;, [Parameters].[Start Date], [Parameters].[End Date])"></calculation>

              
                        </column>
            <column aggregation="Year" datatype="date" default-type="ordinal" layered="true" name="[Date]" pivot="key" role="dimension" type="ordinal" user-datatype="date" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="integer" default-type="quantitative" layered="true" name="[Impressions]" pivot="key" role="measure" type="quantitative" user-datatype="integer" visual-totals="Default"></column>
            <column caption="KPI 1 LY" datatype="real" name="[KPI 1 LY]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 1]&#13;&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Impressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Clicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [Spend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apos; THEN [WebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;LY&apo