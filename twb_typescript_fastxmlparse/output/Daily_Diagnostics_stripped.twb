            <column caption="Plan KPI 1" datatype="real" name="[Plan KPI 1]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[KPI 1]&#13;&#10;    WHEN &quot;Spend&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END)&#13;&#10;    WHEN &quot;CPM&quot; THEN (sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanImpressions] END))*1000&#13;&#10;    WHEN &quot;Impressions&quot; THEN SUM(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanImpressions] END)&#13;&#10;    WHEN &quot;CTR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanClicks] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanImpressions] END)&#13;&#10;    WHEN &quot;CPC&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanClicks] END)&#13;&#10;    WHEN &quot;Clicks&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanClicks] END)&#13;&#10;    WHEN &quot;Web CVR&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Web RPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Web CPO&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web Orders&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web AOV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebOrders] END)&#13;&#10;    WHEN &quot;Web Revenue&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END)&#13;&#10;    WHEN &quot;Web ROAS&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebRevenue] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END)&#13;&#10;    WHEN &quot;Web Traffic&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN NULL&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN NULL&#13;&#10;    WHEN &quot;Web CPV&quot; THEN sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanSpend] END) / sum(IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [PlanWebTraffic] END)&#13;&#10;    WHEN &quot;Platform CVR&quot;  THEN NULL&#13;&#10;    WHEN &quot;Platform Orders&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform AOV&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform Revenue&quot; THEN NULL&#13;&#10;    WHEN &quot;Platform ROAS&quot; THEN NULL&#13;&#10;END"></calculation>

              
                        </column>
            <column aggregation="Sum" datatype="real" default-type="quantitative" layered="true" name="[PlanClicks]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="real" default-type="quantitative" layered="true" name="[PlanImpressions]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="real" default-format="c&quot;$&quot;#,##0;-&quot;$&quot;#,##0" default-type="quantitative" layered="true" name="[PlanSpend]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="integer" default-type="quantitative" hidden="true" layered="true" name="[PlanWebOrders]" pivot="key" role="measure" type="quantitative" user-datatype="integer" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="real" default-format="c&quot;$&quot;#,##0;&quot;$&quot;-#,##0" default-type="quantitative" hidden="true" layered="true" name="[PlanWebRevenue]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="integer" default-type="quantitative" hidden="true" layered="true" name="[PlanWebTraffic]" pivot="key" role="measure" type="quantitative" user-datatype="integer" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="integer" default-type="quantitative" hidden="true" layered="true" name="[PlatformOrders]" pivot="key" role="measure" type="quantitative" user-datatype="integer" visual-totals="Default"></column>
            <column aggregation="Sum" datatype="real" default-format="c&quot;$&quot;#,##0;&quot;$&quot;-#,##0" default-type="quantitative" hidden="true" layered="true" name="[PlatformRevenue]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
            <column aggregation="Count" datatype="string" default-type="nominal" layered="true" name="[Platform]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column caption="Previous Period End Date" datatype="date" default-format="S" name="[Previous Period End Date]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="DATE(DATEADD(&apos;day&apos;, -1, [Parameters].[Start Date]))"></calculation>

              
                        </column>
            <column caption="Previous Period Start Date" datatype="date" default-format="S" name="[Previous Period Start Date]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="DATE(DATEADD(&apos;day&apos;, -[Date Difference]-1, [Parameters].[Start Date]))"></calculation>

              
                        </column>
