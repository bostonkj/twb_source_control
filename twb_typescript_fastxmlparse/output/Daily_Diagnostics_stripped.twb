            <column aggregation="Count" datatype="string" default-type="nominal" hidden="true" layered="true" name="[customDimension2]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column aggregation="Count" datatype="string" default-type="nominal" hidden="true" layered="true" name="[customDimension9]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column caption="vs. KPI 2 LY (#) Output" datatype="string" name="[vs. KPI 2 LY (#) Output]" role="measure" type="nominal">
              <calculation class="tableau" formula="IIF([vs. KPI 2 LY (#)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;IF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;, &quot;Platform Revenue&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 100000000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 10000000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 1000000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 100000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 10000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 1000000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 100000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 10000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;) AND ABS([vs. KPI 2 LY (#)]) &gt; 1000&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;Impressions&quot;, &quot;Clicks&quot;, &quot;Web Orders&quot;, &quot;Web Traffic&quot;, &quot;Platform Orders&quot;)&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)])))&#13;&#10;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;CPM&quot;, &quot;CPC&quot;, &quot;Web CPO&quot;, &quot;Web AOV&quot;, &quot;Web ROAS&quot;, &quot;Web CPV&quot;,&quot;Web RPV&quot;,  &quot;Platform AOV&quot;, &quot;Platform ROAS&quot;)&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. KPI 2 LY (#)]), 2))&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;CTR&quot;, &quot;Web CVR&quot;,&quot;Platform CVR&quot;)&#13;&#10;    THEN STR(ROUND(ABS([vs. KPI 2 LY (#)])*100, 2))+&quot;%&quot;&#13;&#10;ELSEIF [Parameters].[KPI 2] IN (&quot;% Total Web Revenue&quot;)&#13;&#10;    THEN STR(ROUND(([KPI 2])*100,2))+&quot;%&quot;&#13;&#10;END"></calculation>

              
                        </column>
            <column caption="vs. KPI 2 LY (#)" datatype="real" name="[vs. KPI 2 LY (#)]" role="measure" type="quantitative">
              <calculation class="tableau" formula="[KPI 2] - [KPI 2 LY]"></calculation>

              
