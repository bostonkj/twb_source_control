      <column aggregation="Year" datatype="date" default-type="ordinal" hidden="true" layered="true" name="[Date_LY]" pivot="key" role="dimension" type="ordinal" user-datatype="date" visual-totals="Default"></column>
      <column caption="FCST CPC" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST CPC]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTSpend]) / SUM([FCSTClicks])"></calculation>

        
            </column>
      <column caption="FCST CPM" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST CPM]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTSpend]) / SUM([FCSTImpressions]) * 1000"></calculation>

        
            </column>
      <column caption="FCST CTR" datatype="real" default-format="p0.00%" hidden="true" name="[FCST CTR]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTClicks]) / SUM([FCSTImpressions])"></calculation>

        
            </column>
      <column caption="FCST Web AOV" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST Web AOV]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTWebRevenue]) / SUM([FCSTWebOrders])"></calculation>

        
            </column>
      <column caption="FCST Web CPO" datatype="real" default-format="c&quot;$&quot;#,##0;-&quot;$&quot;#,##0" hidden="true" name="[FCST Web CPO]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTSpend]) / SUM([FCSTWebOrders])"></calculation>

        
            </column>
      <column caption="FCST Web CPV" datatype="real" default-format="c&quot;$&quot;#,##0;-&quot;$&quot;#,##0" hidden="true" name="[FCST Web CPV]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTSpend]) / SUM([FCSTWebTraffic])"></calculation>

        
            </column>
      <column caption="FCST Web CVR" datatype="real" default-format="p0.00%" hidden="true" name="[FCST Web CVR]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTWebOrders]) / SUM([FCSTWebTraffic])"></calculation>

        
            </column>
      <column caption="FCST Web ROAS" datatype="real" default-format="c&quot;$&quot;#,##0.00;-&quot;$&quot;#,##0.00" hidden="true" name="[FCST Web ROAS]" role="measure" type="quantitative">
        <calculation class="tableau" formula="SUM([FCSTWebRevenue]) / SUM([FCSTSpend])"></calculation>

        
            </column>
      <column aggregation="Sum" datatype="real" default-type="quantitative" hidden="true" layered="true" name="[FCSTClicks]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
      <column aggregation="Sum" datatype="real" default-type="quantitative" hidden="true" layered="true" name="[FCSTImpressions]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
      <column aggregation="Sum" datatype="real" default-format="n&quot;$&quot;#,##0;-&quot;$&quot;#,##0" default-type="quantitative" hidden="true" layered="true" name="[FCSTSpend]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
      <column aggregation="Sum" datatype="real" default-type="quantitative" hidden="true" layered="true" name="[FCSTWebOrders]" pivot="key" role="measure" type="quantitative" user-datatype="real" visual-totals="Default"></column>
