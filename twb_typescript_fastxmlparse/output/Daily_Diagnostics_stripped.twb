            </column>
      <column caption="vs. Spend PoP (#) Output" datatype="string" name="[Calculation_1060316291224948736]" role="measure" type="nominal">
        <calculation class="tableau" formula="IIF(([vs. Spend PoP (#)]) &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+&#13;&#10;&#13;&#10;IF ABS([vs. Spend PoP (#)]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000))+&quot;K&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 10000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000,1))+&quot;K&quot;&#13;&#10;ELSEIF  ABS([vs. Spend PoP (#)]) &gt; 1000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([vs. Spend PoP (#)]) / 1000,2))+&quot;K&quot;&#13;&#10;END"></calculation>

        
            </column>
      <column caption="vs. Spend PoP (%) Output" datatype="string" name="[Calculation_1060316291232759811]" role="measure" type="nominal">
        <calculation class="tableau" formula="IIF([vs. Spend PoP (%)] &gt; 0, &quot;▲&quot;, &quot;▼&quot;)+STR(ROUND(ABS([vs. Spend PoP (%)])*100, 2))+&quot;%&quot;"></calculation>

        
            </column>
      <column caption="KPI 1 PoP CF" datatype="real" name="[Calculation_1060316291237552134]" role="measure" type="quantitative">
        <calculation class="tableau" formula="// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[KPI 1] IN (&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[vs. KPI 1 PoP (#)]*-1 &#13;&#10;    ELSE [vs. KPI 1 PoP (#)] //Default: positive numbers are Green and negative are Red&#13;&#10;END"></calculation>

        
            </column>
      <column caption="KPI 1 Tooltip" datatype="string" name="[Calculation_1198520500214992896]" role="dimension" type="nominal">
        <calculation class="tableau" formula="CASE [Parameters].[KPI 1]&#13;&#10;  WHEN &apos;Spend&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;     &#13;&#10;    WHEN &apos;CPM&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Impressions&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;CTR&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;        &#13;&#10;    WHEN &apos;CPC&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Clicks&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web CVR&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web RPV&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web CPO&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;  &#13;&#10;    WHEN &apos;Web Orders&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web AOV&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web Revenue&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN &apos;Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web ROAS&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web Traffic&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;           &#13;&#10;    WHEN &apos;Web CPV&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Platform CVR&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN &apos;Platform Orders&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Platform AOV&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;  WHEN &apos;Platform Revenue&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10; &#13;&#10;   WHEN &apos;Platform ROAS&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;END"></calculation>

        
            </column>
