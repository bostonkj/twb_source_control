            <column aggregation="Count" datatype="string" default-type="nominal" hidden="true" layered="true" name="[customDimension2]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column aggregation="Count" datatype="string" default-type="nominal" hidden="true" layered="true" name="[customDimension9]" pivot="key" role="dimension" type="nominal" user-datatype="string" visual-totals="Default"></column>
            <column caption="vs. KPI 1 LY (#) Output" datatype="string" name="[vs. KPI 1 LY (#) Output]" role="measure" type="nominal">
