      <column caption="% Total Web Revenue" datatype="real" default-format="p0.00%" name="[Calculation_2049419372584763398]" role="measure" type="quantitative">
        <calculation class="tableau" formula="(SUM((IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue]END))/SUM( { FIXED : SUM((IF ([Calculation_1009650805398740992]) = &apos;TY&apos; THEN [WebRevenue] END))}))"></calculation>

        
