      <column caption="vs. Plan Primary KPI (%)" datatype="real" default-format="p0.00%" name="[KPI 2-1 vs Plan Difference (copy)_1146729096431460388]" role="measure" type="quantitative">
        <calculation class="tableau" formula="([P-KPI 1 LY (copy)_1146729096431890469])/ZN([PL2  This Year (copy)_901282899121156154])-1"/>
      </column>
      <column caption="vs. Plan KPI 6 (#) Output" datatype="string" name="[KPI 2-1 vs Plan Difference Str (copy 2)_1146729096347410442]" role="measure" type="nominal">
        <calculation class="tableau" formula="IIF([KPI 2-1 Plan Difference (copy)_1793840067788312581] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;&#13;&#10;// $ metrics -&gt; currency formatting (€ + K/M/B)&#13;&#10;IF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#13;&#10;    &quot;Spend&quot;,&quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Media Revenue&quot;,&quot;Realized Media Revenue&quot;,&quot;Future Media Revenue&quot;,&#13;&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Count metrics -&gt; count formatting (K/M/B, no €)&#13;&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#13;&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#13;&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#13;&#10;    &quot;Platform Orders&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Rate / per metrics -&gt; 2dp currency&#13;&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#13;&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#13;&#10;    &quot;Media iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#13;&#10;    &quot;Media Return&quot;,&quot;Realized Return&quot;,&quot;Future Return&quot;,&quot;EMR Return&quot;,&#13;&#10;    &quot;iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#13;&#10;) THEN&#13;&#10;    &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]), 2))&#13;&#10;&#13;&#10;// Percent metrics -&gt; 2dp %&#13;&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;) THEN&#13;&#10;    STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]), 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;// Special case preserved exactly as provided (uses [KPI 6], not vs field)&#13;&#10;/*&#10;ELSEIF [Parameters].[KPI 6] IN (&quot;% Total Web Revenue&quot;) THEN&#13;&#10;    STR(ROUND(([KPI 6]) * 100, 2)) + &quot;%&quot;&#13;&#10;*/&#10;&#13;&#10;END"/>
      </column>
