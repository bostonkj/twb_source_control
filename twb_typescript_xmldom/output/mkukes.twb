            <column caption="KPI 6 Tooltip" datatype="string" name="[KPI 2-1 Tooltip (copy)_2290080459209846790]" role="dimension" type="nominal">
              <calculation class="tableau" formula="CASE [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929]&#13;&#10;    WHEN 'Spend' THEN 'Sourced from Media Platforms'&#13;&#10;     &#13;&#10;    WHEN 'CPM' THEN 'Spend / Impressions * 1000&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Impressions' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'CTR' THEN 'Clicks / Impressions&#13;&#10;Sourced from Media Platforms'&#13;&#10;        &#13;&#10;    WHEN 'CPC' THEN 'Spend / Clicks&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Clicks' THEN 'Sourced from Media Platforms'&#13;&#10;       &#13;&#10;    WHEN 'Web CVR' THEN 'Web Orders / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web RPV' THEN 'Web Revenue / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Total Web Revenue' THEN 'Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN '% Total Web Revenue' THEN 'Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web CPO' THEN 'Spend / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;  &#13;&#10;    WHEN 'Web Orders' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web AOV' THEN 'Web Revenue / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;       &#13;&#10;    WHEN 'Web Revenue' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web ROAS' THEN 'Web Revenue / Spend&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Web Traffic' THEN 'Sourced from Web Analytics (Adobe)'&#13;&#10;           &#13;&#10;    WHEN 'Web CPV' THEN 'Spend / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)'&#13;&#10;&#13;&#10;    WHEN 'Media Revenue' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Media iROAS' THEN 'Media Revenue / Spend&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Realized Media Revenue' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Realized iROAS' THEN 'Realized Media Revenue / Spend&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Future Media Revenue' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Future iROAS' THEN 'Future Media Revenue / Spend&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Media Value' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Media Return' THEN 'Media value / Spend&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Realized Media Value' THEN 'Sourced from MMM+'&#13;&#10;          &#13;&#10;   WHEN 'Realized Return' THEN 'Realized Media Value / Spend&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;       &#13;&#10;    WHEN 'Future Media Value' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;   WHEN 'Future Return' THEN 'Future Media Value / Spend&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'EMR Value' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;   WHEN 'EMR Return' THEN 'EMR Value/ Spend&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Incremental Total Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Incremental New Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'iCPA' THEN 'Spend / Incremental New Customers&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Incremental Current Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Incremental Reactivated Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;&#13;&#10;    WHEN 'Platform CVR' THEN 'Platform Orders / Clicks&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN 'Platform Orders' THEN 'Sourced from Media Platforms'&#13;&#10;&#13;&#10;    WHEN 'Platform AOV' THEN 'Platform Revenue / Platform Orders&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;  WHEN 'Platform Revenue' THEN 'Sourced from Media Platforms'&#13;&#10; &#13;&#10;   WHEN 'Platform ROAS' THEN 'Platform Revenue / Spend&#13;&#10;Sourced from Media Platforms'&#13;&#10;&#13;&#10;&#13;&#10;END"/>
            </column>
            <column caption="KPI 6" datatype="real" name="[KPI2-1 This Year (copy)_742812488104312836]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929]&#10;&#10;    WHEN 'Spend' THEN SUM([Calculation_2727985148704944162])&#10;    WHEN 'CPM' THEN (SUM([Calculation_2727985148704944162]) / SUM([Impressions]) * 1000)&#10;    WHEN 'Impressions' THEN SUM([Impressions])&#10;    WHEN 'CTR' THEN (SUM([Clicks]) / SUM([Impressions]))&#10;    WHEN 'CPC' THEN (SUM([Calculation_2727985148704944162]) / SUM([Clicks]))&#10;    WHEN 'Clicks' THEN SUM([Clicks])&#10;    WHEN 'Web CVR' THEN (SUM([WebOrders]) / SUM([WebTraffic]))&#10;    WHEN 'Web CPO' THEN (SUM([Calculation_2727985148704944162]) / SUM([WebOrders]))&#10;    WHEN 'Web Orders' THEN SUM([WebOrders])&#10;    WHEN 'Web AOV' THEN (SUM([WebRevenue]) / SUM([WebOrders]))&#10;    WHEN 'Web Revenue' THEN SUM([WebRevenue])&#10;    WHEN 'Web ROAS' THEN (SUM([WebRevenue]) / SUM([Spend]))&#10;    WHEN 'Web Traffic' THEN SUM([WebTraffic])&#10;    WHEN 'Web CPV' THEN (SUM([Calculation_2727985148704944162]) / SUM([WebTraffic]))&#10;    WHEN 'Media Revenue' THEN SUM([MediaRevenue])&#10;    WHEN 'Media iROAS' THEN [Calculation_2727985148333301764]&#10;    WHEN 'Realized Media Revenue' THEN SUM([RealizedMediaRevenue])&#10;    WHEN 'Realized iROAS' THEN [Media iROAS (copy)_2727985148334161926]&#10;    WHEN 'Future Media Revenue' THEN SUM([FutureMediaRevenue])&#10;    WHEN 'Future iROAS' THEN [Media iROAS (copy)_2727985148333957125]&#10;    WHEN 'Media Value' THEN SUM([MediaValue])&#10;    WHEN 'Media Return' THEN [Media iROAS (copy)_2727985148338708487]&#10;    WHEN 'Realized Media Value' THEN SUM([RealizedMediaValue])&#10;    WHEN 'Realized Return' THEN [Media Return (copy)_2727985148338884616]&#10;    WHEN 'Future Media Value' THEN SUM([FutureMediaValue])&#10;    WHEN 'Future Return' THEN [Media Return (copy)_2727985148339564553]&#10;    WHEN 'EMR Value' THEN SUM([EMRValue])&#10;    WHEN 'EMR Return' THEN [Calculation_2727985148330471427]&#10;    WHEN 'Incremental Total Customers' THEN SUM([IncrementalTotalCustomers])&#10;    WHEN 'Incremental New Customers' THEN SUM([IncrementalNewCustomers])&#10;    WHEN 'iCPA' THEN (SUM([Calculation_2727985148704944162]) / SUM([IncrementalNewCustomers]))&#10;    WHEN 'Incremental Current Customers' THEN SUM([IncrementalCurrentCustomers])&#10;    WHEN 'Incremental Reactivated Customers' THEN SUM([IncrementalReactivatedCustomers])&#10;    WHEN 'Platform CVR' THEN (SUM([PlatformOrders]) / SUM([Clicks]))&#10;    WHEN 'Platform Orders' THEN SUM([PlatformOrders])&#10;    WHEN 'Platform AOV' THEN (SUM([PlatformRevenue]) / SUM([PlatformOrders]))&#10;    WHEN 'Platform Revenue' THEN SUM([PlatformRevenue])&#10;    WHEN 'Platform ROAS' THEN (SUM([PlatformRevenue]) / SUM([Spend]))&#10;    WHEN 'Web RPV' THEN (SUM([WebRevenue]) / SUM([WebTraffic]))&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED : SUM([WebRevenue]) })&#10;    WHEN '% Total Web Revenue' THEN&#10;        SUM([WebRevenue]) / SUM({ FIXED : SUM([WebRevenue]) })&#10;&#10;END"/>
            </column>
            <column caption="Realized Return" datatype="real" name="[Media Return (copy)_2727985148338884616]" role="measure" type="quantitative">
              <calculation class="tableau" formula="(SUM&#10;    (IF [Calculation_2727985147991842816] = TRUE THEN [RealizedMediaValue] END)&#10;    )&#10;    /SUM([Calculation_2727985148704944162])"/>
            </column>
            <column caption="Future Return" datatype="real" name="[Media Return (copy)_2727985148339564553]" role="measure" type="quantitative">
              <calculation class="tableau" formula="(SUM&#10;    (IF [Calculation_2727985147991842816] = TRUE THEN [FutureMediaValue] END)&#10;    )&#10;    /SUM([Calculation_2727985148704944162])"/>
            </column>
            <column caption="Future iROAS" datatype="real" name="[Media iROAS (copy)_2727985148333957125]" role="measure" type="quantitative">
              <calculation class="tableau" formula="(SUM&#10;    (IF [Calculation_2727985147991842816] = TRUE THEN [FutureMediaRevenue] END)&#10;    )&#10;    /SUM([Calculation_2727985148704944162])"/>
