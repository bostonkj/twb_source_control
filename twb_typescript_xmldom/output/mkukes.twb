            <column caption="KPI 5 Output" datatype="string" name="[kpi1-1 str this year (copy)_1570067444781944842]" role="measure" type="nominal">
              <calculation class="tableau" formula="// Currency metrics -&gt; € + K/M/B&#13;&#10;IF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;        &quot;Spend&quot;,&quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Media Revenue&quot;,&quot;Realized Media Revenue&quot;,&quot;Future Media Revenue&quot;,&#13;&#10;        &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#13;&#10;    ) THEN&#13;&#10;&#13;&#10;        IF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 100000000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000000)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 10000000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 1000000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 100000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 10000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 1000000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 100000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000)) + &quot;K&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 10000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000, 1)) + &quot;K&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 1000 THEN &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000, 2)) + &quot;K&quot;&#13;&#10;        ELSE &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233])))&#13;&#10;        END&#13;&#10;&#13;&#10;    // Count metrics -&gt; K/M/B (no €)&#13;&#10;    ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;        &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#13;&#10;        &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#13;&#10;        &quot;Platform Orders&quot;&#13;&#10;    ) THEN&#13;&#10;&#13;&#10;        IF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 100000000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000000)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 10000000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 1000000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 100000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 10000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 1000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 100000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000)) + &quot;K&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 10000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000, 1)) + &quot;K&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy)_1329969288810631233]) &gt; 1000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]) / 1000, 2)) + &quot;K&quot;&#13;&#10;        ELSE STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233])))&#13;&#10;        END&#13;&#10;&#13;&#10;    // Rate metrics -&gt; € + 2 decimals&#13;&#10;    ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;        &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#13;&#10;        &quot;Media iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#13;&#10;        &quot;Media Return&quot;,&quot;Realized Return&quot;,&quot;Future Return&quot;,&#13;&#10;        &quot;EMR Return&quot;,&quot;iCPA&quot;,&#13;&#10;        &quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#13;&#10;    ) THEN&#13;&#10;        &quot;€&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]), 2))&#13;&#10;&#13;&#10;    // Percent metrics -&gt; xx.xx%&#13;&#10;    ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;) THEN&#13;&#10;        STR(ROUND(ABS([KPI1-1 This Year (copy)_1329969288810631233]), 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;    // Special percent -&gt; value*100%&#13;&#10;    ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&quot;% Total Web Revenue&quot;) THEN&#13;&#10;        STR(ROUND([KPI1-1 This Year (copy)_1329969288810631233] * 100, 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;END"/>
            </column>
