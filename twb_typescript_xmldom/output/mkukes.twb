            <column caption="vs. Spend TY" datatype="real" default-format="c&quot;$&quot;#,##0;&quot;$&quot;-#,##0" name="[Calculation_1146729096399511572]" role="measure" type="quantitative">
              <calculation class="tableau" formula="SUM(IF ([Calculation_1714182672546091008]) = &quot;TY&quot; AND [Parameters].[Parameter 12] = 'Store' THEN [Calculation_2727985148704944162]&#10;    ELSEIF [Calculation_1714182672546091008] = 'TY' THEN [Spend] END)"/>
