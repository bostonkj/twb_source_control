            <column caption="vs. Plan KPI 5 (#)" datatype="real" default-format="*+0.00;-0.00" name="[KPI 2-1 Period Difference (copy)_1793840067787829252]" role="measure" type="quantitative">
              <calculation class="tableau" formula="[KPI1-1 This Year (copy)_1329969288810631233]-[KPI 2-1 TY (copy)_1793840067784417280]&#10;//([KPI 5])-ZN([Plan KPI 5])"/>
            </column>
            <column caption="Plan KPI 5" datatype="real" name="[KPI 2-1 TY (copy)_1793840067784417280]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013]&#13;&#10;&#13;&#10;    WHEN 'Spend' THEN SUM([Spend All (copy)_3996311395817148417])&#13;&#10;    WHEN 'CPM' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanImpressions]) * 1000)&#13;&#10;    WHEN 'Impressions' THEN SUM([PlanImpressions])&#13;&#10;    WHEN 'CTR' THEN (SUM([PlanClicks]) / SUM([PlanImpressions]))&#13;&#10;    WHEN 'CPC' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanClicks]))&#13;&#10;    WHEN 'Clicks' THEN SUM([PlanClicks])&#13;&#10;    WHEN 'Web CVR' THEN (SUM([PlanWebOrders]) / SUM([PlanWebTraffic]))&#13;&#10;    WHEN 'Web CPO' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebOrders]))&#13;&#10;    WHEN 'Web Orders' THEN SUM([PlanWebOrders])&#13;&#10;    WHEN 'Web AOV' THEN (SUM([PlanWebRevenue]) / SUM([PlanWebOrders]))&#13;&#10;    WHEN 'Web Revenue' THEN SUM([PlanWebRevenue])&#10;&#13;&#10;    // Keeping your original behavior (it was effectively returning 0)&#13;&#10;    WHEN 'Total Web Revenue' THEN 0&#10;&#13;&#10;    WHEN 'Web ROAS' THEN (SUM([PlanWebRevenue]) / SUM([PlanSpend]))&#13;&#10;    WHEN 'Web Traffic' THEN SUM([PlanWebTraffic])&#13;&#10;    WHEN 'Web CPV' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebTraffic]))&#13;&#10;    WHEN 'Media Revenue' THEN SUM([PlanMediaRevenue])&#13;&#10;    WHEN 'Media iROAS' THEN [Media iROAS LY (copy)_2727985148349190165]&#13;&#10;    WHEN 'Realized Media Revenue' THEN SUM([PlanRealizedMediaRevenue])&#13;&#10;    WHEN 'Realized iROAS' THEN [Realized iROAS LY (copy)_2727985148349190167]&#13;&#10;    WHEN 'Future Media Revenue' THEN SUM([PlanFutureMediaRevenue])&#13;&#10;    WHEN 'Future iROAS' THEN [Future iROAS LY (copy)_2727985148349190163]&#13;&#10;    WHEN 'Media Value' THEN SUM([PlanMediaValue])&#13;&#10;    WHEN 'Media Return' THEN [Media Return LY (copy)_2727985148349190164]&#13;&#10;    WHEN 'Realized Media Value' THEN SUM([PlanRealizedMediaValue])&#13;&#10;    WHEN 'Realized Return' THEN [Realized Return LY (copy)_2727985148349190166]&#13;&#10;    WHEN 'Future Media Value' THEN SUM([PlanFutureMediaValue])&#13;&#10;    WHEN 'Future Return' THEN [Future Return LY (copy)_2727985148349190162]&#13;&#10;    WHEN 'EMR Value' THEN SUM([PlanEMRValue])&#13;&#10;    WHEN 'EMR Return' THEN [EMR Return LY (copy)_2727985148349190161]&#13;&#10;    WHEN 'Incremental Total Customers' THEN SUM([PlanIncrementalTotalCustomers])&#13;&#10;    WHEN 'Incremental New Customers' THEN SUM([PlanIncrementalNewCustomers])&#13;&#10;    WHEN 'iCPA' THEN (SUM([PlanSpend]) / SUM([PlanIncrementalNewCustomers]))&#13;&#10;    WHEN 'Incremental Current Customers' THEN SUM([PlanIncrementalCurrentCustomers])&#13;&#10;    WHEN 'Incremental Reactivated Customers' THEN SUM([PlanIncrementalReactivatedCustomers])&#10;&#13;&#10;    WHEN 'Platform CVR' THEN 0&#13;&#10;    WHEN 'Platform Orders' THEN 0&#13;&#10;    WHEN 'Platform AOV' THEN 0&#13;&#10;    WHEN 'Platform Revenue' THEN 0&#13;&#10;    WHEN 'Platform ROAS' THEN 0&#10;&#13;&#10;    WHEN 'Web RPV' THEN (SUM([PlanWebRevenue]) / SUM([PlanWebTraffic]))&#13;&#10;&#13;&#10;END"/>
            </column>
            <column caption="KPI 5 LY" datatype="real" name="[KPI1-1 Last Year (copy)_1329969288823300162]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013]&#13;&#10;&#13;&#10;    WHEN 'Spend' THEN SUM([Spend All (copy)_3996311395816796160])&#13;&#10;    WHEN 'CPM' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([Impressions_LY]) * 1000)&#13;&#10;    WHEN 'Impressions' THEN SUM([Impressions_LY])&#13;&#10;    WHEN 'CTR' THEN (SUM([Clicks_LY]) / SUM([Impressions_LY]))&#13;&#10;    WHEN 'CPC' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([Clicks_LY]))&#13;&#10;    WHEN 'Clicks' THEN SUM([Clicks_LY])&#13;&#10;    WHEN 'Web CVR' THEN (SUM([WebOrders_LY]) / SUM([WebTraffic_LY]))&#13;&#10;    WHEN 'Web CPO' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([WebOrders_LY]))&#13;&#10;    WHEN 'Web Orders' THEN SUM([WebOrders_LY])&#13;&#10;    WHEN 'Web AOV' THEN (SUM([WebRevenue_LY]) / SUM([WebOrders_LY]))&#13;&#10;    WHEN 'Web Revenue' THEN SUM([WebRevenue_LY])&#13;&#10;    WHEN 'Web ROAS' THEN (SUM([WebRevenue_LY]) / SUM([Spend_LY]))&#13;&#10;    WHEN 'Web Traffic' THEN SUM([WebTraffic_LY])&#13;&#10;    WHEN 'Web CPV' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([WebTraffic_LY]))&#13;&#10;    WHEN 'Media Revenue' THEN SUM([MediaRevenue_LY])&#13;&#10;    WHEN 'Media iROAS' THEN [Media iROAS (copy)_2727985148341379083]&#13;&#10;    WHEN 'Realized Media Revenue' THEN SUM([RealizedMediaRevenue_LY])&#13;&#10;    WHEN 'Realized iROAS' THEN [Realized iROAS (copy)_2727985148341379087]&#13;&#10;    WHEN 'Future Media Revenue' THEN SUM([FutureMediaRevenue_LY])&#13;&#10;    WHEN 'Future iROAS' THEN [Future iROAS (copy)_2727985148341379086]&#13;&#10;    WHEN 'Media Value' THEN SUM([MediaValue_LY])&#13;&#10;    WHEN 'Media Return' THEN [Media Return (copy)_2727985148341379088]&#13;&#10;    WHEN 'Realized Media Value' THEN SUM([RealizedMediaValue_LY])&#13;&#10;    WHEN 'Realized Return' THEN [Realized Return (copy)_2727985148341379084]&#13;&#10;    WHEN 'Future Media Value' THEN SUM([FutureMediaValue_LY])&#13;&#10;    WHEN 'Future Return' THEN [Future Return (copy)_2727985148341379085]&#13;&#10;    WHEN 'EMR Value' THEN SUM([EMRValue_LY])&#13;&#10;    WHEN 'EMR Return' THEN [EMR Return (copy)_2727985148341379082]&#13;&#10;    WHEN 'Incremental Total Customers' THEN SUM([IncrementalTotalCustomers_LY])&#13;&#10;    WHEN 'Incremental New Customers' THEN SUM([IncrementalNewCustomers_LY])&#13;&#10;    WHEN 'iCPA' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([IncrementalNewCustomers_LY]))&#13;&#10;    WHEN 'Incremental Current Customers' THEN SUM([IncrementalCurrentCustomers_LY])&#13;&#10;    WHEN 'Incremental Reactivated Customers' THEN SUM([IncrementalReactivatedCustomers_LY])&#13;&#10;    WHEN 'Platform CVR' THEN (SUM([PlatformOrders_LY]) / SUM([Clicks_LY]))&#13;&#10;    WHEN 'Platform Orders' THEN SUM([PlatformOrders_LY])&#13;&#10;    WHEN 'Platform AOV' THEN (SUM([PlatformRevenue_LY]) / SUM([PlatformOrders_LY]))&#13;&#10;    WHEN 'Platform Revenue' THEN SUM([PlatformRevenue_LY])&#13;&#10;    WHEN 'Platform ROAS' THEN (SUM([PlatformRevenue_LY]) / SUM([Spend_LY]))&#13;&#10;    WHEN 'Web RPV' THEN (SUM([WebRevenue_LY]) / SUM([WebTraffic_LY]))&#13;&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED : SUM([WebRevenue_LY]) })&#13;&#10;    WHEN '% Total Web Revenue' THEN&#13;&#10;        SUM([WebRevenue_LY]) / SUM({ FIXED : SUM([WebRevenue_LY]) })&#13;&#10;&#13;&#10;END"/>
            </column>
            <column caption="KPI 5" datatype="real" name="[KPI1-1 This Year (copy)_1329969288810631233]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013]&#13;&#10;&#13;&#10;    WHEN 'Spend' THEN SUM([Calculation_2727985148704944162])&#13;&#10;    WHEN 'CPM' THEN (SUM([Calculation_2727985148704944162]) / SUM([Impressions]) * 1000)&#13;&#10;    WHEN 'Impressions' THEN SUM([Impressions])&#13;&#10;    WHEN 'CTR' THEN (SUM([Clicks]) / SUM([Impressions]))&#13;&#10;    WHEN 'CPC' THEN (SUM([Calculation_2727985148704944162]) / SUM([Clicks]))&#13;&#10;    WHEN 'Clicks' THEN SUM([Clicks])&#13;&#10;    WHEN 'Web CVR' THEN (SUM([WebOrders]) / SUM([WebTraffic]))&#13;&#10;    WHEN 'Web CPO' THEN (SUM([Calculation_2727985148704944162]) / SUM([WebOrders]))&#13;&#10;    WHEN 'Web Orders' THEN SUM([WebOrders])&#13;&#10;    WHEN 'Web AOV' THEN (SUM([WebRevenue]) / SUM([WebOrders]))&#13;&#10;    WHEN 'Web Revenue' THEN SUM([WebRevenue])&#13;&#10;    WHEN 'Web ROAS' THEN (SUM([WebRevenue]) / SUM([Spend]))&#13;&#10;    WHEN 'Web Traffic' THEN SUM([WebTraffic])&#13;&#10;    WHEN 'Web CPV' THEN (SUM([Calculation_2727985148704944162]) / SUM([WebTraffic]))&#13;&#10;    WHEN 'Media Revenue' THEN SUM([MediaRevenue])&#13;&#10;    WHEN 'Media iROAS' THEN [Calculation_2727985148333301764]&#13;&#10;    WHEN 'Realized Media Revenue' THEN SUM([RealizedMediaRevenue])&#13;&#10;    WHEN 'Realized iROAS' THEN [Media iROAS (copy)_2727985148334161926]&#13;&#10;    WHEN 'Future Media Revenue' THEN SUM([FutureMediaRevenue])&#13;&#10;    WHEN 'Future iROAS' THEN [Media iROAS (copy)_2727985148333957125]&#13;&#10;    WHEN 'Media Value' THEN SUM([MediaValue])&#13;&#10;    WHEN 'Media Return' THEN [Media iROAS (copy)_2727985148338708487]&#13;&#10;    WHEN 'Realized Media Value' THEN SUM([RealizedMediaValue])&#13;&#10;    WHEN 'Realized Return' THEN [Media Return (copy)_2727985148338884616]&#13;&#10;    WHEN 'Future Media Value' THEN SUM([FutureMediaValue])&#13;&#10;    WHEN 'Future Return' THEN [Media Return (copy)_2727985148339564553]&#13;&#10;    WHEN 'EMR Value' THEN SUM([EMRValue])&#13;&#10;    WHEN 'EMR Return' THEN [Calculation_2727985148330471427]&#13;&#10;    WHEN 'Incremental Total Customers' THEN SUM([IncrementalTotalCustomers])&#13;&#10;    WHEN 'Incremental New Customers' THEN SUM([IncrementalNewCustomers])&#13;&#10;    WHEN 'iCPA' THEN (SUM([Calculation_2727985148704944162]) / SUM([IncrementalNewCustomers]))&#13;&#10;    WHEN 'Incremental Current Customers' THEN SUM([IncrementalCurrentCustomers])&#13;&#10;    WHEN 'Incremental Reactivated Customers' THEN SUM([IncrementalReactivatedCustomers])&#13;&#10;    WHEN 'Platform CVR' THEN (SUM([PlatformOrders]) / SUM([Clicks]))&#13;&#10;    WHEN 'Platform Orders' THEN SUM([PlatformOrders])&#13;&#10;    WHEN 'Platform AOV' THEN (SUM([PlatformRevenue]) / SUM([PlatformOrders]))&#13;&#10;    WHEN 'Platform Revenue' THEN SUM([PlatformRevenue])&#13;&#10;    WHEN 'Platform ROAS' THEN (SUM([PlatformRevenue]) / SUM([Spend]))&#13;&#10;    WHEN 'Web RPV' THEN (SUM([WebRevenue]) / SUM([WebTraffic]))&#13;&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED : SUM([WebRevenue]) })&#13;&#10;    WHEN '% Total Web Revenue' THEN&#13;&#10;        SUM([WebRevenue]) / SUM({ FIXED : SUM([WebRevenue]) })&#13;&#10;&#13;&#10;END"/>
