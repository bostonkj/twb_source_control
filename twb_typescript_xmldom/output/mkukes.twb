      <column caption="Plan KPI 5 LY" datatype="real" hidden="true" name="[KPI 5 LY (copy)_2727985148615004191]" role="measure" type="quantitative">
        <calculation class="tableau" formula="CASE [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013]&#13;&#10;&#13;&#10;    WHEN 'Spend' THEN SUM([PlanSpend_LY])&#13;&#10;    WHEN 'CPM' THEN (SUM([PlanSpend_LY]) / SUM([PlanImpressions_LY]) * 1000)&#13;&#10;    WHEN 'Impressions' THEN SUM([PlanImpressions_LY])&#13;&#10;    WHEN 'CTR' THEN (SUM([PlanClicks_LY]) / SUM([PlanImpressions_LY]))&#13;&#10;    WHEN 'CPC' THEN (SUM([PlanSpend_LY]) / SUM([PlanClicks_LY]))&#13;&#10;    WHEN 'Clicks' THEN SUM([PlanClicks_LY])&#13;&#10;    WHEN 'Web CVR' THEN (SUM([PlanWebOrders_LY]) / SUM([PlanWebTraffic_LY]))&#13;&#10;    WHEN 'Web CPO' THEN (SUM([PlanSpend_LY]) / SUM([PlanWebOrders_LY]))&#13;&#10;    WHEN 'Web Orders' THEN SUM([PlanWebOrders_LY])&#13;&#10;    WHEN 'Web AOV' THEN (SUM([PlanWebRevenue_LY]) / SUM([PlanWebOrders_LY]))&#13;&#10;    WHEN 'Web Revenue' THEN SUM([PlanWebRevenue_LY])&#13;&#10;    WHEN 'Web ROAS' THEN (SUM([PlanWebRevenue_LY]) / SUM([PlanSpend_LY]))&#13;&#10;    WHEN 'Web Traffic' THEN SUM([PlanWebTraffic_LY])&#13;&#10;    WHEN 'Web CPV' THEN (SUM([PlanSpend_LY]) / SUM([PlanWebTraffic_LY]))&#13;&#10;    WHEN 'Media Revenue' THEN SUM([PlanMediaRevenue_LY])&#13;&#10;    WHEN 'Media iROAS' THEN [Media iROAS LY (copy) (copy)_2727985148349210652]&#13;&#10;    WHEN 'Realized Media Revenue' THEN SUM([PlanRealizedMediaRevenue_LY])&#13;&#10;    WHEN 'Realized iROAS' THEN [Realized iROAS LY (copy) (copy)_2727985148349210654]&#13;&#10;    WHEN 'Future Media Revenue' THEN SUM([PlanFutureMediaRevenue_LY])&#13;&#10;    WHEN 'Future iROAS' THEN [Future iROAS LY (copy) (copy)_2727985148349210650]&#13;&#10;    WHEN 'Media Value' THEN SUM([PlanMediaValue_LY])&#13;&#10;    WHEN 'Media Return' THEN [Media Return LY (copy) (copy)_2727985148349210651]&#13;&#10;    WHEN 'Realized Media Value' THEN SUM([PlanRealizedMediaValue_LY])&#13;&#10;    WHEN 'Realized Return' THEN [Realized Return LY (copy) (copy)_2727985148349210653]&#13;&#10;    WHEN 'Future Media Value' THEN SUM([PlanFutureMediaValue_LY])&#13;&#10;    WHEN 'Future Return' THEN [Future Return LY (copy) (copy)_2727985148349210649]&#13;&#10;    WHEN 'EMR Value' THEN SUM([PlanEMRValue_LY])&#13;&#10;    WHEN 'EMR Return' THEN [EMR Return LY (copy) (copy)_2727985148349210648]&#13;&#10;    WHEN 'Incremental Total Customers' THEN SUM([PlanIncrementalTotalCustomers_LY])&#13;&#10;    WHEN 'Incremental New Customers' THEN SUM([PlanIncrementalNewCustomers_LY])&#13;&#10;    WHEN 'iCPA' THEN (SUM([PlanSpend_LY]) / SUM([PlanIncrementalNewCustomers_LY]))&#13;&#10;    WHEN 'Incremental Current Customers' THEN SUM([PlanIncrementalCurrentCustomers_LY])&#13;&#10;    WHEN 'Incremental Reactivated Customers' THEN SUM([PlanIncrementalReactivatedCustomers_LY])&#10;&#13;&#10;    WHEN 'Platform CVR' THEN 0&#13;&#10;    WHEN 'Platform Orders' THEN 0&#13;&#10;    WHEN 'Platform AOV' THEN 0&#13;&#10;    WHEN 'Platform Revenue' THEN 0&#13;&#10;    WHEN 'Platform ROAS' THEN 0&#10;&#13;&#10;    WHEN 'Web RPV' THEN (SUM([PlanWebRevenue_LY]) / SUM([PlanWebTraffic_LY]))&#13;&#10;    WHEN 'Total Web Revenue' THEN SUM({ FIXED : SUM([PlanWebRevenue_LY]) })&#13;&#10;    WHEN '% Total Web Revenue' THEN&#13;&#10;        SUM([PlanWebRevenue_LY]) / SUM({ FIXED : SUM([PlanWebRevenue_LY]) })&#13;&#10;&#13;&#10;END"/>
      </column>
