            <column caption="vs. KPI 8 LY (#) Output" datatype="string" name="[K2-1  Active Metrics vs LY % (copy)_1691383160033579024]" role="measure" type="nominal">
              <calculation class="tableau" formula="IIF([K2-1 Active metric vs LY Difference (copy)_449234087459569679] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;&#13;&#10;// € metrics -&gt; currency formatting (€ + K/M/B)&#13;&#10;IF [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626] IN (&#13;&#10;    &quot;Spend&quot;,&quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Media Revenue&quot;,&quot;Realized Media Revenue&quot;,&quot;Future Media Revenue&quot;,&#13;&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 100000000000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 10000000000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 1000000000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 100000000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 10000000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 1000000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 100000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 10000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 1000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Count metrics -&gt; count formatting (K/M/B, no €)&#13;&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626] IN (&#13;&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#13;&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#13;&#10;    &quot;Platform Orders&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 100000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 10000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 1000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 100000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 10000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 1000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 100000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 10000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) &gt; 1000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Rate / per metrics -&gt; 2dp currency&#13;&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626] IN (&#13;&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#13;&#10;    &quot;Media iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#13;&#10;    &quot;Media Return&quot;,&quot;Realized Return&quot;,&quot;Future Return&quot;,&quot;EMR Return&quot;,&#13;&#10;    &quot;iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#13;&#10;) THEN&#13;&#10;    &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]), 2))&#13;&#10;&#13;&#10;// Percent metrics -&gt; 2dp %&#13;&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;) THEN&#13;&#10;    STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy)_449234087459569679]), 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;// Special case preserved exactly as provided (uses [KPI 8], not vs field)&#13;&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626] IN (&quot;% Total Web Revenue&quot;) THEN&#13;&#10;    STR(ROUND(([KPI2-2 This Year (copy)_1255096945753911303]) * 100, 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;END"/>
            </column>
            <column caption="vs. KPI 8 LY (#)" datatype="real" name="[K2-1 Active metric vs LY Difference (copy)_449234087459569679]" role="measure" type="quantitative">
              <calculation class="tableau" formula="([KPI2-2 This Year (copy)_1255096945753911303])-[KPI2-1 Last Year (copy)_449234087457902595]"/>
            </column>
            <column caption="Plan KPI 8" datatype="real" name="[KPI 2-1 Plan (copy)_1793840067787182081]" role="measure" type="quantitative">
              <calculation class="tableau" formula="CASE [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626]&#10;&#10;    WHEN 'Spend' THEN SUM([Spend All (copy)_3996311395817148417])&#10;    WHEN 'CPM' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanImpressions]) * 1000)&#10;    WHEN 'Impressions' THEN SUM([PlanImpressions])&#10;    WHEN 'CTR' THEN (SUM([PlanClicks]) / SUM([PlanImpressions]))&#10;    WHEN 'CPC' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanClicks]))&#10;    WHEN 'Clicks' THEN SUM([PlanClicks])&#10;    WHEN 'Web CVR' THEN (SUM([PlanWebOrders]) / SUM([PlanWebTraffic]))&#10;    WHEN 'Web CPO' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebOrders]))&#10;    WHEN 'Web Orders' THEN SUM([PlanWebOrders])&#10;    WHEN 'Web AOV' THEN (SUM([PlanWebRevenue]) / SUM([PlanWebOrders]))&#10;    WHEN 'Web Revenue' THEN SUM([PlanWebRevenue])&#10;&#10;    // Keeping your original behavior (it was effectively returning 0)&#10;    WHEN 'Total Web Revenue' THEN 0&#10;&#10;    WHEN 'Web ROAS' THEN (SUM([PlanWebRevenue]) / SUM([PlanSpend]))&#10;    WHEN 'Web Traffic' THEN SUM([PlanWebTraffic])&#10;    WHEN 'Web CPV' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebTraffic]))&#10;    WHEN 'Media Revenue' THEN SUM([PlanMediaRevenue])&#10;    WHEN 'Media iROAS' THEN [Media iROAS LY (copy)_2727985148349190165]&#10;    WHEN 'Realized Media Revenue' THEN SUM([PlanRealizedMediaRevenue])&#10;    WHEN 'Realized iROAS' THEN [Realized iROAS LY (copy)_2727985148349190167]&#10;    WHEN 'Future Media Revenue' THEN SUM([PlanFutureMediaRevenue])&#10;    WHEN 'Future iROAS' THEN [Future iROAS LY (copy)_2727985148349190163]&#10;    WHEN 'Media Value' THEN SUM([PlanMediaValue])&#10;    WHEN 'Media Return' THEN [Media Return LY (copy)_2727985148349190164]&#10;    WHEN 'Realized Media Value' THEN SUM([PlanRealizedMediaValue])&#10;    WHEN 'Realized Return' THEN [Realized Return LY (copy)_2727985148349190166]&#10;    WHEN 'Future Media Value' THEN SUM([PlanFutureMediaValue])&#10;    WHEN 'Future Return' THEN [Future Return LY (copy)_2727985148349190162]&#10;    WHEN 'EMR Value' THEN SUM([PlanEMRValue])&#10;    WHEN 'EMR Return' THEN [EMR Return LY (copy)_2727985148349190161]&#10;    WHEN 'Incremental Total Customers' THEN SUM([PlanIncrementalTotalCustomers])&#10;    WHEN 'Incremental New Customers' THEN SUM([PlanIncrementalNewCustomers])&#10;    WHEN 'iCPA' THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanIncrementalNewCustomers]))&#10;    WHEN 'Incremental Current Customers' THEN SUM([PlanIncrementalCurrentCustomers])&#10;    WHEN 'Incremental Reactivated Customers' THEN SUM([PlanIncrementalReactivatedCustomers])&#10;&#10;    WHEN 'Platform CVR' THEN 0&#10;    WHEN 'Platform Orders' THEN 0&#10;    WHEN 'Platform AOV' THEN 0&#10;    WHEN 'Platform Revenue' THEN 0&#10;    WHEN 'Platform ROAS' THEN 0&#10;&#10;    WHEN 'Web RPV' THEN (SUM([PlanWebRevenue]) / SUM([PlanWebTraffic]))&#10;&#10;END"/>
            </column>
            <column caption="vs. Plan KPI 8 (#)" datatype="real" name="[KPI 2-1 Plan Difference (copy 3)_1793840067788357639]" role="measure" type="quantitative">
              <calculation class="tableau" formula="([KPI2-2 This Year (copy)_1255096945753911303])-([KPI 2-1 Plan (copy)_1793840067787182081])"/>
            </column>
