69]) THEN [MediaRevenue]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Realized Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [RealizedMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Future Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [FutureMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Realized Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [RealizedMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10; WHEN 'Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [MediaValue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10; WHEN 'Realized Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [RealizedMediaValue]                 &#13;&#10;        END)&#13;&#10;&#13;&#10; WHEN 'Future Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [FutureMediaValue]                 &#13;&#10;        END)&#13;&#10;     &#13;&#10;&#13;&#10;    WHEN 'EMR Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [EMRValue]                 &#13;&#10;        END)&#13;&#10;      &#13;&#10;  WHEN 'Incremental Total Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [IncrementalTotalCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Incremental New Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [IncrementalNewCustomers]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Incremental Current Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [IncrementalCurrentCustomers]                 &#13;&#10;        END)&#13;&#10;        &#13;&#10; WHEN 'Incremental Reactivated Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Calculation_992762284451258369]) THEN [IncrementalReactivatedCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;       &#13;&#10;&#13;&#10;    END)"/>
