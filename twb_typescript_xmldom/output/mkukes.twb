            <column caption="vs. KPI 6 LY (%)" datatype="real" default-format="p0.00%" name="[K2-1 Active metric vs LY % (copy 2)_449234087459512333]" role="measure" type="quantitative">
              <calculation class="tableau" formula="(([KPI2-1 This Year (copy)_742812488104312836])-[KPI2-1 Last Year (copy 2)_449234087458037764])/[KPI2-1 Last Year (copy 2)_449234087458037764]"/>
