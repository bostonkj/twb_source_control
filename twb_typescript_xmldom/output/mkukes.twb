      <column caption="Primary KPI" datatype="string" name="[PL2 Active Metric Parameter (copy)_901282899119939639]" param-domain-type="list" role="measure" type="nominal" value="&quot;Spend&quot;">
        <calculation class="tableau" formula="CASE [Parameters].[Primary KPI] WHEN &quot;Spend&quot; THEN SUM([Spend]) WHEN &quot;CPM&quot; THEN (SUM([Spend]) / SUM([Impressions])) * 1000 WHEN &quot;Impressions&quot; THEN SUM([Impressions]) WHEN &quot;CTR&quot; THEN SUM([Clicks]) / SUM([Impressions]) WHEN &quot;CPC&quot; THEN SUM([Spend]) / SUM([Clicks]) WHEN &quot;Clicks&quot; THEN SUM([Clicks]) WHEN &quot;Web CVR&quot; THEN SUM([WebOrders]) / SUM([WebTraffic]) WHEN &quot;Web RPV&quot; THEN SUM([WebRevenue]) / SUM([WebTraffic]) WHEN &quot;Web CPO&quot; THEN SUM([Spend]) / SUM([WebOrders]) WHEN &quot;Web Orders&quot; THEN SUM([WebOrders]) WHEN &quot;Web AOV&quot; THEN SUM([WebRevenue]) / SUM([WebOrders]) WHEN &quot;Web Revenue&quot; THEN SUM([WebRevenue]) WHEN &quot;Web ROAS&quot; THEN SUM([WebRevenue]) / SUM([Spend]) WHEN &quot;Web Traffic&quot; THEN SUM([WebTraffic]) WHEN &quot;Web CPV&quot; THEN SUM([Spend]) / SUM([WebTraffic]) WHEN &quot;Platform CVR&quot; THEN SUM([PlatformOrders]) / SUM([Clicks]) WHEN &quot;Platform Orders&quot; THEN SUM([PlatformOrders]) WHEN &quot;Platform AOV&quot; THEN SUM([PlatformRevenue]) / SUM([PlatformOrders]) WHEN &quot;Platform Revenue&quot; THEN SUM([PlatformRevenue]) END"/>
