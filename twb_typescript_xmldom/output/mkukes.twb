            <column caption="Order Type Filter" datatype="boolean" name="[Calculation_985725394907299840]" role="dimension" type="nominal">
              <calculation class="tableau" formula="CASE [Parameters].[Parameter 12]&#13;&#10;WHEN 'Enterprise' THEN [OrderType (copy)_2727985147994247169] = [OrderType (copy)_2727985147994247169]&#13;&#10;WHEN 'Ecom' THEN [OrderType (copy)_2727985147994247169] = 'Ecom'&#13;&#10;WHEN 'Store' THEN [OrderType (copy)_2727985147994247169] = 'Store'&#13;&#10;WHEN 'App' THEN [OrderType (copy)_2727985147994247169] = 'App'&#13;&#10;END"/>
