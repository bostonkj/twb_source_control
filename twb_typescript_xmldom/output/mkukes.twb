THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 100000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 10000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 1000 THEN &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Count metrics -&gt; count formatting (K/M/B, no €)&#13;&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#13;&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#13;&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#13;&#10;    &quot;Platform Orders&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 100000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 10000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 1000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 100000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 10000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 1000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 100000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 10000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) &gt; 1000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Rate / per metrics -&gt; 2dp currency&#13;&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#13;&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#13;&#10;    &quot;Media iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#13;&#10;    &quot;Media Return&quot;,&quot;Realized Return&quot;,&quot;Future Return&quot;,&quot;EMR Return&quot;,&#13;&#10;    &quot;iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#13;&#10;) THEN&#13;&#10;    &quot;€&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]), 2))&#13;&#10;&#13;&#10;// Percent metrics -&gt; 2dp %&#13;&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;) THEN&#13;&#10;    STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 2)_449234087459594256]), 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;// Special case preserved exactly as provided (uses [KPI 6], not vs field)&#13;&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&quot;% Total Web Revenue&quot;) THEN&#13;&#10;    STR(ROUND(([KPI2-1 This Year (copy)_742812488104312836]) * 100, 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;END"/>
