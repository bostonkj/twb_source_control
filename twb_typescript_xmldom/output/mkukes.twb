N STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 10000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 1000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 100000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 10000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 1000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Rate / per metrics -&gt; 2dp currency&#13;&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626] IN (&#13;&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#13;&#10;    &quot;Media iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#13;&#10;    &quot;Media Return&quot;,&quot;Realized Return&quot;,&quot;Future Return&quot;,&quot;EMR Return&quot;,&#13;&#10;    &quot;iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#13;&#10;) THEN&#13;&#10;    &quot;€&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]), 2))&#13;&#10;&#13;&#10;// Percent metrics -&gt; 2dp %&#13;&#10;ELSEIF [Parameters].[K2-2 Active 