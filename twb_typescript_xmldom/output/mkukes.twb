              <calculation class="tableau" formula="CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;when  'Revenue' then '€'&#10;when  'Web Revenue' then '€'&#10;when  'Media Revenue' then '€' &#10;when  'Realized Media Revenue'  then '€'&#10;when  'Future Media Revenue'  then '€'&#10;when  'Media Value' then '€'&#10;when  'Realized Media Value' then '€'&#10;when  'Future Media Value'then '€'&#10;when  'EMR Value' then '€'&#10;&#10;END&#10;&#10;&#10;/*WHEN &quot;Spend&quot; THEN '$'&#10;when  'EMR$' then '$'&#10;when  'Realized Media Value' then '$'&#10;when  'Future Media Value'then '$'&#10;when  'Incremental Media Revenue' then '$'&#10;when  'Incremental Realized Media Revenue' then '$'&#10;when  'Incremental Future Media Revenue' then '$'&#10;when  'EMR $' then '$'&#10;when  'EMR Rate/$' then '$'&#10;when  'Media Return/$' then '$'&#10;when  'Realized Return/$' then '$'&#10;when  'iROAS' then '$'&#10;when  'Revenue' then '$'&#10;when  'RAOS' then '$'&#10;when  'CPO' then '$'&#10;when  'AOV' then '$'&#10;when  'Spend' then '$'&#10;when  'CPM' then '$'&#10;&#10;when  'CPC' then '$'&#10;when  'CPV' then '$'&#10;when  'Media Revenue' then '$' &#10;when  'Realized Media Revenue'  then '$'&#10;when  'Realized iROAS' then '$'&#10;when  'Incremental Media Revenue(Realized + Future)' then'$'&#10;when  'Incremental Realized Media Revenue' then '$'&#10;ELSE ''*/"/>
