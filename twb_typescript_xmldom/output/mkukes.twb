            <column caption="vs. KPI 7 LY (%)" datatype="real" default-format="p0.00%" name="[K2-1 Active metric vs LY % (copy 3)_449234087459536910]" role="measure" type="quantitative">
              <calculation class="tableau" formula="(([KPI2-2 This Year (copy 2)_1255096945753931784])-[KPI2-1 Last Year (copy 3)_449234087458062341])/[KPI2-1 Last Year (copy 3)_449234087458062341]"/>
