              <calculation class="tableau" formula="CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;    WHEN 'Revenue' THEN SUM([Revenue])&#10;    WHEN 'Orders' THEN SUM([Orders])&#10;    WHEN 'Total Customers' THEN SUM([TotalCustomers])&#10;    WHEN 'New Customers' THEN SUM([NewCustomers])&#10;    WHEN 'Current Customers' THEN SUM([CurrentCustomers])&#10;    WHEN 'Reactivated Customers' THEN SUM([ReactivatedCustomers])&#10;    WHEN 'Web Orders' THEN SUM([WebOrders])&#10;    WHEN 'Web Revenue' THEN SUM([WebRevenue])&#10;    WHEN 'Web Traffic' THEN SUM([WebTraffic])&#10;    WHEN 'Media Revenue' THEN SUM([MediaRevenue])&#10;    WHEN 'Realized Media Revenue' THEN SUM([RealizedMediaRevenue])&#10;    WHEN 'Future Media Revenue' THEN SUM([FutureMediaRevenue])&#10;    WHEN 'Media Value' THEN SUM([MediaValue])&#10;    WHEN 'Realized Media Value' THEN SUM([RealizedMediaValue])&#10;    WHEN 'Future Media Value' THEN SUM([FutureMediaValue])&#10;    WHEN 'EMR Value' THEN SUM([EMRValue])&#10;    WHEN 'Incremental Total Customers' THEN SUM([IncrementalTotalCustomers])&#10;    WHEN 'Incremental New Customers' THEN SUM([IncrementalNewCustomers])&#10;    WHEN 'Incremental Current Customers' THEN SUM([IncrementalCurrentCustomers])&#10;    WHEN 'Incremental Reactivated Customers' THEN SUM([IncrementalReactivatedCustomers])&#10;END"/>
