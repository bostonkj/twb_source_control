            <column caption="vs. KPI 8 LY (%)" datatype="real" default-format="p0.00%" name="[K2-1 Active metric vs LY % (copy)_449234087459491852]" role="measure" type="quantitative">
              <calculation class="tableau" formula="(([KPI2-2 This Year (copy)_1255096945753911303])-[KPI2-1 Last Year (copy)_449234087457902595])/[KPI2-1 Last Year (copy)_449234087457902595]"/>
