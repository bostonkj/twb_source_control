            <column caption="vs. KPI 5 LY (#) Output" datatype="string" name="[K1-1  Active Metrics vs LY % (copy)_1691383160026578958]" role="measure" type="nominal">
              <calculation class="tableau" formula="IIF([K1-1 Active metric vs LY Difference (copy)_1255096945766715404] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;&#13;&#10;// € metrics -&gt; currency formatting (€ + K/M/B)&#13;&#10;IF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;    &quot;Spend&quot;,&quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Media Revenue&quot;,&quot;Realized Media Revenue&quot;,&quot;Future Media Revenue&quot;,&#13;&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000000000 THEN &quot;€&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000000000 THEN &quot;€&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000000000 THEN &quot;€&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000000 THEN &quot;€&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000000 THEN &quot;€&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000000 THEN &quot;