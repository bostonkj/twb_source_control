            <column caption="YTD Date" datatype="date" name="[Calculation_1654228464561578010]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="{ FIXED [fiscalYear]:MIN([Date])}"/>
            </column>
            <column caption="Date Flag" datatype="string" name="[Calculation_1714182672546091008]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF [Date]&gt;=[Calculation_2637139079381286990] and [Date]&lt;=[Anchor Start Date (copy)_867505918082613251] THEN 'TY'&#13;&#10;ELSEIF  [Date]&gt;=DATETRUNC('week',DATEADD('year',-1,[Parameters].[Parameter 8])+6,'sunday') and [Date]&lt;=DATETRUNC('week',DATEADD('year',-1,[Parameters].[Parameter 1])+6,'saturday') THEN 'LY'&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;ELSEIF  [Date]&gt;={[Anchor Start Date MTD (copy)_992762284465217540]} and [Date]&lt;=DATETRUNC('week',TODAY(),'saturday')+1  THEN 'YTD Current'&#13;&#10;ELSEIF  [Date]&gt;={[Anchor Start Date YTD (copy)_301178266734993423]} and [Date]&lt;=DATETRUNC('week',DATEADD('year',-1, TODAY()),'saturday')+1 THEN 'YTD Previous'&#13;&#10;END"/>
            </column>
            <column caption="Anchor Start Date" datatype="datetime" name="[Calculation_2637139079381286990]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="DATETRUNC('week',[Parameters].[Parameter 8],'sunday')"/>
            </column>
            <column caption="Spend All" datatype="real" name="[Calculation_2727985148704944162]" role="measure" type="quantitative">
              <calculation class="tableau" formula="{ FIXED [Date], [Channel], [Subchannel]: SUM([Spend]) }"/>
            </column>
            <column caption="vs. YTD Primary KPI (%)" datatype="real" default-format="p0.00%" name="[Calculation_301178266736517137]" role="measure" type="quantitative">
              <calculation class="tableau" formula="([P-KPI 1 MTD (copy)_992762284465725446]-[P-KPI 1 YTD (copy)_301178266732146701])/[P-KPI 1 YTD (copy)_301178266732146701]"/>
            </column>
            <column caption="Default Start Date" datatype="date" datatype-customized="true" name="[Calculation_4140989541042946049]" role="dimension" type="ordinal">
              <calculation class="tableau" formula="DATE(DATETRUNC('week', DATEADD('week', -4, TODAY())))"/>
            </column>
            <column caption="Paid vs. Owned" datatype="string" name="[Calculation_6791006039007158277]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF REGEXP_MATCH([Channel], &#10;&quot;Affiliate|Direct Mail|Display|Paid Search|Paid Social|Video|OOH|Print|Shopping|Social&quot;)&#10;THEN &quot;Paid&quot;&#10;ELSEIF REGEXP_MATCH([Channel], &#10;&quot;Base &amp; Traditional Media&quot;)&#10;THEN &quot;Base&quot;&#10;ELSEIF REGEXP_MATCH([Channel], &#10;&quot;CRM|Direct|Email|Internal|Organic Search|Organic Social|Referring Domains|SMS|Uninfluenced Order|Unknown|Unmatched Order&quot;)&#10;THEN &quot;Owned&quot;&#10;END"/>
            </column>
            <column caption="Order Type Filter" datatype="boolean" name="[Calculation_985725394907299840]" role="dimension" type="nominal">
              <calculation class="tableau" formula="CASE [Parameters].[Parameter 12]&#13;&#10;WHEN 'Enterprise' THEN [OrderType (copy)_2727985147994247169] = [OrderType (copy)_2727985147994247169]&#13;&#10;WHEN 'Ecom' THEN [OrderType (copy)_2727985147994247169] = 'Ecom'&#13;&#10;WHEN 'Store' THEN [OrderType (copy)_2727985147994247169] = 'Store'&#13;&#10;WHEN 'App' THEN [OrderType (copy)_2727985147994247169] = 'App'&#13;&#10;END"/>
            </column>
