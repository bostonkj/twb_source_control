              <calculation class="tableau" formula="CASE [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013]&#13;&#10;&#13;&#10;    WHEN 'Spend' THEN SUM([Spend All (copy)_3996311395816796160])&#13;&#10;    WHEN 'CPM' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([Impressions_LY]) * 1000)&#13;&#10;    WHEN 'Impressions' THEN SUM([Impressions_LY])&#13;&#10;    WHEN 'CTR' THEN (SUM([Clicks_LY]) / SUM([Impressions_LY]))&#13;&#10;    WHEN 'CPC' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([Clicks_LY]))&#13;&#10;    WHEN 'Clicks' THEN SUM([Clicks_LY])&#13;&#10;    WHEN 'Web CVR' THEN (SUM([WebOrders_LY]) / SUM([WebTraffic_LY]))&#13;&#10;    WHEN 'Web CPO' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([WebOrders_LY]))&#13;&#10;    WHEN 'Web Orders' THEN SUM([WebOrders_LY])&#13;&#10;    WHEN 'Web AOV' THEN (SUM([WebRevenue_LY]) / SUM([WebOrders_LY]))&#13;&#10;    WHEN 'Web Revenue' THEN SUM([WebRevenue_LY])&#13;&#10;    WHEN 'Web ROAS' THEN (SUM([WebRevenue_LY]) / SUM([Spend_LY]))&#13;&#10;    WHEN 'Web Traffic' THEN SUM([WebTraffic_LY])&#13;&#10;    WHEN 'Web CPV' THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([WebTraffic_LY]))&#13;&#10;    WHEN 'Media Revenue' THEN SUM([MediaRevenue_LY])&#13;&#10;    WHEN 'Media iROAS' THEN [Media iROAS (copy)_2727985148341379083]&#13;&#10;    WHEN 'Realized Media Revenue' THEN SUM([RealizedMediaRevenue_LY])&#13;&#10;    WHEN 'Realized iROAS' THEN [Realized iROAS (copy)_2727985148341379087]&#13;&#10;    WHEN 'Future Media Revenue' THEN SUM([FutureMediaRevenue_LY])&#13;&#10;    WHEN 'Future iROAS' THEN [Future iROAS (copy)_2727985148341379086]&#13;&#10;    WHEN 'Media Value' THEN SUM([MediaValue_LY])&#13;&#10;    WHEN 'Media Return' THEN [Media Return (copy)_2727985148341379088]&#13;&#10;    WHEN 'Realized Media Value' THEN SUM([RealizedMediaValue_LY])&#13;&#10;    WHEN 'Realized Return' THEN [Realized Return (copy)_2727985148341379084]&#13;&#10;    WHEN 'Future Media Value' THEN 