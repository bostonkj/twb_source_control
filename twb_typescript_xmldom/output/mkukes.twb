zed Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanRealizedMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Future Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanFutureMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Realized Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanRealizedMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10; WHEN 'Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanMediaValue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10; WHEN 'Realized Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanRealizedMediaValue]                 &#13;&#10;        END)&#13;&#10;&#13;&#10; WHEN 'Future Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanFutureMediaValue]                 &#13;&#10;        END)&#13;&#10;     &#13;&#10;&#13;&#10;    WHEN 'EMR Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanEMRValue]                 &#13;&#10;        END)&#13;&#10;      &#13;&#10;  WHEN 'Incremental Total Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanIncrementalTotalCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Incremental New Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanIncrementalNewCustomers]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Incremental Current Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanIncrementalCurrentCustomers]                 &#13;&#10;        END)&#13;&#10;        &#13;&#10; WHEN 'Incremental Reactivated Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF ([Calculation_1714182672546091008]) = 'TY' THEN [PlanIncrementalReactivatedCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;       &#13;&#10;&#13;&#10;    END)"/>
