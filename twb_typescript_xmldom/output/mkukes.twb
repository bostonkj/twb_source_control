              <calculation class="tableau" formula="(CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#13;&#10;    WHEN 'Revenue' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL([Anchor Date Range MTD (copy)_301178266710245377]) THEN [Revenue]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Orders' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [Orders]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Total Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [TotalCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'New Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [NewCustomers]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Current Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [CurrentCustomers]                 &#13;&#10;        END)&#13;&#10;        &#13;&#10; WHEN 'Reactivated Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [ReactivatedCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Web Orders' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [WebOrders]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Web Revenue' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [WebRevenue]                 &#13;&#10;        END)&#13;&#10;        &#13;&#10;    WHEN 'Web Traffic' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [WebTraffic]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Media Revenue' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [MediaRevenue]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Realized Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [RealizedMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Future Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [FutureMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Realized Media Revenue' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [RealizedMediaRevenue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10; WHEN 'Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [MediaValue]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10; WHEN 'Realized Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [RealizedMediaValue]                 &#13;&#10;        END)&#13;&#10;&#13;&#10; WHEN 'Future Media Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [FutureMediaValue]                 &#13;&#10;        END)&#13;&#10;     &#13;&#10;&#13;&#10;    WHEN 'EMR Value' THEN &#13;&#10;      SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [EMRValue]                 &#13;&#10;        END)&#13;&#10;      &#13;&#10;  WHEN 'Incremental Total Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalTotalCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Incremental New Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalNewCustomers]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Incremental Current Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalCurrentCustomers]                 &#13;&#10;        END)&#13;&#10;        &#13;&#10; WHEN 'Incremental Reactivated Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalReactivatedCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;       &#13;&#10;&#13;&#10;    END)"/>
