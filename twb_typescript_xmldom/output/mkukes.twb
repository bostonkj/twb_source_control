                 &#13;&#10;        END)&#13;&#10;&#13;&#10;    WHEN 'Incremental New Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [IncrementalNewCustomers]                 &#13;&#10;        END)&#13;&#10;       &#13;&#10;    WHEN 'Incremental Current Customers' THEN &#13;&#10;       SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [IncrementalCurrentCustomers]                 &#13;&#10;        END)&#13;&#10;        &#13;&#10; WHEN 'Incremental Reactivated Customers' THEN &#13;&#10;     SUM(&#13;&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [IncrementalReactivatedCustomers]                 &#13;&#10;        END)&#13;&#10;&#13;&#10;       &#13;&#10;&#13;&#10;    END)"/>
            </column>
