              <calculation class="tableau" formula="CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#13;&#10; &#13;&#10;    WHEN 'Web Orders' THEN 'Sourced from Web Analytics'&#13;&#10;            &#13;&#10;    WHEN 'Web Revenue' THEN 'Sourced from Web Analytics'&#13;&#10;&#13;&#10;    WHEN 'Web Traffic' THEN 'Sourced from Web Analytics'&#13;&#10;&#13;&#10;    WHEN 'Media Revenue' THEN 'Realized Media Revenue + Future Media Revenue&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Realized Media Revenue' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Future Media Revenue' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Media Value' THEN 'Realized Media Value + Future Media Value&#13;&#10;Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Realized Media Value' THEN 'Sourced from MMM+'&#13;&#10;             &#13;&#10;    WHEN 'Future Media Value' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'EMR Value' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Incremental Total Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Incremental New Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Incremental Current Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    WHEN 'Incremental Reactivated Customers' THEN 'Sourced from MMM+'&#13;&#10;&#13;&#10;    ELSE 'Sourced from CRM'&#13;&#10;&#13;&#10;END"/>
