            <column caption="vs. KPI 5 LY (%)" datatype="real" default-format="p0.00%" name="[K1-1 Active metric vs LY % (copy)_1255096945766699019]" role="measure" type="quantitative">
              <calculation class="tableau" formula="(([KPI1-1 This Year (copy)_1329969288810631233])-[KPI1-1 Last Year (copy)_1329969288823300162])/[KPI1-1 Last Year (copy)_1329969288823300162]"/>
