      <column caption='vs. KPI 5 LY (#) Output' datatype='string' name='[K1-1  Active Metrics vs LY % (copy)_1691383160026578958]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IIF([K1-1 Active metric vs LY Difference (copy)_1255096945766715404] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;&#13;&#10;// $ metrics -&gt; currency formatting ($ + K/M/B)&#13;&#10;IF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;    &quot;Spend&quot;, &quot;Total Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Incremental Revenue&quot;,&quot;Realized Incremental Revenue&quot;,&quot;Future Incremental Revenue&quot;,&#13;&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Count metrics -&gt; count formatting (K/M/B, no $)&#13;&#10;ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#13;&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#13;&#10;    &quot;Platform Orders&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000000000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000000000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000000000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 100000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 10000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) &gt; 1000 THEN STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Rate / per metrics -&gt; 2dp currency&#13;&#10;ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#13;&#10;    &quot;iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#13;&#10;    &quot;Media Return&quot;,&quot;Realized Media Return&quot;,&quot;Future Media Return&quot;,&quot;EMR Return&quot;,&#13;&#10;    &quot;New Customer iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#13;&#10;) THEN&#13;&#10;    &quot;$&quot; + STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404]), 2))&#13;&#10;&#13;&#10;// Percent metrics -&gt; 2dp %&#13;&#10;ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;, &quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#13;&#10;    STR(ROUND(ABS([K1-1 Active metric vs LY Difference (copy)_1255096945766715404])*100, 2)) + &quot;%&quot;&#13;&#10;&#13;&#10;/*&#13;&#10;// Special case preserved exactly as provided (uses [KPI 5], not vs field)&#13;&#10;ELSEIF [Parameters].[KPI 5] IN (&quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#13;&#10;    STR(ROUND(([KPI 5]) * 100, 2)) + &quot;%&quot;&#13;&#10;*/&#13;&#10;&#13;&#10;END' />
      </column>
