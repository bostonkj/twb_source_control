      <column caption='Primary KPI (Table)' datatype='real' name='[Primary KPI (copy)_4512817981208145926]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;    WHEN &apos;Revenue&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [Revenue] END)&#10;    WHEN &apos;Orders&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [Orders] END)&#10;    WHEN &apos;Total Customers&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [TotalCustomers] END)&#10;    WHEN &apos;New Customers&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [NewCustomers] END)&#10;    WHEN &apos;Current Customers&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [CurrentCustomers] END)&#10;    WHEN &apos;Reactivated Customers&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [ReactivatedCustomers] END)&#10;    WHEN &apos;Web Orders&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [WebOrders] END)&#10;    WHEN &apos;Web Revenue&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [WebRevenue] END)&#10;    WHEN &apos;Web Traffic&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [WebTraffic] END)&#10;    WHEN &apos;Incremental Revenue&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [MediaRevenue] END)&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [RealizedMediaRevenue] END)&#10;    WHEN &apos;Future Incremental Revenue&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [FutureMediaRevenue] END)&#10;    WHEN &apos;Media Value&apos; THEN &#10;        SUM(IF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [MediaValue] END)&#10;    WHEN &apos;Realize