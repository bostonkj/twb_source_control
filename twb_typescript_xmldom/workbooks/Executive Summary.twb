              <calculation class='tableau' formula='SUM(IF ([Calculation_1714182672546091008]) = &quot;TY&quot; AND [Parameters].[Parameter 12] = &apos;Store&apos; THEN [Spend All (copy)_3996311395817148417]&#10;    ELSEIF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [PlanSpend] END)' />
