            <column caption='KPI 7 LY CF' datatype='real' name='[CF  K2-1 vs LY (copy)_449234087459082246]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Listed metrics have opposite performance indicators&#13;&#10;&#13;&#10;IF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&apos;iCPA&apos;,&apos;CPM&apos;, &apos;CPC&apos;, &apos;Web CPO&apos;, &apos;Web CPV&apos;)&#13;&#10;    THEN[K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]*-1 &#13;&#10;    ELSE [K2-1 Active metric vs LY Difference (copy 3)_449234087459610641] //Default: positive numbers are Green and negative are Red&#13;&#10;END' />
            </column>
