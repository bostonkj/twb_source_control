      <column caption='vs. Spend TY' datatype='real' default-format='c&quot;$&quot;#,##0;&quot;$&quot;-#,##0' name='[Calculation_1146729096399511572]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF ([Calculation_1714182672546091008]) = &quot;TY&quot; AND [Parameters].[Parameter 12] = &apos;Store&apos; THEN [Calculation_2727985148704944162]&#10;    ELSEIF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [Spend] END)' />
      </column>
      <column caption='Date Filter' datatype='boolean' name='[Calculation_123286066946166785]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Date]&gt;=[Calculation_2637139079381286990] and [Date]&lt;=[Anchor Start Date (copy)_867505918082613251]' />
      </column>
      <column caption='Refresh Tooltip' datatype='string' name='[Calculation_1314488142121086976]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;Refreshed weekly by 8am CT&apos;' />
      </column>
      <column caption='KPI 1 Output' datatype='string' name='[Calculation_1570067444776833026]' role='measure' type='nominal'>
        <calculation class='tableau' formula='// Revenue formatting (currency, positive-only thresholds)&#13;&#10;IF [Parameters].[Parameter 7] = &quot;Revenue&quot; THEN&#13;&#10;&#13;&#10;        IF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000000)) + &quot;B&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000000, 1)) + &quot;B&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 100000000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000)) + &quot;M&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 10000000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000, 1)) + &quot;M&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 1000000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 100000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000)) + &quot;K&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 10000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000, 1)) + &quot;K&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 1000 THEN &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000, 2)) + &quot;K&quot;&#13;&#10;        ELSE &quot;$&quot; + STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778]))&#13;&#10;        END&#13;&#10;&#13;&#10;    // Customer/order counts formatting (positive-only thresholds)&#13;&#10;    ELSEIF [Parameters].[Parameter 7] IN (&#13;&#10;        &quot;Total Customers&quot;, &quot;New Customers&quot;, &quot;Orders&quot;, &quot;Current Customers&quot;, &quot;Reactivated Customers&quot;&#13;&#10;    ) THEN&#13;&#10;&#13;&#10;        IF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 100000000000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000000)) + &quot;B&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 10000000000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000000, 1)) + &quot;B&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 1000000000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 100000000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000)) + &quot;M&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 10000000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000, 1)) + &quot;M&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 1000000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 100000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000)) + &quot;K&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 10000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000, 1)) + &quot;K&quot;&#13;&#10;        ELSEIF [KPI1-1 Previous period (copy)_2409144348492107778] &gt; 1000 THEN STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778] / 1000, 2)) + &quot;K&quot;&#13;&#10;        ELSE STR(ROUND([KPI1-1 Previous period (copy)_2409144348492107778]))&#13;&#10;        END&#13;&#10;END' />
      </column>
      <column caption='YTD Date' datatype='date' name='[Calculation_1654228464561578010]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ FIXED [fiscalYear]:MIN([Date])}' />
      </column>
      <column caption='Date Flag' datatype='string' name='[Calculation_1714182672546091008]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Date]&gt;=[Calculation_2637139079381286990] and [Date]&lt;=[Anchor Start Date (copy)_867505918082613251] THEN &apos;TY&apos;&#13;&#10;ELSEIF  [Date]&gt;=DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1,[Parameters].[Parameter 8])+6,&apos;sunday&apos;) and [Date]&lt;=DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1,[Parameters].[Parameter 1])+6,&apos;saturday&apos;) THEN &apos;LY&apos;&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;ELSEIF  [Date]&gt;={[Anchor Start Date MTD (copy)_992762284465217540]} and [Date]&lt;=DATETRUNC(&apos;week&apos;,TODAY(),&apos;saturday&apos;)+1  THEN &apos;YTD Current&apos;&#13;&#10;ELSEIF  [Date]&gt;={[Anchor Start Date YTD (copy)_301178266734993423]} and [Date]&lt;=DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1, TODAY()),&apos;saturday&apos;)+1 THEN &apos;YTD Previous&apos;&#13;&#10;END' />
      </column>
      <column caption='Table Header - Plan' datatype='string' name='[Calculation_1872793685762048]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639] + &quot; &quot; + [$  kpi1-1 (copy)_1004302741622292481] + &quot; Plan&quot;' />
      </column>
      <column caption='Fiscal Week Start' datatype='datetime' name='[Calculation_1925851835080531968]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,MIN([Date])+10)' />
      </column>
      <column caption='Lookup Filter' datatype='integer' name='[Calculation_1925851835081474049]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(ATTR( IF [Date]&gt;= [Calculation_2637139079381286990] AND [Date]&lt;=[Anchor Start Date (copy)_867505918082613251] THEN 1 END),0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='vs. Spend LY (#)' datatype='real' name='[Calculation_2006635173569425408]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1146729096399511572]-[KPI 2-0 Total Media Spend (copy)_1146729096408174614]' />
      </column>
      <column caption='Primary KPI Contribution LY' datatype='real' name='[Calculation_2130202665754800150]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [P-KPI 1 TY (copy)_1146729096429023266]&gt;=[P-KPI 1 LY (copy)_1146729096431890469] THEN 0 &#13;&#10;ELSE [P-KPI 1 LY (copy)_1146729096431890469]&#13;&#10;END' />
      </column>
      <column caption='Anchor Start Date' datatype='datetime' name='[Calculation_2637139079381286990]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,[Parameters].[Parameter 8],&apos;sunday&apos;)' />
      </column>
      <column caption='Channel Has Spend' datatype='boolean' name='[Calculation_2727985147991842816]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// Keep entire channels if any row has Spend &gt; 0 or Spend is NOT NULL&#10;{ FIXED [Calculation_123286066946166785], [Channel]:&#10;    MAX(&#10;      IIF( IFNULL([Calculation_2727985148704944162], 0) &gt; 0, 1, 0 )&#10;//      IIF( IFNULL([Spend], 0) &gt; 0, 1, 0 )&#10;    )&#10;} = 1' />
      </column>
      <column caption='EMR Return' datatype='real' name='[Calculation_2727985148330471427]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM&#10;    (&#10;    IF [Calculation_2727985147991842816]=TRUE THEN [EMRValue] END) &#10;    ) &#10;    /SUM([Calculation_2727985148704944162])' />
      </column>
      <column caption='Media iROAS' datatype='real' name='[Calculation_2727985148333301764]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM&#10;    (IF [Calculation_2727985147991842816] = TRUE THEN [MediaRevenue] END)&#10;    )&#10;    /SUM([Calculation_2727985148704944162])' />
      </column>
      <column caption='Spend All' datatype='real' name='[Calculation_2727985148704944162]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Date], [Channel], [Subchannel]: SUM([Spend]) }' />
      </column>
      <column caption='EMR Value Calc' datatype='real' hidden='true' name='[Calculation_2778650646238633985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM&#10;    (&#10;    IF [Calculation_2727985147991842816]=TRUE THEN [EMRValue] END))' />
      </column>
      <column caption='vs. YTD Primary KPI (%)' datatype='real' default-format='p0.00%' name='[Calculation_301178266736517137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([P-KPI 1 MTD (copy)_992762284465725446]-[P-KPI 1 YTD (copy)_301178266732146701])/[P-KPI 1 YTD (copy)_301178266732146701]' />
      </column>
      <column caption='Anchor Date Range' datatype='date' hidden='true' name='[Calculation_318629700371587072]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Date]&gt;=[Calculation_2637139079381286990] and [Date]&lt;=[Anchor Start Date (copy)_867505918082613251] THEN [Date] END' />
      </column>
      <column caption='Date error' datatype='string' name='[Calculation_386183712160677888]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='if [Parameters].[Parameter 1]&lt;[Parameters].[Parameter 8] THEN&#13;&#10;&apos;Invaid Date Range: End Date cannot be earlier than Start Date&apos;&#13;&#10;END' />
      </column>
      <column caption='DZV Date Range Error' datatype='boolean' name='[Calculation_386183712196395012]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 1]&lt; [Parameters].[Parameter 8]' />
      </column>
      <column caption='Default Start Date' datatype='datetime' datatype-customized='true' name='[Calculation_4140989541042946049]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='//DATE(DATETRUNC(&apos;week&apos;, DATEADD(&apos;week&apos;, -4, TODAY())))&#13;&#10;&#13;&#10;{FIXED: DATEADD(&apos;week&apos;, -4, DATETRUNC(&apos;week&apos;, MAX(IF NOT ISNULL([EMRValue]) OR NOT ISNULL([RealizedMediaRevenue]) OR NOT ISNULL([MediaRevenue]) THEN [Date] END)))}' />
      </column>
      <column caption='Last 3 Months Date' datatype='string' name='[Calculation_4338556152561664]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF&#10;    DATETRUNC(&apos;month&apos;,[Date]) &gt;= DATEADD(&apos;month&apos;,-2,DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251]))&#10;    AND&#10;    DATETRUNC(&apos;month&apos;,[Date]) &lt;= DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251])&#10;&#10;THEN &apos;TY&apos;&#10;&#10;ELSEIF&#10;&#10;    DATETRUNC(&apos;month&apos;,[Date]) &gt;= DATEADD(&apos;year&apos;,-1,&#10;        DATEADD(&apos;month&apos;,-2,DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251])))&#10;    AND&#10;    DATETRUNC(&apos;month&apos;,[Date]) &lt;= DATEADD(&apos;year&apos;,-1,&#10;        DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251]))&#10;&#10;THEN &apos;LY&apos;&#10;&#10;END' />
      </column>
      <column caption='Exclude Channel' datatype='boolean' name='[Calculation_4512817981216530440]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT(REGEXP_MATCH([Channel],&#10;    &quot;.*(All|Base|Direct$|Internal|Other|Referring Domains|Unknown|Uninfluenced|Unmatched).*&quot;))' />
      </column>
      <column caption='Paid vs. Owned' datatype='string' name='[Calculation_6791006039007158277]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF REGEXP_MATCH([Channel], &#10;&quot;Affiliate|Direct Mail|Display|Paid Search|Paid Social|Video&quot;)&#10;THEN &quot;Paid&quot;&#10;ELSEIF REGEXP_MATCH([Channel], &#10;&quot;Base &amp; Traditional Media&quot;)&#10;THEN &quot;Base&quot;&#10;ELSEIF REGEXP_MATCH([Channel], &#10;&quot;CRM|Direct|Email|Internal|Organic Search|Organic Social|Referring Domains|SMS|Uninfluenced Order|Unknown|Unmatched Order&quot;)&#10;THEN &quot;Owned&quot;&#10;END' />
      </column>
      <column caption='Order Type Filter' datatype='boolean' name='[Calculation_985725394907299840]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 12]&#13;&#10;WHEN &apos;Enterprise&apos; THEN [OrderType (copy)_2727985147994247169] = [OrderType (copy)_2727985147994247169]&#13;&#10;WHEN &apos;Ecom&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;Ecom&apos;&#13;&#10;WHEN &apos;Store&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;Store&apos;&#13;&#10;WHEN &apos;App&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;App&apos;&#13;&#10;END' />
      </column>
      <column caption='Anchor Start Date MTD' datatype='date' name='[Calculation_992762284450070528]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='MIN &#13;&#10;(IF ([Date])= DATETRUNC(&apos;week&apos;,TODAY(),&apos;saturday&apos;) THEN [YTD Date (copy)_1654228464561893403] END)' />
      </column>
      <column caption='Anchor Date Range MTD' datatype='date' name='[Calculation_992762284451258369]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF [Date]&gt;={[Calculation_992762284450070528]} and [Date]&lt;=DATETRUNC(&apos;week&apos;,TODAY(),&apos;saturday&apos;)+1 THEN [Date]&#13;&#10;END' />
      </column>
