    <worksheet name='Paid v. Owned Contribution'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4b5a64' fontsize='12'>&lt;</run>
            <run bold='true' fontcolor='#4b5a64' fontsize='12'>[Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]</run>
            <run bold='true' fontcolor='#4b5a64' fontsize='12'>&gt; by Contribution Type</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='all_data_emr | Project : loft_prod_ehr' name='sqlproxy.0gs3wx61vvqjfu17bh93v1g4tnin' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Incremental Revenue ($)' caption='Primary KPI' datatype='string' name='[PL2 Active Metric Parameter (copy)_901282899119939639]' param-domain-type='list' role='measure' type='nominal' value='&quot;Incremental Revenue&quot;'>
              <calculation class='tableau' formula='&quot;Incremental Revenue&quot;' />
              <aliases>
                <alias key='&quot;EMR Value&quot;' value='EMR Value ($)' />
                <alias key='&quot;Future Incremental Revenue&quot;' value='Future Incremental Revenue ($)' />
                <alias key='&quot;Future Media Value&quot;' value='Future Media Value ($)' />
                <alias key='&quot;Incremental Revenue&quot;' value='Incremental Revenue ($)' />
                <alias key='&quot;Media Value&quot;' value='Media Value ($)' />
                <alias key='&quot;Realized Incremental Revenue&quot;' value='Realized Incremental Revenue ($)' />
                <alias key='&quot;Realized Media Value&quot;' value='Realized Media Value ($)' />
                <alias key='&quot;Revenue&quot;' value='Revenue ($)' />
                <alias key='&quot;Web Revenue&quot;' value='Web Revenue ($)' />
              </aliases>
            </column>
            <column caption='Order Type Param' datatype='string' name='[Parameter 12]' param-domain-type='list' role='measure' type='nominal' value='&quot;Enterprise&quot;'>
              <calculation class='tableau' formula='&quot;Enterprise&quot;' />
              <aliases>
                <alias key='&quot;Ecom&quot;' value='Ecom' />
              </aliases>
            </column>
            <column caption='Anchor End Date Param' datatype='date' default-format='*m/d/yyyy' default-value-field='[sqlproxy.0gs3wx61vvqjfu17bh93v1g4tnin].[Default Start Date (copy)_4140989541045669890]' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='#2026-07-04#'>
              <calculation class='tableau' formula='#2026-07-04#' />
              <range granularity='1' period-type-v2='day' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.0gs3wx61vvqjfu17bh93v1g4tnin'>
            <column caption='Primary KPI $' datatype='string' name='[$  kpi1-1 (copy)_1004302741622292481]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;when  &apos;Revenue&apos; then &apos;$&apos;&#10;when  &apos;Web Revenue&apos; then &apos;$&apos;&#10;when  &apos;Incremental Revenue&apos; then &apos;$&apos; &#10;when  &apos;Realized Incremental Revenue&apos;  then &apos;$&apos;&#10;when  &apos;Future Incremental Revenue&apos;  then &apos;$&apos;&#10;when  &apos;Media Value&apos; then &apos;$&apos;&#10;when  &apos;Realized Media Value&apos; then &apos;$&apos;&#10;when  &apos;Future Media Value&apos;then &apos;$&apos;&#10;when  &apos;EMR Value&apos; then &apos;$&apos;&#10;&#10;END&#10;&#10;&#10;/*WHEN &quot;Spend&quot; THEN &apos;$&apos;&#10;when  &apos;EMR$&apos; then &apos;$&apos;&#10;when  &apos;Realized Media Value&apos; then &apos;$&apos;&#10;when  &apos;Future Media Value&apos;then &apos;$&apos;&#10;when  &apos;Incremental Media Revenue&apos; then &apos;$&apos;&#10;when  &apos;Incremental Realized Media Revenue&apos; then &apos;$&apos;&#10;when  &apos;Incremental Future Media Revenue&apos; then &apos;$&apos;&#10;when  &apos;EMR $&apos; then &apos;$&apos;&#10;when  &apos;EMR Rate/$&apos; then &apos;$&apos;&#10;when  &apos;Media Return/$&apos; then &apos;$&apos;&#10;when  &apos;Realized Return/$&apos; then &apos;$&apos;&#10;when  &apos;iROAS&apos; then &apos;$&apos;&#10;when  &apos;Revenue&apos; then &apos;$&apos;&#10;when  &apos;RAOS&apos; then &apos;$&apos;&#10;when  &apos;CPO&apos; then &apos;$&apos;&#10;when  &apos;AOV&apos; then &apos;$&apos;&#10;when  &apos;Spend&apos; then &apos;$&apos;&#10;when  &apos;CPM&apos; then &apos;$&apos;&#10;&#10;when  &apos;CPC&apos; then &apos;$&apos;&#10;when  &apos;CPV&apos; then &apos;$&apos;&#10;when  &apos;Media Revenue&apos; then &apos;$&apos; &#10;when  &apos;Realized Media Revenue&apos;  then &apos;$&apos;&#10;when  &apos;Realized iROAS&apos; then &apos;$&apos;&#10;when  &apos;Incremental Media Revenue(Realized + Future)&apos; then&apos;$&apos;&#10;when  &apos;Incremental Realized Media Revenue&apos; then &apos;$&apos;&#10;ELSE &apos;&apos;*/' />
            </column>
            <column caption='Anchor End Date' datatype='datetime' name='[Anchor Start Date (copy)_867505918082613251]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,[Parameters].[Parameter 1]+6,&apos;saturday&apos;)' />
            </column>
            <column caption='Last 3 Months Date' datatype='string' name='[Calculation_4338556152561664]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF&#10;    DATETRUNC(&apos;month&apos;,[Date]) &gt;= DATEADD(&apos;month&apos;,-2,DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251]))&#10;    AND&#10;    DATETRUNC(&apos;month&apos;,[Date]) &lt;= DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251])&#10;&#10;THEN &apos;TY&apos;&#10;&#10;ELSEIF&#10;&#10;    DATETRUNC(&apos;month&apos;,[Date]) &gt;= DATEADD(&apos;year&apos;,-1,&#10;        DATEADD(&apos;month&apos;,-2,DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251])))&#10;    AND&#10;    DATETRUNC(&apos;month&apos;,[Date]) &lt;= DATEADD(&apos;year&apos;,-1,&#10;        DATETRUNC(&apos;month&apos;,[Anchor Start Date (copy)_867505918082613251]))&#10;&#10;THEN &apos;LY&apos;&#10;&#10;END' />
            </column>
            <column caption='Paid vs. Owned' datatype='string' name='[Calculation_6791006039007158277]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF REGEXP_MATCH([Channel], &#10;&quot;Affiliate|Direct Mail|Display|Paid Search|Paid Social|Video&quot;)&#10;THEN &quot;Paid&quot;&#10;ELSEIF REGEXP_MATCH([Channel], &#10;&quot;Base &amp; Traditional Media&quot;)&#10;THEN &quot;Base&quot;&#10;ELSEIF REGEXP_MATCH([Channel], &#10;&quot;CRM|Direct|Email|Internal|Organic Search|Organic Social|Referring Domains|SMS|Uninfluenced Order|Unknown|Unmatched Order&quot;)&#10;THEN &quot;Owned&quot;&#10;END' />
            </column>
            <column caption='Order Type Filter' datatype='boolean' name='[Calculation_985725394907299840]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 12]&#13;&#10;WHEN &apos;Enterprise&apos; THEN [OrderType (copy)_2727985147994247169] = [OrderType (copy)_2727985147994247169]&#13;&#10;WHEN &apos;Ecom&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;Ecom&apos;&#13;&#10;WHEN &apos;Store&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;Store&apos;&#13;&#10;WHEN &apos;App&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;App&apos;&#13;&#10;END' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[Channel]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[CurrentCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[Date]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
            <column caption='Default End Date' datatype='datetime' datatype-customized='true' name='[Default Start Date (copy)_4140989541045669890]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='//DATE(DATEADD(&apos;day&apos;, -1, DATETRUNC(&apos;week&apos;, TODAY())))&#13;&#10;&#13;&#10;{FIXED: DATEADD(&apos;day&apos;, 6, DATETRUNC(&apos;week&apos;, MAX(IF NOT ISNULL([EMRValue]) OR NOT ISNULL([RealizedMediaRevenue]) OR NOT ISNULL([MediaRevenue]) THEN [Date] END)))}' />
            </column>
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[EMRValue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[FunnelStage]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FutureMediaRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FutureMediaValue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
