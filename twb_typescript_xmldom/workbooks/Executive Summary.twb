      <column caption='Plan KPI 5 LY' datatype='real' hidden='true' name='[KPI 5 LY (copy)_2727985148615004191]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013]&#13;&#10;&#13;&#10;    WHEN &apos;Spend&apos; THEN SUM([PlanSpend_LY])&#13;&#10;    WHEN &apos;CPM&apos; THEN (SUM([PlanSpend_LY]) / SUM([PlanImpressions_LY]) * 1000)&#13;&#10;    WHEN &apos;Impressions&apos; THEN SUM([PlanImpressions_LY])&#13;&#10;    WHEN &apos;CTR&apos; THEN (SUM([PlanClicks_LY]) / SUM([PlanImpressions_LY]))&#13;&#10;    WHEN &apos;CPC&apos; THEN (SUM([PlanSpend_LY]) / SUM([PlanClicks_LY]))&#13;&#10;    WHEN &apos;Clicks&apos; THEN SUM([PlanClicks_LY])&#13;&#10;    WHEN &apos;Web CVR&apos; THEN (SUM([PlanWebOrders_LY]) / SUM([PlanWebTraffic_LY]))&#13;&#10;    WHEN &apos;Web CPO&apos; THEN (SUM([PlanSpend_LY]) / SUM([PlanWebOrders_LY]))&#13;&#10;    WHEN &apos;Web Orders&apos; THEN SUM([PlanWebOrders_LY])&#13;&#10;    WHEN &apos;Web AOV&apos; THEN (SUM([PlanWebRevenue_LY]) / SUM([PlanWebOrders_LY]))&#13;&#10;    WHEN &apos;Web Revenue&apos; THEN SUM([PlanWebRevenue_LY])&#13;&#10;    WHEN &apos;Web ROAS&apos; THEN (SUM([PlanWebRevenue_LY]) / SUM([PlanSpend_LY]))&#13;&#10;    WHEN &apos;Web Traffic&apos; THEN SUM([PlanWebTraffic_LY])&#13;&#10;    WHEN &apos;Web CPV&apos; THEN (SUM([PlanSpend_LY]) / SUM([PlanWebTraffic_LY]))&#13;&#10;    WHEN &apos;Media Revenue&apos; THEN SUM([PlanMediaRevenue_LY])&#13;&#10;    WHEN &apos;Media iROAS&apos; THEN [Media iROAS LY (copy) (copy)_2727985148349210652]&#13;&#10;    WHEN &apos;Realized Media Revenue&apos; THEN SUM([PlanRealizedMediaRevenue_LY])&#13;&#10;    WHEN &apos;Realized iROAS&apos; THEN [Realized iROAS LY (copy) (copy)_2727985148349210654]&#13;&#10;    WHEN &apos;Future Media Revenue&apos; THEN SUM([PlanFutureMediaRevenue_LY])&#13;&#10;    WHEN &apos;Future iROAS&apos; THEN [Future iROAS LY (copy) (copy)_2727985148349210650]&#13;&#10;    WHEN &apos;Media Value&apos; THEN SUM([PlanMediaValue_LY])&#13;&#10;    WHEN &apos;Media Return&apos; THEN [Media Return LY (copy) (copy)_2727985148349210651]&#13;&#10;    WHEN &apos;Realized Media Value&apos; THEN SUM([PlanRealizedMediaValue_LY])&#13;&#10;    WHEN &apos;Realized Return&apos; THEN [Realized Return LY (copy) (copy)_2727985148349210653]&#13;&#10;    WHEN &apos;Future Media Value&apos; THEN SUM([PlanFutureMediaValue_LY])&#13;&#10;    WHEN &apos;Future Return&apos; THEN [Future Return LY (copy) (copy)_2727985148349210649]&#13;&#10;    WHEN &apos;EMR Value&apos; THEN SUM([PlanEMRValue_LY])&#13;&#10;    WHEN &apos;EMR Return&apos; THEN [EMR Return LY (copy) (copy)_2727985148349210648]&#13;&#10;    WHEN &apos;Incremental Total Customers&apos; THEN SUM([PlanIncrementalTotalCustomers_LY])&#13;&#10;    WHEN &apos;Incremental New Customers&apos; THEN SUM([PlanIncrementalNewCustomers_LY])&#13;&#10;    WHEN &apos;iCPA&apos; THEN (SUM([PlanSpend_LY]) / SUM([PlanIncrementalNewCustomers_LY]))&#13;&#10;    WHEN &apos;Incremental Current Customers&apos; THEN SUM([PlanIncrementalCurrentCustomers_LY])&#13;&#10;    WHEN &apos;Incremental Reactivated Customers&apos; THEN SUM([PlanIncrementalReactivatedCustomers_LY])&#10;&#13;&#10;    WHEN &apos;Platform CVR&apos; THEN 0&#13;&#10;    WHEN &apos;Platform Orders&apos; THEN 0&#13;&#10;    WHEN &apos;Platform AOV&apos; THEN 0&#13;&#10;    WHEN &apos;Platform Revenue&apos; THEN 0&#13;&#10;    WHEN &apos;Platform ROAS&apos; THEN 0&#10;&#13;&#10;    WHEN &apos;Web RPV&apos; THEN (SUM([PlanWebRevenue_LY]) / SUM([PlanWebTraffic_LY]))&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN SUM({ FIXED : SUM([PlanWebRevenue_LY]) })&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN&#13;&#10;        SUM([PlanWebRevenue_LY]) / SUM({ FIXED : SUM([PlanWebRevenue_LY]) })&#13;&#10;&#13;&#10;END' />
      </column>
