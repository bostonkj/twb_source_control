            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[IncrementalNewCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[IncrementalReactivatedCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[IncrementalTotalCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[MediaMix]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[MediaRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[MediaValue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[NewCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='Order Type' datatype='string' name='[OrderType (copy)_2727985147994247169]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[OrderType]' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' hidden='true' layered='true' name='[OrderType]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[Orders]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='Primary KPI' datatype='real' name='[P-KPI 1 LY (copy)_1146729096431890469]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;    WHEN &apos;Revenue&apos; THEN SUM([Revenue])&#10;    WHEN &apos;Orders&apos; THEN SUM([Orders])&#10;    WHEN &apos;Total Customers&apos; THEN SUM([TotalCustomers])&#10;    WHEN &apos;New Customers&apos; THEN SUM([NewCustomers])&#10;    WHEN &apos;Current Customers&apos; THEN SUM([CurrentCustomers])&#10;    WHEN &apos;Reactivated Customers&apos; THEN SUM([ReactivatedCustomers])&#10;    WHEN &apos;Web Orders&apos; THEN SUM([WebOrders])&#10;    WHEN &apos;Web Revenue&apos; THEN SUM([WebRevenue])&#10;    WHEN &apos;Web Traffic&apos; THEN SUM([WebTraffic])&#10;    WHEN &apos;Incremental Revenue&apos; THEN SUM([MediaRevenue])&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN SUM([RealizedMediaRevenue])&#10;    WHEN &apos;Future Incremental Revenue&apos; THEN SUM([FutureMediaRevenue])&#10;    WHEN &apos;Media Value&apos; THEN SUM([MediaValue])&#10;    WHEN &apos;Realized Media Value&apos; THEN SUM([RealizedMediaValue])&#10;    WHEN &apos;Future Media Value&apos; THEN SUM([FutureMediaValue])&#10;    WHEN &apos;EMR Value&apos; THEN SUM([EMRValue])&#10;    WHEN &apos;Incremental Total Customers&apos; THEN SUM([IncrementalTotalCustomers])&#10;    WHEN &apos;Incremental New Customers&apos; THEN SUM([IncrementalNewCustomers])&#10;    WHEN &apos;Incremental Current Customers&apos; THEN SUM([IncrementalCurrentCustomers])&#10;    WHEN &apos;Incremental Reactivated Customers&apos; THEN SUM([IncrementalReactivatedCustomers])&#10;END' />
            </column>
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[ReactivatedCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[RealizedMediaRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[RealizedMediaValue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-format='C1033%' default-type='quantitative' layered='true' name='[Revenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[TotalCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
