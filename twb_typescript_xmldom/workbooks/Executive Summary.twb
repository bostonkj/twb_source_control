            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[PlatformOrders]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[PlatformRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
