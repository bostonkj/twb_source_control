            <column caption='vs. KPI 7 LY (#) Output' datatype='string' name='[K2-1  Active Metrics vs LY % (copy 3)_1691383160033619986]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IIF([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#10;+&#10;&#10;// $ metrics -&gt; currency formatting ($ + K/M/B)&#10;IF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&#10;    &quot;Spend&quot;, &quot;Total Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Incremental Revenue&quot;,&quot;Realized Incremental Revenue&quot;,&quot;Future Incremental Revenue&quot;,&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#10;) THEN&#10;&#10;    IF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000000)) + &quot;B&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000000, 1)) + &quot;B&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000)) + &quot;M&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000, 1)) + &quot;M&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000)) + &quot;K&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000, 1)) + &quot;K&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000, 2)) + &quot;K&quot;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641])))&#10;    END&#10;&#10;// Count metrics -&gt; count formatting (K/M/B, no $)&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#10;    &quot;Platform Orders&quot;&#10;) THEN&#10;&#10;    IF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 100000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000000)) + &quot;B&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 10000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000000, 1)) + &quot;B&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 1000000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 100000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000)) + &quot;M&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 10000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000, 1)) + &quot;M&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 1000000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 100000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000)) + &quot;K&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 10000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000, 1)) + &quot;K&quot;&#10;    ELSEIF ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) &gt; 1000 THEN STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]) / 1000, 2)) + &quot;K&quot;&#10;    ELSE STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641])))&#10;    END&#10;&#10;// Rate / per metrics -&gt; 2dp currency&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#10;    &quot;iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#10;    &quot;Media Return&quot;,&quot;Realized Media Return&quot;,&quot;Future Media Return&quot;,&quot;EMR Return&quot;,&#10;    &quot;New Customer iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#10;) THEN&#10;    &quot;$&quot; + STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]), 2))&#10;&#10;// Percent metrics -&gt; 2dp %&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;, &quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;    STR(ROUND(ABS([K2-1 Active metric vs LY Difference (copy 3)_449234087459610641])*100, 2)) + &quot;%&quot;&#10;&#10;/*&#10;// Special case preserved exactly as provided (uses [KPI 7], not vs field)&#10;ELSEIF [Parameters].[KPI 7] IN (&quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;    STR(ROUND(([KPI 7]) * 100, 2)) + &quot;%&quot;&#10;*/&#10;&#10;END' />
            </column>
            <column caption='vs. KPI 7 LY (#)' datatype='real' name='[K2-1 Active metric vs LY Difference (copy 3)_449234087459610641]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([KPI2-2 This Year (copy 2)_1255096945753931784])-[KPI2-1 Last Year (copy 3)_449234087458062341]' />
            </column>
            <column caption='Plan KPI 7' datatype='real' name='[KPI 2-1 Plan (copy 3)_1793840067787292675]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953]&#10;&#10;    WHEN &apos;Spend&apos; THEN SUM([Spend All (copy)_3996311395817148417])&#10;    WHEN &apos;Total Spend&apos; THEN [Calculation_0192155404906503]&#10;    WHEN &apos;% Total Spend&apos; THEN&#10;        SUM([Spend All (copy)_3996311395817148417]) / [Calculation_0192155404906503]&#10;    WHEN &apos;CPM&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanImpressions]) * 1000)&#10;    WHEN &apos;Impressions&apos; THEN SUM([PlanImpressions])&#10;    WHEN &apos;CTR&apos; THEN (SUM([PlanClicks]) / SUM([PlanImpressions]))&#10;    WHEN &apos;CPC&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanClicks]))&#10;    WHEN &apos;Clicks&apos; THEN SUM([PlanClicks])&#10;    WHEN &apos;Web CVR&apos; THEN (SUM([PlanWebOrders]) / SUM([PlanWebTraffic]))&#10;    WHEN &apos;Web CPO&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebOrders]))&#10;    WHEN &apos;Web Orders&apos; THEN SUM([PlanWebOrders])&#10;    WHEN &apos;Web AOV&apos; THEN (SUM([PlanWebRevenue]) / SUM([PlanWebOrders]))&#10;    WHEN &apos;Web Revenue&apos; THEN SUM([PlanWebRevenue])&#10;&#10;    WHEN &apos;Total Web Revenue&apos; THEN [Calculation_0192155404361731]&#10;    WHEN &apos;% Total Web Revenue&apos; THEN&#10;        SUM([PlanWebRevenue]) / [Calculation_0192155404361731]&#10;&#10;    WHEN &apos;Web ROAS&apos; THEN (SUM([PlanWebRevenue]) / SUM([PlanSpend]))&#10;    WHEN &apos;Web Traffic&apos; THEN SUM([PlanWebTraffic])&#10;    WHEN &apos;Web CPV&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebTraffic]))&#10;    WHEN &apos;Incremental Revenue&apos; THEN SUM([PlanMediaRevenue])&#10;    WHEN &apos;iROAS&apos; THEN [Media iROAS LY (copy)_2727985148349190165]&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN SUM([PlanRealizedMediaRevenue])&#10;    WHEN &apos;Realized iROAS&apos; THEN [Realized iROAS LY (copy)_2727985148349190167]&#10;    WHEN &apos;Future Incremental Revenue&apos; THEN SUM([PlanFutureMediaRevenue])&#10;    WHEN &apos;Future iROAS&apos; THEN [Future iROAS LY (copy)_2727985148349190163]&#10;    WHEN &apos;Media Value&apos; THEN SUM([PlanMediaValue])&#10;    WHEN &apos;Media Return&apos; THEN [Media Return LY (copy)_2727985148349190164]&#10;    WHEN &apos;Realized Media Value&apos; THEN SUM([PlanRealizedMediaValue])&#10;    WHEN &apos;Realized Media Return&apos; THEN [Realized Return LY (copy)_2727985148349190166]&#10;    WHEN &apos;Future Media Value&apos; THEN SUM([PlanFutureMediaValue])&#10;    WHEN &apos;Future Media Return&apos; THEN [Future Return LY (copy)_2727985148349190162]&#10;    WHEN &apos;EMR Value&apos; THEN SUM([PlanEMRValue])&#10;    WHEN &apos;EMR Return&apos; THEN [EMR Return LY (copy)_2727985148349190161]&#10;    WHEN &apos;Incremental Total Customers&apos; THEN SUM([PlanIncrementalTotalCustomers])&#10;    WHEN &apos;Incremental New Customers&apos; THEN SUM([PlanIncrementalNewCustomers])&#10;    WHEN &apos;New Customer iCPA&apos; THEN (SUM([PlanSpend]) / SUM([PlanIncrementalNewCustomers]))&#10;    WHEN &apos;Incremental Current Customers&apos; THEN SUM([PlanIncrementalCurrentCustomers])&#10;    WHEN &apos;Incremental Reactivated Customers&apos; THEN SUM([PlanIncrementalReactivatedCustomers])&#10;&#10;    WHEN &apos;Platform CVR&apos; THEN 0&#10;    WHEN &apos;Platform Orders&apos; THEN 0&#10;    WHEN &apos;Platform AOV&apos; THEN 0&#10;    WHEN &apos;Platform Revenue&apos; THEN 0&#10;    WHEN &apos;Platform ROAS&apos; THEN 0&#10;&#10;    WHEN &apos;Web RPV&apos; THEN (SUM([PlanWebRevenue]) / SUM([PlanWebTraffic]))&#10;&#10;END' />
            </column>
            <column caption='vs. Plan KPI 7 (#)' datatype='real' name='[KPI 2-1 Plan Difference (copy 2)_1793840067788333062]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([KPI2-2 This Year (copy 2)_1255096945753931784])-([KPI 2-1 Plan (copy 3)_1793840067787292675])' />
            </column>
            <column caption='vs. Plan KPI 7 (#) Output' datatype='string' name='[KPI 2-1 vs Plan Difference Str (copy 3)_1146729096347430923]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IIF([KPI 2-1 Plan Difference (copy 2)_1793840067788333062] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#10;+&#10;&#10;// $ metrics -&gt; currency formatting ($ + K/M/B)&#10;IF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&#10;    &quot;Spend&quot;, &quot;Total Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Incremental Revenue&quot;,&quot;Realized Incremental Revenue&quot;,&quot;Future Incremental Revenue&quot;,&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#10;) THEN&#10;&#10;    IF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000000)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000000, 1)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000, 1)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000, 1)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000, 2)) + &quot;K&quot;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062])))&#10;    END&#10;&#10;// Count metrics -&gt; count formatting (K/M/B, no $)&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#10;    &quot;Platform Orders&quot;&#10;) THEN&#10;&#10;    IF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 100000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000000)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 10000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000000, 1)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 1000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 100000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 10000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000, 1)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 1000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 100000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 10000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000, 1)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) &gt; 1000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]) / 1000, 2)) + &quot;K&quot;&#10;    ELSE STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062])))&#10;    END&#10;&#10;// Rate / per metrics -&gt; 2dp currency&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#10;    &quot;iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#10;    &quot;Media Return&quot;,&quot;Realized Media Return&quot;,&quot;Future Media Return&quot;,&quot;EMR Return&quot;,&#10;    &quot;New Customer iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#10;) THEN&#10;    &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062]), 2))&#10;&#10;// Percent metrics -&gt; 2dp %&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;, &quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;    STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 2)_1793840067788333062])*100, 2)) + &quot;%&quot;&#10;&#10;/*&#10;// Special case preserved exactly as provided (uses [KPI 7], not vs field)&#10;ELSEIF [Parameters].[KPI 7] IN (&quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;    STR(ROUND(([KPI 7]) * 100, 2)) + &quot;%&quot;&#10;*/&#10;&#10;END' />
            </column>
            <column caption='KPI 7 LY' datatype='real' name='[KPI2-1 Last Year (copy 3)_449234087458062341]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953]&#10;&#10;    WHEN &apos;Spend&apos; THEN SUM([Spend All (copy)_3996311395816796160])&#10;    WHEN &apos;Total Spend&apos; THEN [Calculation_0192155404787718]&#10;    WHEN &apos;% Total Spend&apos; THEN&#10;        SUM([Spend All (copy)_3996311395816796160]) / [Calculation_0192155404787718]&#10;    WHEN &apos;CPM&apos; THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([Impressions_LY]) * 1000)&#10;    WHEN &apos;Impressions&apos; THEN SUM([Impressions_LY])&#10;    WHEN &apos;CTR&apos; THEN (SUM([Clicks_LY]) / SUM([Impressions_LY]))&#10;    WHEN &apos;CPC&apos; THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([Clicks_LY]))&#10;    WHEN &apos;Clicks&apos; THEN SUM([Clicks_LY])&#10;    WHEN &apos;Web CVR&apos; THEN (SUM([WebOrders_LY]) / SUM([WebTraffic_LY]))&#10;    WHEN &apos;Web CPO&apos; THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([WebOrders_LY]))&#10;    WHEN &apos;Web Orders&apos; THEN SUM([WebOrders_LY])&#10;    WHEN &apos;Web AOV&apos; THEN (SUM([WebRevenue_LY]) / SUM([WebOrders_LY]))&#10;    WHEN &apos;Web Revenue&apos; THEN SUM([WebRevenue_LY])&#10;    WHEN &apos;Web ROAS&apos; THEN (SUM([WebRevenue_LY]) / SUM([Spend_LY]))&#10;    WHEN &apos;Web Traffic&apos; THEN SUM([WebTraffic_LY])&#10;    WHEN &apos;Web CPV&apos; THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([WebTraffic_LY]))&#10;    WHEN &apos;Incremental Revenue&apos; THEN SUM([MediaRevenue_LY])&#10;    WHEN &apos;iROAS&apos; THEN [Media iROAS (copy)_2727985148341379083]&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN SUM([RealizedMediaRevenue_LY])&#10;    WHEN &apos;Realized iROAS&apos; THEN [Realized iROAS (copy)_2727985148341379087]&#10;    WHEN &apos;Future Incremental Revenue&apos; THEN SUM([FutureMediaRevenue_LY])&#10;    WHEN &apos;Future iROAS&apos; THEN [Future iROAS (copy)_2727985148341379086]&#10;    WHEN &apos;Media Value&apos; THEN SUM([MediaValue_LY])&#10;    WHEN &apos;Media Return&apos; THEN [Media Return (copy)_2727985148341379088]&#10;    WHEN &apos;Realized Media Value&apos; THEN SUM([RealizedMediaValue_LY])&#10;    WHEN &apos;Realized Media Return&apos; THEN [Realized Return (copy)_2727985148341379084]&#10;    WHEN &apos;Future Media Value&apos; THEN SUM([FutureMediaValue_LY])&#10;    WHEN &apos;Future Media Return&apos; THEN [Future Return (copy)_2727985148341379085]&#10;    WHEN &apos;EMR Value&apos; THEN SUM([EMRValue_LY])&#10;    WHEN &apos;EMR Return&apos; THEN [EMR Return (copy)_2727985148341379082]&#10;    WHEN &apos;Incremental Total Customers&apos; THEN SUM([IncrementalTotalCustomers_LY])&#10;    WHEN &apos;Incremental New Customers&apos; THEN SUM([IncrementalNewCustomers_LY])&#10;    WHEN &apos;New Customer iCPA&apos; THEN (SUM([Spend All (copy)_3996311395816796160]) / SUM([IncrementalNewCustomers_LY]))&#10;    WHEN &apos;Incremental Current Customers&apos; THEN SUM([IncrementalCurrentCustomers_LY])&#10;    WHEN &apos;Incremental Reactivated Customers&apos; THEN SUM([IncrementalReactivatedCustomers_LY])&#10;    WHEN &apos;Platform CVR&apos; THEN (SUM([PlatformOrders_LY]) / SUM([Clicks_LY]))&#10;    WHEN &apos;Platform Orders&apos; THEN SUM([PlatformOrders_LY])&#10;    WHEN &apos;Platform AOV&apos; THEN (SUM([PlatformRevenue_LY]) / SUM([PlatformOrders_LY]))&#10;    WHEN &apos;Platform Revenue&apos; THEN SUM([PlatformRevenue_LY])&#10;    WHEN &apos;Platform ROAS&apos; THEN (SUM([PlatformRevenue_LY]) / SUM([Spend_LY]))&#10;    WHEN &apos;Web RPV&apos; THEN (SUM([WebRevenue_LY]) / SUM([WebTraffic_LY]))&#10;    WHEN &apos;Total Web Revenue&apos; THEN [Calculation_0192155404197890]&#10;    WHEN &apos;% Total Web Revenue&apos; THEN&#10;        SUM([WebRevenue_LY]) / [Calculation_0192155404197890]&#10;&#10;END' />
            </column>
