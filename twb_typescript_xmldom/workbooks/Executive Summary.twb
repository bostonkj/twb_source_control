            <column caption='vs. Spend LY' datatype='real' name='[KPI 2-0 Total Media Spend (copy)_1146729096408174614]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Parameters].[Parameter 12] = &apos;Store&apos; THEN [Spend All (copy)_3996311395816796160]&#10;    ELSE [Spend_LY] END)&#10;&#10;/*&#10;SUM(IF ([Date Flag]) = &quot;LY&quot; AND [Order Type Param] = &apos;Store&apos; THEN [Spend All]&#10;    ELSEIF [Date Flag] = &apos;LY&apos; THEN [Spend] END)&#10;*/' />
            </column>
            <column caption='vs. Plan Spend (%) Output' datatype='string' name='[KPI 2-0 Total Media Spend LY % Str (copy)_1146729096418410526]' role='measure' type='nominal'>
              <calculation class='tableau' formula='//STR((INT([K1-1 Active metric vs LY Difference])))+&apos; | &apos;+STR(ROUND([K1-1 Active metric vs LY %]*100,2))+&apos;%&apos;&#13;&#10;IF ([KPI 2-0 LY % (copy)_1146729096412839964] ) &gt;= 0&#13;&#10;THEN &apos;▲&apos; ELSE &apos;▼&apos; END&#13;&#10; + STR(ROUND(ABS([KPI 2-0 LY % (copy)_1146729096412839964]) * 100,2))+ &quot;%&quot;' />
            </column>
