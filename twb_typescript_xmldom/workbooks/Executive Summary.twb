              <calculation class='tableau' formula='(SUM&#10;    (IF [Calculation_2727985147991842816] = TRUE THEN [RealizedMediaRevenue] END)&#10;    )&#10;    /SUM([Calculation_2727985148704944162])' />
            </column>
            <column caption='Media Return' datatype='real' name='[Media iROAS (copy)_2727985148338708487]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM&#10;    (IF [Calculation_2727985147991842816] = TRUE THEN [MediaValue] END)&#10;    )&#10;    /SUM([Calculation_2727985148704944162])' />
            </column>
