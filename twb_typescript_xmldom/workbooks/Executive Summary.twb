            <column caption='vs. Plan Spend (%)' datatype='real' default-format='p0.00%' name='[KPI 2-0 LY % (copy)_1146729096412839964]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(([Calculation_1146729096399511572])-([KPI 2-0 Total Media Spend LY (copy)_1146729096412528666]))/([KPI 2-0 Total Media Spend LY (copy)_1146729096412528666])' />
