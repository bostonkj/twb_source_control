      <column caption='vs. Plan KPI 6 (#) Output' datatype='string' name='[KPI 2-1 vs Plan Difference Str (copy 2)_1146729096347410442]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IIF([KPI 2-1 Plan Difference (copy)_1793840067788312581] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#10;+&#10;&#10;// $ metrics -&gt; currency formatting ($ + K/M/B)&#10;IF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#10;    &quot;Spend&quot;, &quot;Total Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Incremental Revenue&quot;,&quot;Realized Incremental Revenue&quot;,&quot;Future Incremental Revenue&quot;,&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#10;) THEN&#10;&#10;    IF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 1)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 1)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 1)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 2)) + &quot;K&quot;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581])))&#10;    END&#10;&#10;// Count metrics -&gt; count formatting (K/M/B, no $)&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#10;    &quot;Platform Orders&quot;&#10;) THEN&#10;&#10;    IF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 1)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 1)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 100000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 10000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 1)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) &gt; 1000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]) / 1000, 2)) + &quot;K&quot;&#10;    ELSE STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581])))&#10;    END&#10;&#10;// Rate / per metrics -&gt; 2dp currency&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#10;    &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#10;    &quot;iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#10;    &quot;Media Return&quot;,&quot;Realized Media Return&quot;,&quot;Future Media Return&quot;,&quot;EMR Return&quot;,&#10;    &quot;New Customer iCPA&quot;,&quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#10;) THEN&#10;    &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581]), 2))&#10;&#10;// Percent metrics -&gt; 2dp %&#10;ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;, &quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;    STR(ROUND(ABS([KPI 2-1 Plan Difference (copy)_1793840067788312581])*100, 2)) + &quot;%&quot;&#10;&#10;/*&#10;// Special case preserved exactly as provided (uses [KPI 6], not vs field)&#10;ELSEIF [Parameters].[KPI 6] IN (&quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;    STR(ROUND(([KPI 6]) * 100, 2)) + &quot;%&quot;&#10;*/&#10;&#10;END' />
