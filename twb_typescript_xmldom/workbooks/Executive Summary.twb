              <calculation class='tableau' formula='IIF([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;IF ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) &gt; 100000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) / 1000000000))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) &gt; 10000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) / 1000000000,1))+&quot;B&quot;&#13;&#10;ELSEIF  ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) &gt; 1000000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) / 1000000000,2))+&quot;B&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) &gt; 100000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) / 1000000))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) &gt; 10000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) / 1000000,1))+&quot;M&quot;&#13;&#10;ELSEIF  ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) &gt; 1000000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) / 1000000,2))+&quot;M&quot;&#13;&#10;&#13;&#10;ELSEIF  ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) &gt; 100000&#13;&#10;    THEN &quot;$&quot;+STR(ROUND(ABS([KPI 2-0 Total Media Spend 2-0 LY Difference (copy)_2006635173569720321]) / 1000))+&quot;K&quot;&