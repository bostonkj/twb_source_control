ifference (copy 3)_1793840067788357639]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000, 1)) + &quot;K&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000, 2)) + &quot;K&quot;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639])))&#10;    END&#10;&#10;// Count metrics -&gt; count formatting (K/M/B, no $)&#10;ELSEIF [Parameters].[K2-2 Active Metric Parameter (copy) (copy)_1255096945751834626] IN (&#10;    &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#10;    &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#10;    &quot;Platform Orders&quot;&#10;) THEN&#10;&#10;    IF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 100000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000000000)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 10000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000000000, 1)) + &quot;B&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 1000000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;    ELSEIF ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) &gt; 100000000 THEN STR(ROUND(ABS([KPI 2-1 Plan Difference (copy 3)_1793840067788357639]) / 1000000)) + &quot;M&quot;&#10;    ELSEIF ABS([KPI 2-1 Plan