            <column caption='Date Flag' datatype='string' name='[Calculation_1714182672546091008]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Date]&gt;=[Calculation_2637139079381286990] and [Date]&lt;=[Anchor Start Date (copy)_867505918082613251] THEN &apos;TY&apos;&#13;&#10;ELSEIF  [Date]&gt;=DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1,[Parameters].[Parameter 8])+6,&apos;sunday&apos;) and [Date]&lt;=DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1,[Parameters].[Parameter 1])+6,&apos;saturday&apos;) THEN &apos;LY&apos;&#13;&#10;ELSEIF [Date] &gt;= [Previous Period Start Date] AND [Date] &lt;= [Previous Period End Date] THEN &quot;PP&quot;&#13;&#10;ELSEIF  [Date]&gt;={[Anchor Start Date MTD (copy)_992762284465217540]} and [Date]&lt;=DATETRUNC(&apos;week&apos;,TODAY(),&apos;saturday&apos;)+1  THEN &apos;YTD Current&apos;&#13;&#10;ELSEIF  [Date]&gt;={[Anchor Start Date YTD (copy)_301178266734993423]} and [Date]&lt;=DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1, TODAY()),&apos;saturday&apos;)+1 THEN &apos;YTD Previous&apos;&#13;&#10;END' />
