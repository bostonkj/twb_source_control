            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[Orders]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='Primary KPI' datatype='real' name='[P-KPI 1 LY (copy)_1146729096431890469]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;    WHEN &apos;Revenue&apos; THEN SUM([Revenue])&#10;    WHEN &apos;Orders&apos; THEN SUM([Orders])&#10;    WHEN &apos;Total Customers&apos; THEN SUM([TotalCustomers])&#10;    WHEN &apos;New Customers&apos; THEN SUM([NewCustomers])&#10;    WHEN &apos;Current Customers&apos; THEN SUM([CurrentCustomers])&#10;    WHEN &apos;Reactivated Customers&apos; THEN SUM([ReactivatedCustomers])&#10;    WHEN &apos;Web Orders&apos; THEN SUM([WebOrders])&#10;    WHEN &apos;Web Revenue&apos; THEN SUM([WebRevenue])&#10;    WHEN &apos;Web Traffic&apos; THEN SUM([WebTraffic])&#10;    WHEN &apos;Incremental Revenue&apos; THEN SUM([MediaRevenue])&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN SUM([RealizedMediaRevenue])&#10;    WHEN &apos;Future Incremental Revenue&apos; THEN SUM([FutureMediaRevenue])&#10;    WHEN &apos;Media Value&apos; THEN SUM([MediaValue])&#10;    WHEN &apos;Realized Media Value&apos; THEN SUM([RealizedMediaValue])&#10;    WHEN &apos;Future Media Value&apos; THEN SUM([FutureMediaValue])&#10;    WHEN &apos;EMR Value&apos; THEN SUM([EMRValue])&#10;    WHEN &apos;Incremental Total Customers&apos; THEN SUM([IncrementalTotalCustomers])&#10;    WHEN &apos;Incremental New Customers&apos; THEN SUM([IncrementalNewCustomers])&#10;    WHEN &apos;Incremental Current Customers&apos; THEN SUM([IncrementalCurrentCustomers])&#10;    WHEN &apos;Incremental Reactivated Customers&apos; THEN SUM([IncrementalReactivatedCustomers])&#10;END' />
            </column>
            <column caption='vs. QTD Primary KPI' datatype='real' name='[P-KPI 1 MTD (copy)_301178266713153542]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;    WHEN &apos;Revenue&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL([Anchor Date Range MTD (copy)_301178266710245377]) THEN [Revenue]                 &#10;        END)&#10;&#10;    WHEN &apos;Orders&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [Orders]                 &#10;        END)&#10;       &#10;    WHEN &apos;Total Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [TotalCustomers]                 &#10;        END)&#10;&#10;    WHEN &apos;New Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [NewCustomers]                 &#10;        END)&#10;       &#10;    WHEN &apos;Current Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [CurrentCustomers]                 &#10;        END)&#10;        &#10; WHEN &apos;Reactivated Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [ReactivatedCustomers]                 &#10;        END)&#10;&#10;    WHEN &apos;Web Orders&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [WebOrders]                 &#10;        END)&#10;&#10;    WHEN &apos;Web Revenue&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [WebRevenue]                 &#10;        END)&#10;        &#10;    WHEN &apos;Web Traffic&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [WebTraffic]                 &#10;        END)&#10;&#10;    WHEN &apos;Incremental Revenue&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [MediaRevenue]                 &#10;        END)&#10;&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [RealizedMediaRevenue]                 &#10;        END)&#10;       &#10;    WHEN &apos;Future Incremental Revenue&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [FutureMediaRevenue]                 &#10;        END)&#10;       &#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [RealizedMediaRevenue]                 &#10;        END)&#10;       &#10; WHEN &apos;Media Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [MediaValue]                 &#10;        END)&#10;       &#10; WHEN &apos;Realized Media Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [RealizedMediaValue]                 &#10;        END)&#10;&#10; WHEN &apos;Future Media Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [FutureMediaValue]                 &#10;        END)&#10;     &#10;&#10;    WHEN &apos;EMR Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [EMRValue]                 &#10;        END)&#10;      &#10;  WHEN &apos;Incremental Total Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalTotalCustomers]                 &#10;        END)&#10;&#10;    WHEN &apos;Incremental New Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalNewCustomers]                 &#10;        END)&#10;       &#10;    WHEN &apos;Incremental Current Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalCurrentCustomers]                 &#10;        END)&#10;        &#10; WHEN &apos;Incremental Reactivated Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_301178266710245377]) THEN [IncrementalReactivatedCustomers]                 &#10;        END)&#10;&#10;       &#10;&#10;    END)' />
            </column>
            <column caption='vs. YTD Primary KPI' datatype='real' name='[P-KPI 1 MTD (copy)_992762284465725446]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(CASE [Parameters].[PL2 Active Metric Parameter (copy)_901282899119939639]&#10;    WHEN &apos;Revenue&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL([Anchor Date Range MTD (copy)_992762284465262597]) THEN [Revenue]                 &#10;        END)&#10;&#10;    WHEN &apos;Orders&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [Orders]                 &#10;        END)&#10;       &#10;    WHEN &apos;Total Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [TotalCustomers]                 &#10;        END)&#10;&#10;    WHEN &apos;New Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [NewCustomers]                 &#10;        END)&#10;       &#10;    WHEN &apos;Current Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [CurrentCustomers]                 &#10;        END)&#10;        &#10; WHEN &apos;Reactivated Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [ReactivatedCustomers]                 &#10;        END)&#10;&#10;    WHEN &apos;Web Orders&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [WebOrders]                 &#10;        END)&#10;&#10;    WHEN &apos;Web Revenue&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [WebRevenue]                 &#10;        END)&#10;        &#10;    WHEN &apos;Web Traffic&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [WebTraffic]                 &#10;        END)&#10;&#10;    WHEN &apos;Incremental Revenue&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [MediaRevenue]                 &#10;        END)&#10;&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [RealizedMediaRevenue]                 &#10;        END)&#10;       &#10;    WHEN &apos;Future Incremental Revenue&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [FutureMediaRevenue]                 &#10;        END)&#10;       &#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [RealizedMediaRevenue]                 &#10;        END)&#10;       &#10; WHEN &apos;Media Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [MediaValue]                 &#10;        END)&#10;       &#10; WHEN &apos;Realized Media Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [RealizedMediaValue]                 &#10;        END)&#10;&#10; WHEN &apos;Future Media Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [FutureMediaValue]                 &#10;        END)&#10;     &#10;&#10;    WHEN &apos;EMR Value&apos; THEN &#10;      SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [EMRValue]                 &#10;        END)&#10;      &#10;  WHEN &apos;Incremental Total Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [IncrementalTotalCustomers]                 &#10;        END)&#10;&#10;    WHEN &apos;Incremental New Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [IncrementalNewCustomers]                 &#10;        END)&#10;       &#10;    WHEN &apos;Incremental Current Customers&apos; THEN &#10;       SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [IncrementalCurrentCustomers]                 &#10;        END)&#10;        &#10; WHEN &apos;Incremental Reactivated Customers&apos; THEN &#10;     SUM(&#10;      IF NOT ISNULL( [Anchor Date Range MTD (copy)_992762284465262597]) THEN [IncrementalReactivatedCustomers]                 &#10;        END)&#10;&#10;       &#10;&#10;    END)' />
            </column>
