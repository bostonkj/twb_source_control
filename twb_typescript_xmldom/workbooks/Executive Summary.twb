        <calculation class='tableau' formula='IIF([Lower PL3 metric vs comp Difference (copy)_2637139079373791304] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;&#13;&#10;// Revenue deltas -&gt; currency formatting ($ + K/M/B)&#13;&#10;IF [Parameters].[Parameter 7] = &quot;Revenue&quot; THEN&#13;&#10;&#13;&#10;    IF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE &quot;$&quot; + STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304])))&#13;&#10;    END&#13;&#10;&#13;&#10;// Customer/order deltas -&gt; count formatting (K/M/B, no $)&#13;&#10;ELSEIF [Parameters].[Parameter 7] IN (&#13;&#10;    &quot;Total Customers&quot;, &quot;New Customers&quot;, &quot;Orders&quot;, &quot;Current Customers&quot;, &quot;Reactivated Customers&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 100000000000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 10000000000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 1000000000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 100000000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 10000000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 1000000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 100000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 10000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000, 1)) + &quot;K&quot;&#13;&#10;    ELSEIF ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) &gt; 1000 THEN STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304]) / 1000, 2)) + &quot;K&quot;&#13;&#10;    ELSE STR(ROUND(ABS([Lower PL3 metric vs comp Difference (copy)_2637139079373791304])))&#13;&#10;    END&#13;&#10;END' />
