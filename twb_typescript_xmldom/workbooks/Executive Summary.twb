      <column caption='Date Difference' datatype='integer' name='[Date Difference]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [Parameters].[Parameter 8], [Parameters].[Parameter 1])' />
