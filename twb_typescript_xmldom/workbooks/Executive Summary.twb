              <calculation class='tableau' formula='MIN &#13;&#10;(IF [Date]= DATETRUNC(&apos;week&apos;,TODAY(),&apos;saturday&apos;) THEN [MTD Date (copy)_301178266709913600] END)' />
            </column>
            <column caption='Anchor Start Date YTD' datatype='date' name='[Anchor Start Date MTD (copy)_992762284465217540]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='MIN &#13;&#10;(IF [Date]= DATETRUNC(&apos;week&apos;,TODAY(),&apos;saturday&apos;) THEN [Calculation_1654228464561578010] END)' />
