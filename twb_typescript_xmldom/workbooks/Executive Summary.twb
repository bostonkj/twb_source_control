          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='KPI 5' datatype='string' name='[K1-1 Active Metric Parameter (copy)_1329969288807166013]' param-domain-type='list' role='measure' type='nominal' value='&quot;EMR Value&quot;'>
              <calculation class='tableau' formula='&quot;EMR Value&quot;' />
            </column>
            <column caption='Order Type Param' datatype='string' name='[Parameter 12]' param-domain-type='list' role='measure' type='nominal' value='&quot;Enterprise&quot;'>
              <calculation class='tableau' formula='&quot;Enterprise&quot;' />
              <aliases>
                <alias key='&quot;Ecom&quot;' value='Ecom' />
              </aliases>
            </column>
            <column caption='Anchor End Date Param' datatype='date' default-format='*m/d/yyyy' default-value-field='[sqlproxy.0gs3wx61vvqjfu17bh93v1g4tnin].[Default Start Date (copy)_4140989541045669890]' name='[Parameter 1]' param-domain-type='range' role='measure' type='quantitative' value='#2026-07-04#'>
              <calculation class='tableau' formula='#2026-07-04#' />
              <range granularity='1' period-type-v2='day' />
            </column>
            <column caption='Anchor Start Date Param' datatype='date' default-format='*m/d/yyyy' default-value-field='[sqlproxy.0gs3wx61vvqjfu17bh93v1g4tnin].[Calculation_4140989541042946049]' name='[Parameter 8]' param-domain-type='range' role='measure' type='quantitative' value='#2026-05-31#'>
              <calculation class='tableau' formula='#2026-05-31#' />
              <range granularity='1' period-type-v2='day' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.0gs3wx61vvqjfu17bh93v1g4tnin'>
            <column caption='Anchor End Date' datatype='datetime' name='[Anchor Start Date (copy)_867505918082613251]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,[Parameters].[Parameter 1]+6,&apos;saturday&apos;)' />
            </column>
            <column caption='Total Web Revenue' datatype='real' name='[Calculation_0192155402866689]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM({ FIXED [Date]:MIN(IF [Calculation_123286066946166785] THEN [DailyTotalWebRevenue] END)})' />
            </column>
            <column caption='Total Spend' datatype='real' name='[Calculation_0192155404615684]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM({ FIXED [Date]:MIN(IF [Calculation_123286066946166785] THEN [DailyTotalSpend] END)})' />
            </column>
            <column caption='Date Filter' datatype='boolean' name='[Calculation_123286066946166785]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Date]&gt;=[Calculation_2637139079381286990] and [Date]&lt;=[Anchor Start Date (copy)_867505918082613251]' />
            </column>
            <column caption='Anchor Start Date' datatype='datetime' name='[Calculation_2637139079381286990]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,[Parameters].[Parameter 8],&apos;sunday&apos;)' />
            </column>
            <column caption='Channel Has Spend' datatype='boolean' name='[Calculation_2727985147991842816]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Keep entire channels if any row has Spend &gt; 0 or Spend is NOT NULL&#10;{ FIXED [Calculation_123286066946166785], [Channel]:&#10;    MAX(&#10;      IIF( IFNULL([Calculation_2727985148704944162], 0) &gt; 0, 1, 0 )&#10;//      IIF( IFNULL([Spend], 0) &gt; 0, 1, 0 )&#10;    )&#10;} = 1' />
            </column>
            <column caption='EMR Return' datatype='real' name='[Calculation_2727985148330471427]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM&#10;    (&#10;    IF [Calculation_2727985147991842816]=TRUE THEN [EMRValue] END) &#10;    ) &#10;    /SUM([Calculation_2727985148704944162])' />
            </column>
            <column caption='Media iROAS' datatype='real' name='[Calculation_2727985148333301764]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM&#10;    (IF [Calculation_2727985147991842816] = TRUE THEN [MediaRevenue] END)&#10;    )&#10;    /SUM([Calculation_2727985148704944162])' />
            </column>
            <column caption='Spend All' datatype='real' name='[Calculation_2727985148704944162]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{ FIXED [Date], [Channel], [Subchannel]: SUM([Spend]) }' />
            </column>
            <column caption='Default Start Date' datatype='datetime' datatype-customized='true' name='[Calculation_4140989541042946049]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='//DATE(DATETRUNC(&apos;week&apos;, DATEADD(&apos;week&apos;, -4, TODAY())))&#13;&#10;&#13;&#10;{FIXED: DATEADD(&apos;week&apos;, -4, DATETRUNC(&apos;week&apos;, MAX(IF NOT ISNULL([EMRValue]) OR NOT ISNULL([RealizedMediaRevenue]) OR NOT ISNULL([MediaRevenue]) THEN [Date] END)))}' />
            </column>
            <column caption='Exclude Channel' datatype='boolean' name='[Calculation_4512817981216530440]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='NOT(REGEXP_MATCH([Channel],&#10;    &quot;.*(All|Base|Direct$|Internal|Other|Referring Domains|Unknown|Uninfluenced|Unmatched).*&quot;))' />
            </column>
            <column caption='Order Type Filter' datatype='boolean' name='[Calculation_985725394907299840]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 12]&#13;&#10;WHEN &apos;Enterprise&apos; THEN [OrderType (copy)_2727985147994247169] = [OrderType (copy)_2727985147994247169]&#13;&#10;WHEN &apos;Ecom&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;Ecom&apos;&#13;&#10;WHEN &apos;Store&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;Store&apos;&#13;&#10;WHEN &apos;App&apos; THEN [OrderType (copy)_2727985147994247169] = &apos;App&apos;&#13;&#10;END' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[Channel]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[Clicks]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[DailyTotalSpend]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[DailyTotalWebRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[Date]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
            <column caption='Default End Date' datatype='datetime' datatype-customized='true' name='[Default Start Date (copy)_4140989541045669890]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='//DATE(DATEADD(&apos;day&apos;, -1, DATETRUNC(&apos;week&apos;, TODAY())))&#13;&#10;&#13;&#10;{FIXED: DATEADD(&apos;day&apos;, 6, DATETRUNC(&apos;week&apos;, MAX(IF NOT ISNULL([EMRValue]) OR NOT ISNULL([RealizedMediaRevenue]) OR NOT ISNULL([MediaRevenue]) THEN [Date] END)))}' />
            </column>
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[EMRValue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FutureMediaRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[FutureMediaValue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[Impressions]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[IncrementalCurrentCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[IncrementalNewCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[IncrementalReactivatedCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[IncrementalTotalCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column caption='KPI 5 Tooltip' datatype='string' name='[KPI 2-1 TY (copy)_2290080459186708485]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013]&#13;&#10;    WHEN &apos;Spend&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;     &#13;&#10;    WHEN &apos;CPM&apos; THEN &apos;Spend / Impressions * 1000&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Impressions&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;CTR&apos; THEN &apos;Clicks / Impressions&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;        &#13;&#10;    WHEN &apos;CPC&apos; THEN &apos;Spend / Clicks&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Clicks&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web CVR&apos; THEN &apos;Web Orders / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;    WHEN &apos;Total Web Revenue&apos; THEN &apos;Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;% Total Web Revenue&apos; THEN &apos;Selected Web Revenue/Total Web Revenue for Selected Date Range&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web RPV&apos; THEN &apos;Web Revenue / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web CPO&apos; THEN &apos;Spend / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;  &#13;&#10;    WHEN &apos;Web Orders&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web AOV&apos; THEN &apos;Web Revenue / Web Orders&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;       &#13;&#10;    WHEN &apos;Web Revenue&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web ROAS&apos; THEN &apos;Web Revenue / Spend&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Web Traffic&apos; THEN &apos;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;           &#13;&#10;    WHEN &apos;Web CPV&apos; THEN &apos;Spend / Web Traffic&#13;&#10;Sourced from Web Analytics (Adobe)&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Incremental Revenue&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;iROAS&apos; THEN &apos;Media Revenue / Spend&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Realized iROAS&apos; THEN &apos;Realized Media Revenue / Spend&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Future Incremental Revenue&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Future iROAS&apos; THEN &apos;Future Media Revenue / Spend&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Media Value&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Media Return&apos; THEN &apos;Media value / Spend&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Realized Media Value&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;          &#13;&#10;   WHEN &apos;Realized Media Return&apos; THEN &apos;Realized Media Value / Spend&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;       &#13;&#10;    WHEN &apos;Future Media Value&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;   WHEN &apos;Future Media Return&apos; THEN &apos;Future Media Value / Spend&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;EMR Value&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;   WHEN &apos;EMR Return&apos; THEN &apos;EMR Value/ Spend&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Incremental Total Customers&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Incremental New Customers&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;New Customer iCPA&apos; THEN &apos;Spend / Incremental New Customers&#13;&#10;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Incremental Current Customers&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Incremental Reactivated Customers&apos; THEN &apos;Sourced from MMM+&apos;&#13;&#10;&#13;&#10;&#13;&#10;    WHEN &apos;Platform CVR&apos; THEN &apos;Platform Orders / Clicks&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;     &#13;&#10;  WHEN &apos;Platform Orders&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;    WHEN &apos;Platform AOV&apos; THEN &apos;Platform Revenue / Platform Orders&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;  WHEN &apos;Platform Revenue&apos; THEN &apos;Sourced from Media Platforms&apos;&#13;&#10; &#13;&#10;   WHEN &apos;Platform ROAS&apos; THEN &apos;Platform Revenue / Spend&#13;&#10;Sourced from Media Platforms&apos;&#13;&#10;&#13;&#10;&#13;&#10;END' />
