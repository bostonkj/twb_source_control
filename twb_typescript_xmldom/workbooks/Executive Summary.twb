            <column caption='Default End Date' datatype='datetime' datatype-customized='true' name='[Default Start Date (copy)_4140989541045669890]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='//DATE(DATEADD(&apos;day&apos;, -1, DATETRUNC(&apos;week&apos;, TODAY())))&#13;&#10;&#13;&#10;{FIXED: DATEADD(&apos;day&apos;, 6, DATETRUNC(&apos;week&apos;, MAX(IF NOT ISNULL([EMRValue]) OR NOT ISNULL([RealizedMediaRevenue]) OR NOT ISNULL([MediaRevenue]) THEN [Date] END)))}' />
            </column>
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[EMRValue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column caption='KPI 3 Tooltip' datatype='string' name='[KPI 1-1 Tooltip (copy 3)_2290080459185737732]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[K1-1 Active Metric Parameter (copy)_2637139079337299991]&#13;&#10;    &#13;&#10;    WHEN &apos;Traffic&apos; THEN &apos;Web Traffic + Store Traffic&apos;&#13;&#10;    ELSE &apos;Sourced from CRM&apos;&#13;&#10;&#13;&#10;END' />
            </column>
            <column caption='KPI 3' datatype='real' name='[KPI1-1 This Year (copy) (copy)_2030841979801784325]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[K1-1 Active Metric Parameter (copy)_2637139079337299991]&#13;&#10;&#13;&#10;    WHEN &apos;Total Customers&apos; THEN SUM([TotalCustomers])&#13;&#10;    &#13;&#10;    WHEN &apos;New Customers&apos; THEN SUM([NewCustomers])&#13;&#10;&#13;&#10;    WHEN &apos;Current Customers&apos; THEN SUM([CurrentCustomers])&#13;&#10;&#13;&#10;    WHEN &apos;Reactivated Customers&apos; THEN SUM([ReactivatedCustomers])&#13;&#10;&#13;&#10;    WHEN &apos;Revenue&apos; THEN SUM([Revenue])&#13;&#10;    &#13;&#10;   WHEN &apos;Orders&apos; THEN SUM([Orders])&#13;&#10;&#13;&#10;END' />
            </column>
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[MediaRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[NewCustomers]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='Order Type' datatype='string' name='[OrderType (copy)_2727985147994247169]' role='dimension' type='nominal'>
