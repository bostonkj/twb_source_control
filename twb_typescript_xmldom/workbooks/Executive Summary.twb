            <column caption='KPI 7' datatype='string' name='[K2-2 Active Metric Parameter (copy)_1255096945751805953]' param-domain-type='list' role='measure' type='nominal' value='&quot;Incremental Current Customers&quot;'>
              <calculation class='tableau' formula='&quot;Incremental Current Customers&quot;' />
