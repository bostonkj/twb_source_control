              <calculation class='tableau' formula='MIN &#13;&#10;(IF [Date]= DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1, TODAY()),&apos;saturday&apos;) THEN [Calculation_1654228464561578010] END)' />
