      <column caption='vs. Plan KPI 5 (#) Output' datatype='string' name='[KPI 2-1 LY Difference Str (copy)_1146729096343560192]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IIF([KPI 2-1 Period Difference (copy)_1793840067787829252] &gt;= 0, &quot;▲&quot;, &quot;▼&quot;)&#13;&#10;+&#13;&#10;&#13;&#10;// $ metrics -&gt; currency formatting ($ + K/M/B)&#13;&#10;IF [Parameters].[K1-1 Active Metric Parameter (copy)_1329969288807166013] IN (&#13;&#10;    &quot;Spend&quot;, &quot;Total Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Incremental Revenue&quot;,&quot;Realized Incremental Revenue&quot;,&quot;Future Incremental Revenue&quot;,&#13;&#10;    &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#13;&#10;) THEN&#13;&#10;&#13;&#10;    IF ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) / 1000000000)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;    ELSEIF ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) / 1000000)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;    ELSEIF ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI 2-1 Period Difference (copy)_1793840067787829252]) / 