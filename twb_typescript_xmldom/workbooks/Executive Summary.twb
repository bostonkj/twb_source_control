              <calculation class='tableau' formula='SUM(IF ([Calculation_1714182672546091008]) = &quot;TY&quot; AND [Parameters].[Parameter 12] = &apos;Store&apos; THEN [Calculation_2727985148704944162]&#10;    ELSEIF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [Spend] END)' />
