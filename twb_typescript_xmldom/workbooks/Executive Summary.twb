              <calculation class='tableau' formula='CASE [Parameters].[K2-2 Active Metric Parameter (copy)_1255096945751805953]&#10;&#10;    WHEN &apos;Spend&apos; THEN SUM([Spend All (copy)_3996311395817148417])&#10;    WHEN &apos;Total Spend&apos; THEN [Calculation_0192155404906503]&#10;    WHEN &apos;% Total Spend&apos; THEN&#10;        SUM([Spend All (copy)_3996311395817148417]) / [Calculation_0192155404906503]&#10;    WHEN &apos;CPM&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanImpressions]) * 1000)&#10;    WHEN &apos;Impressions&apos; THEN SUM([PlanImpressions])&#10;    WHEN &apos;CTR&apos; THEN (SUM([PlanClicks]) / SUM([PlanImpressions]))&#10;    WHEN &apos;CPC&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanClicks]))&#10;    WHEN &apos;Clicks&apos; THEN SUM([PlanClicks])&#10;    WHEN &apos;Web CVR&apos; THEN (SUM([PlanWebOrders]) / SUM([PlanWebTraffic]))&#10;    WHEN &apos;Web CPO&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebOrders]))&#10;    WHEN &apos;Web Orders&apos; THEN SUM([PlanWebOrders])&#10;    WHEN &apos;Web AOV&apos; THEN (SUM([PlanWebRevenue]) / SUM([PlanWebOrders]))&#10;    WHEN &apos;Web Revenue&apos; THEN SUM([PlanWebRevenue])&#10;&#10;    WHEN &apos;Total Web Revenue&apos; THEN [Calculation_0192155404361731]&#10;    WHEN &apos;% Total Web Revenue&apos; THEN&#10;        SUM([PlanWebRevenue]) / [Calculation_0192155404361731]&#10;&#10;    WHEN &apos;Web ROAS&apos; THEN (SUM([PlanWebRevenue]) / SUM([PlanSpend]))&#10;    WHEN &apos;Web Traffic&apos; THEN SUM([PlanWebTraffic])&#10;    WHEN &apos;Web CPV&apos; THEN (SUM([Spend All (copy)_3996311395817148417]) / SUM([PlanWebTraffic]))&#10;    WHEN &apos;Incremental Revenue&apos; THEN SUM([PlanMediaRevenue])&#10;    WHEN &apos;iROAS&apos; THEN [Media iROAS LY (copy)_2727985148349190165]&#10;    WHEN &apos;Realized Incremental Revenue&apos; THEN SUM([PlanRealizedMediaRevenue])&#10;    WHEN &apos;Realized iROAS&apos; THEN [Realized iROAS L