          <datasource-dependencies datasource='sqlproxy.0gs3wx61vvqjfu17bh93v1g4tnin'>
            <column caption='Anchor End Date' datatype='datetime' name='[Anchor Start Date (copy)_867505918082613251]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;week&apos;,[Parameters].[Parameter 1]+6,&apos;saturday&apos;)' />
            </column>
            <column caption='Anchor Start Date YTD' datatype='date' name='[Anchor Start Date MTD (copy)_992762284465217540]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='MIN &#13;&#10;(IF [Date]= DATETRUNC(&apos;week&apos;,TODAY(),&apos;saturday&apos;) THEN [Calculation_1654228464561578010] END)' />
            </column>
            <column caption='Anchor Start Date YTD LY' datatype='date' name='[Anchor Start Date YTD (copy)_301178266734993423]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='MIN &#13;&#10;(IF [Date]= DATETRUNC(&apos;week&apos;,DATEADD(&apos;year&apos;,-1, TODAY()),&apos;saturday&apos;) THEN [Calculation_1654228464561578010] END)' />
            </column>
            <column caption='vs. Spend TY' datatype='real' default-format='c&quot;$&quot;#,##0;&quot;$&quot;-#,##0' name='[Calculation_1146729096399511572]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF ([Calculation_1714182672546091008]) = &quot;TY&quot; AND [Parameters].[Parameter 12] = &apos;Store&apos; THEN [Calculation_2727985148704944162]&#10;    ELSEIF [Calculation_1714182672546091008] = &apos;TY&apos; THEN [Spend] END)' />
            </column>
            <column caption='MIN(0)' datatype='integer' name='[Calculation_1220194083385286677]' role='measure' type='quantitative' user:unnamed='KPI 2-0 Plan %'>
