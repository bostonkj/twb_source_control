              <calculation class='tableau' formula='// Revenue -&gt; currency formatting ($ + K/M/B), using ABS like original&#13;&#10;IF [Parameters].[K1-1 Active Metric Parameter (copy)_2637139079346167835] = &quot;Revenue&quot; THEN&#13;&#10;&#13;&#10;        IF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000000)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000)) + &quot;K&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000, 1)) + &quot;K&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000, 2)) + &quot;K&quot;&#13;&#10;        ELSE &quot;$&quot; + STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480])))&#13;&#10;        END&#13;&#10;&#13;&#10;    // Customer/order counts -&gt; K/M/B, using ABS like original&#13;&#10;    ELSEIF [Parameters].[K1-1 Active Metric Parameter (copy)_2637139079346167835] IN (&#13;&#10;        &quot;Total Customers&quot;, &quot;New Customers&quot;, &quot;Orders&quot;, &quot;Current Customers&quot;, &quot;Reactivated Customers&quot;&#13;&#10;    ) THEN&#13;&#10;&#13;&#10;        IF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 100000000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000000)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 10000000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000000, 1)) + &quot;B&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 1000000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000000, 2)) + &quot;B&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 100000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 10000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000, 1)) + &quot;M&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 1000000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000000, 2)) + &quot;M&quot;&#13;&#10;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) &gt; 100000 THEN STR(ROUND(ABS([KPI1-1 This Year (copy 2)_2030841979801833480]) / 1000)) + &quot;K&quot;&#13;&#10;        ELSEIF ABS([KPI1-1 This Year (cop