            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[WebOrders]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Sum' datatype='real' default-type='quantitative' layered='true' name='[WebRevenue]' pivot='key' role='measure' type='quantitative' user-datatype='real' visual-totals='Default' />
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[WebTraffic]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column-instance column='[KPI 2-1 Tooltip (copy)_2290080459209846790]' derivation='Attribute' name='[attr:KPI 2-1 Tooltip (copy)_2290080459209846790:nk]' pivot='key' type='nominal' />
            <column caption='KPI 6 Output' datatype='string' name='[kpi2-1 str this year (copy)_1570067444782387214]' role='measure' type='nominal'>
              <calculation class='tableau' formula='// Currency metrics -&gt; $ + K/M/B&#10;IF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#10;        &quot;Spend&quot;, &quot;Total Spend&quot;, &quot;Web Revenue&quot;,&quot;Total Web Revenue&quot;,&quot;Incremental Revenue&quot;,&quot;Realized Incremental Revenue&quot;,&quot;Future Incremental Revenue&quot;,&#10;        &quot;Media Value&quot;,&quot;Realized Media Value&quot;,&quot;Future Media Value&quot;,&quot;EMR Value&quot;,&quot;Platform Revenue&quot;&#10;    ) THEN&#10;&#10;        IF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 100000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000000)) + &quot;B&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 10000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000000, 1)) + &quot;B&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 1000000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 100000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000)) + &quot;M&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 10000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000, 1)) + &quot;M&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 1000000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 100000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000)) + &quot;K&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 10000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000, 1)) + &quot;K&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 1000 THEN &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000, 2)) + &quot;K&quot;&#10;        ELSE &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836])))&#10;        END&#10;&#10;    // Count metrics -&gt; K/M/B (no $)&#10;    ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#10;        &quot;Impressions&quot;,&quot;Clicks&quot;,&quot;Web Orders&quot;,&quot;Web Traffic&quot;,&#10;        &quot;Incremental Total Customers&quot;,&quot;Incremental New Customers&quot;,&quot;Incremental Current Customers&quot;,&quot;Incremental Reactivated Customers&quot;,&#10;        &quot;Platform Orders&quot;&#10;    ) THEN&#10;&#10;        IF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 100000000000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000000)) + &quot;B&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 10000000000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000000, 1)) + &quot;B&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 1000000000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000000, 2)) + &quot;B&quot;&#10;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 100000000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000)) + &quot;M&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 10000000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000, 1)) + &quot;M&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 1000000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000000, 2)) + &quot;M&quot;&#10;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 100000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000)) + &quot;K&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 10000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000, 1)) + &quot;K&quot;&#10;        ELSEIF ABS([KPI2-1 This Year (copy)_742812488104312836]) &gt; 1000 THEN STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]) / 1000, 2)) + &quot;K&quot;&#10;        ELSE STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836])))&#10;        END&#10;&#10;    // Rate metrics -&gt; $ + 2 decimals&#10;    ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&#10;        &quot;CPM&quot;,&quot;CPC&quot;,&quot;Web CPO&quot;,&quot;Web AOV&quot;,&quot;Web ROAS&quot;,&quot;Web CPV&quot;,&quot;Web RPV&quot;,&#10;        &quot;iROAS&quot;,&quot;Realized iROAS&quot;,&quot;Future iROAS&quot;,&#10;        &quot;Media Return&quot;,&quot;Realized Media Return&quot;,&quot;Future Media Return&quot;,&#10;        &quot;EMR Return&quot;,&quot;New Customer iCPA&quot;,&#10;        &quot;Platform AOV&quot;,&quot;Platform ROAS&quot;&#10;    ) THEN&#10;        &quot;$&quot; + STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836]), 2))&#10;&#10;    // Percent metrics -&gt; xx.xx%&#10;    ELSEIF [Parameters].[K2-1 Active Metric Parameter (copy)_742812488103804929] IN (&quot;CTR&quot;,&quot;Web CVR&quot;,&quot;Platform CVR&quot;, &quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;        STR(ROUND(ABS([KPI2-1 This Year (copy)_742812488104312836])*100, 2)) + &quot;%&quot;&#10;/*&#10;    // Special percent -&gt; value*100%&#10;    ELSEIF [Parameters].[KPI 6] IN (&quot;% Total Web Revenue&quot;, &quot;% Total Spend&quot;) THEN&#10;        STR(ROUND([KPI 6] * 100, 2)) + &quot;%&quot;&#10;*/&#10;END' />
